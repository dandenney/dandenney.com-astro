---
import type { CaseExhibit } from "@/data/cases/types";

/**
 * The evidence gallery in the case-file identity: an exhibit wall of
 * photographs and documents at their natural aspect ratios, each with a
 * mono evidence tag, opening into a dossier viewer (native <dialog>) that
 * pairs the full image with its rich caption. Exhibit bodies are trusted
 * HTML authored in the case data file. Index chips and viewer rules pick
 * up the shared semantic tones (lastSeen amber, remains red, ...).
 * Expects Archivo + Fragment Mono on the page, like the other components.
 */
interface Props {
  exhibits: CaseExhibit[];
}

const { exhibits } = Astro.props;
const pad = (n: number) => String(n + 1).padStart(2, "0");
const total = pad(exhibits.length - 1);
---

<div class="cg" data-case-gallery>
  <ol class="cg-wall" role="list">
    {exhibits.map((ex, i) => (
      <li class="cg-item" data-tone={ex.tone ?? "plain"}>
        <button
          type="button"
          class="cg-open"
          data-exhibit-trigger={i}
          aria-haspopup="dialog"
          aria-label={`Open exhibit ${pad(i)}, ${ex.title}`}
        >
          <span class="cg-frame">
            <img
              src={ex.src}
              width={ex.width}
              height={ex.height}
              alt={ex.alt}
              loading="lazy"
              decoding="async"
            />
          </span>
          <span class="cg-tag">
            <span class="cg-index">{pad(i)}</span>
            <span class="cg-tag-text">
              <span class="cg-kind">{ex.kindLabel ?? "Exhibit"}</span>
              <span class="cg-name">{ex.title}</span>
            </span>
            <span class="cg-plus" aria-hidden="true">+</span>
          </span>
        </button>
      </li>
    ))}
  </ol>

  <dialog class="cg-viewer" aria-label="Exhibit viewer">
    <header class="cg-bar">
      <p class="cg-count">
        <span data-exhibit-count>01</span>
        <span class="cg-count-sep">/</span>
        <span>{total}</span>
      </p>
      <div class="cg-controls">
        <button type="button" class="cg-btn" data-exhibit-prev aria-label="Previous exhibit">&larr;</button>
        <button type="button" class="cg-btn" data-exhibit-next aria-label="Next exhibit">&rarr;</button>
        <button type="button" class="cg-btn cg-btn-close" data-exhibit-close aria-label="Close exhibit viewer">
          Close
        </button>
      </div>
    </header>
    <div class="cg-slides">
      {exhibits.map((ex, i) => (
        <figure class="cg-slide" data-exhibit-slide={i} data-tone={ex.tone ?? "plain"} hidden>
          <div class="cg-media">
            <img
              src={ex.src}
              width={ex.width}
              height={ex.height}
              alt={ex.alt}
              loading="lazy"
              decoding="async"
            />
          </div>
          <figcaption class="cg-panel">
            <p class="cg-kicker">
              <span class="cg-kicker-index">Exhibit {pad(i)}</span>
              {ex.kindLabel && <span class="cg-kicker-kind">{ex.kindLabel}</span>}
            </p>
            <h3 class="cg-title">{ex.title}</h3>
            {ex.dateLabel && <p class="cg-date">{ex.dateLabel}</p>}
            {ex.body && <div class="cg-body" set:html={ex.body} />}
            {ex.credit && <p class="cg-credit">{ex.credit}</p>}
          </figcaption>
        </figure>
      ))}
    </div>
  </dialog>
</div>

<script>
  const galleries = document.querySelectorAll<HTMLElement>("[data-case-gallery]");

  galleries.forEach((root) => {
    const viewer = root.querySelector<HTMLDialogElement>(".cg-viewer");
    if (!viewer || typeof viewer.showModal !== "function") return;

    const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-exhibit-slide]"));
    const counter = root.querySelector<HTMLElement>("[data-exhibit-count]");
    const triggers = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-exhibit-trigger]"));
    let current = 0;

    const show = (index: number) => {
      current = (index + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        slide.hidden = i !== current;
      });
      if (counter) counter.textContent = String(current + 1).padStart(2, "0");
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        show(Number(trigger.dataset.exhibitTrigger));
        viewer.showModal();
        document.documentElement.classList.add("cg-lock");
      });
    });

    viewer.addEventListener("close", () => {
      document.documentElement.classList.remove("cg-lock");
    });

    root.querySelector("[data-exhibit-prev]")?.addEventListener("click", () => show(current - 1));
    root.querySelector("[data-exhibit-next]")?.addEventListener("click", () => show(current + 1));
    root.querySelector("[data-exhibit-close]")?.addEventListener("click", () => viewer.close());

    viewer.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") show(current - 1);
      if (event.key === "ArrowRight") show(current + 1);
    });

    // Close on backdrop click: the dialog itself is only the click target
    // when the pointer lands outside the frame's content areas.
    viewer.addEventListener("pointerdown", (event) => {
      if (event.target === viewer) viewer.close();
    });

  });
</script>

<style>
  .cg {
    --cg-bg: #0b0d12;
    --cg-panel: rgba(233, 235, 239, 0.03);
    --cg-ink: #e9ebef;
    --cg-ink-2: #a3abba;
    --cg-ink-3: #666e7d;
    --cg-hairline: rgba(233, 235, 239, 0.14);
    --cg-accent: #e3a94f;
    --cg-lastseen: #e3a94f;
    --cg-remains: #e05252;
    --cg-sighting: #62b6cb;
    --cg-poi: #9aa3b2;
    --cg-residence: #edf1f7;
    --cg-charge: #b487e0;
    --cg-conviction: #58b98a;
    --cg-mono: "Fragment Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    --cg-sans: "Archivo", system-ui, sans-serif;

    font-family: var(--cg-sans);
    color: var(--cg-ink);
  }

  .cg-item[data-tone="lastSeen"] { --cg-tone: var(--cg-lastseen); }
  .cg-item[data-tone="remains"],
  .cg-item[data-tone="trace"] { --cg-tone: var(--cg-remains); }
  .cg-item[data-tone="sighting"],
  .cg-item[data-tone="lead"] { --cg-tone: var(--cg-sighting); }
  .cg-item[data-tone="poi"] { --cg-tone: var(--cg-poi); }
  .cg-item[data-tone="residence"] { --cg-tone: var(--cg-residence); }
  .cg-item[data-tone="charge"] { --cg-tone: var(--cg-charge); }
  .cg-item[data-tone="conviction"] { --cg-tone: var(--cg-conviction); }
  .cg-item[data-tone="plain"] { --cg-tone: var(--cg-ink-2); }

  /* ---------- Exhibit wall ---------- */

  .cg-wall {
    margin: 0;
    padding: 0;
    list-style: none;
    columns: 3;
    column-gap: clamp(1rem, 2vw, 1.5rem);
  }

  .cg-item {
    break-inside: avoid;
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
  }

  .cg-open {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: none;
    color: inherit;
    font: inherit;
    text-align: left;
    cursor: zoom-in;
  }

  .cg-open:focus-visible {
    outline: 2px solid var(--cg-accent);
    outline-offset: 4px;
  }

  .cg-frame {
    display: block;
    overflow: hidden;
    border: 1px solid var(--cg-hairline);
    background: var(--cg-panel);
  }

  .cg-frame img {
    display: block;
    width: 100%;
    height: auto;
    filter: saturate(0.82);
    transition: filter 300ms ease, transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cg-tag {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.7rem 0.125rem 0;
  }

  .cg-index {
    font-family: var(--cg-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: var(--cg-tone);
  }

  .cg-tag-text {
    display: block;
    flex: 1;
    min-width: 0;
  }

  .cg-kind {
    display: block;
    margin-bottom: 0.2rem;
    font-family: var(--cg-mono);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cg-ink-3);
  }

  .cg-name {
    display: block;
    font-size: 0.9375rem;
    font-weight: 640;
    font-variation-settings: "wdth" 106;
    line-height: 1.3;
    color: var(--cg-ink);
  }

  .cg-plus {
    font-family: var(--cg-mono);
    font-size: 0.75rem;
    color: var(--cg-ink-3);
    transition: color 200ms ease;
  }

  @media (hover: hover) {
    .cg-open:hover .cg-frame img {
      filter: saturate(1);
      transform: scale(1.025);
    }

    .cg-open:hover .cg-plus {
      color: var(--cg-accent);
    }
  }

  /* Scroll-driven reveal where supported; elsewhere the wall is simply visible */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .cg-item {
        animation: cg-in linear both;
        animation-timeline: view();
        animation-range: entry 5% entry 65%;
      }
    }
  }

  @keyframes cg-in {
    from {
      opacity: 0;
      translate: 0 18px;
    }
  }

  /* ---------- Viewer ---------- */

  .cg-viewer {
    box-sizing: border-box;
    width: min(94vw, 74rem);
    max-height: min(94dvh, 60rem);
    margin: auto;
    padding: 0;
    border: 1px solid var(--cg-hairline);
    background: var(--cg-bg);
    color: var(--cg-ink);
  }

  .cg-viewer::backdrop {
    background: rgba(4, 5, 8, 0.88);
  }

  .cg-viewer[open] {
    display: flex;
    flex-direction: column;
    animation: cg-raise 360ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cg-viewer[open]::backdrop {
    animation: cg-dim 360ms ease;
  }

  @keyframes cg-raise {
    from {
      opacity: 0;
      translate: 0 12px;
    }
  }

  @keyframes cg-dim {
    from {
      opacity: 0;
    }
  }

  :global(html.cg-lock) {
    overflow: hidden;
  }

  .cg-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--cg-hairline);
  }

  .cg-count {
    margin: 0;
    font-family: var(--cg-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--cg-ink-2);
  }

  .cg-count-sep {
    color: var(--cg-ink-3);
  }

  .cg-controls {
    display: flex;
    gap: 0.5rem;
  }

  .cg-btn {
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--cg-hairline);
    background: none;
    color: var(--cg-ink-2);
    font-family: var(--cg-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .cg-btn:hover {
    color: var(--cg-ink);
    border-color: rgba(233, 235, 239, 0.4);
  }

  .cg-btn:focus-visible {
    outline: 2px solid var(--cg-accent);
    outline-offset: 2px;
  }

  .cg-btn-close {
    text-transform: uppercase;
  }

  .cg-slides {
    flex: 1;
    min-height: 0;
  }

  .cg-slide {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 24rem);
    height: 100%;
    margin: 0;
    animation: cg-settle 320ms ease;
  }

  .cg-slide[hidden] {
    display: none;
  }

  @keyframes cg-settle {
    from {
      opacity: 0;
    }
  }

  .cg-slide[data-tone="lastSeen"] { --cg-tone: var(--cg-lastseen); }
  .cg-slide[data-tone="remains"],
  .cg-slide[data-tone="trace"] { --cg-tone: var(--cg-remains); }
  .cg-slide[data-tone="sighting"],
  .cg-slide[data-tone="lead"] { --cg-tone: var(--cg-sighting); }
  .cg-slide[data-tone="poi"] { --cg-tone: var(--cg-poi); }
  .cg-slide[data-tone="residence"] { --cg-tone: var(--cg-residence); }
  .cg-slide[data-tone="charge"] { --cg-tone: var(--cg-charge); }
  .cg-slide[data-tone="conviction"] { --cg-tone: var(--cg-conviction); }
  .cg-slide[data-tone="plain"] { --cg-tone: var(--cg-accent); }

  .cg-media {
    display: grid;
    place-items: center;
    min-height: 0;
    padding: clamp(1rem, 3vw, 2.5rem);
    background: #07080c;
  }

  .cg-media img {
    max-width: 100%;
    max-height: calc(min(94dvh, 60rem) - 8rem);
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .cg-panel {
    min-height: 0;
    overflow-y: auto;
    padding: clamp(1.25rem, 2.5vw, 2rem);
    border-left: 1px solid var(--cg-hairline);
    box-shadow: inset 0 2px 0 var(--cg-tone);
  }

  .cg-kicker {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin: 0 0 1rem;
    font-family: var(--cg-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .cg-kicker-index {
    color: var(--cg-tone);
  }

  .cg-kicker-kind {
    color: var(--cg-ink-3);
  }

  .cg-title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.3rem, 2.4vw, 1.7rem);
    font-weight: 820;
    font-variation-settings: "wdth" 112;
    line-height: 1.05;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .cg-date {
    margin: 0 0 1.25rem;
    font-family: var(--cg-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--cg-ink-2);
  }

  .cg-body :global(p) {
    margin: 0 0 0.9rem;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--cg-ink-2);
  }

  .cg-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .cg-body :global(a) {
    color: var(--cg-ink);
    text-decoration-color: rgba(233, 235, 239, 0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 200ms ease;
  }

  .cg-body :global(a:hover) {
    text-decoration-color: var(--cg-accent);
  }

  .cg-credit {
    margin: 1.25rem 0 0;
    padding-top: 0.9rem;
    border-top: 1px solid var(--cg-hairline);
    font-family: var(--cg-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    color: var(--cg-ink-3);
  }

  /* ---------- Small screens ---------- */

  @media (max-width: 899px) {
    .cg-wall {
      columns: 2;
    }
  }

  @media (max-width: 719px) {
    .cg-viewer {
      width: 100vw;
      max-width: 100vw;
      max-height: 100dvh;
      height: 100dvh;
      border: 0;
    }

    .cg-slide {
      grid-template-columns: 1fr;
      grid-template-rows: minmax(0, 1fr) auto;
    }

    .cg-media {
      padding: 1rem;
    }

    .cg-media img {
      max-height: 100%;
    }

    .cg-panel {
      max-height: 45dvh;
      border-left: 0;
    }
  }

  @media (max-width: 519px) {
    .cg-wall {
      columns: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cg-frame img {
      transition: filter 300ms ease;
    }

    .cg-open:hover .cg-frame img {
      transform: none;
    }

    .cg-viewer[open],
    .cg-viewer[open]::backdrop,
    .cg-slide {
      animation: none;
    }
  }
</style>
