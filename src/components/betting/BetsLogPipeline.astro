---
import type { DayLog } from "@/data/betsLog/types";

interface Props {
  log: DayLog;
}

const { log } = Astro.props;
const { candidates, harnesses, candidateTiers, finalDecision } = log;

const skipHarnesses = harnesses.filter((h) => h.pick === "skip");

function tierColor(t: number | null): string {
  if (t === 1) return "text-emerald-400 bg-emerald-900/40 border-emerald-700/50";
  if (t === 2) return "text-amber-400 bg-amber-900/40 border-amber-700/50";
  if (t === 3) return "text-red-400 bg-red-900/40 border-red-700/50";
  return "text-slate-600 bg-slate-800/40 border-slate-700/30";
}

const boardResultLabel: Record<string, string> = { win: "Win", loss: "Loss", void: "Void", push: "Push" };
const boardResultColor: Record<string, string> = {
  win: "text-emerald-400",
  loss: "text-red-400",
  void: "text-slate-400",
  push: "text-slate-400",
};

// Passed to the client script via define:vars
const pickConfig = candidates.map((c) => ({ id: c.id, color: c.color }));
const harnessConfig = harnesses.map((h) => ({ id: h.id, pick: h.pick }));
---

<!-- ── Pipeline ──────────────────────────────────────────────── -->
<div id="pipeline-container" class="relative w-full">

  <svg
    id="pipeline-svg"
    class="absolute inset-0 pointer-events-none overflow-visible"
    style="z-index:1; width:100%; height:100%;"
  ></svg>

  <div
    class="relative"
    style="display:grid; grid-template-columns:220px 1fr 220px; grid-template-rows:auto auto auto auto auto; row-gap:8px; column-gap:0; z-index:2;"
  >

    <!-- Left col: invisible SKIP spacer (row 1) -->
    <div style="grid-column:1; grid-row:1; padding-right:20px; visibility:hidden;" aria-hidden="true">
      <div class="rounded-lg border border-slate-700 p-3 text-xs" style="min-height:64px;"></div>
    </div>

    <!-- Left col: candidate pick cards (rows 2–N+1) -->
    {candidates.map((c, i) => (
      <div style={`grid-column:1; grid-row:${i + 2}; padding-right:20px;`}>
        <div
          id={`pick-${c.id}`}
          class="rounded-lg border border-slate-700 bg-slate-900 p-3 text-xs h-full"
          style={`border-left-color:${c.color}; border-left-width:3px;`}
        >
          <div class="flex items-center gap-1.5 mb-1.5">
            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400 bg-slate-800 px-1.5 py-0.5 rounded">
              {c.sport}
            </span>
            <span class="text-[10px] text-slate-500">{c.gameTime}</span>
          </div>
          <div class="font-semibold text-white text-sm leading-tight">{c.player}</div>
          <div class="text-slate-500 text-[10px]">{c.matchup}</div>
          <div class="mt-2 flex items-baseline gap-1 text-xs">
            <span class={c.direction === "Under" ? "text-blue-400 font-medium" : "text-amber-400 font-medium"}>
              {c.direction}
            </span>
            <span class="text-white font-bold">{c.line}</span>
            <span class="text-slate-500">{c.market}</span>
            <span class="ml-auto text-slate-400">{c.odds}</span>
          </div>
          <div class="mt-1.5 grid grid-cols-3 gap-x-2 text-[10px]">
            <div>
              <div class="text-slate-600">Rithmm</div>
              <div class="text-emerald-400 font-semibold">{c.rithmm}%</div>
            </div>
            <div>
              <div class="text-slate-600">DTM</div>
              <div class={`font-semibold ${c.dtm > 10 ? "text-red-400" : "text-slate-300"}`}>{c.dtm}%</div>
            </div>
            <div>
              <div class="text-slate-600">Recent</div>
              <div class="text-slate-300">{c.recent}</div>
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- Center col: harness nodes (spans all rows) -->
    <div
      style={`grid-column:2; grid-row:1/${candidates.length + 2}; display:flex; align-items:center; justify-content:center;`}
    >
      <div class="flex items-center gap-1">
        {harnesses.map((h) => (
          <div class="flex flex-col items-center gap-1.5">
            <div
              id={`hnode-${h.id}`}
              class="w-14 h-14 rounded-full border-2 flex items-center justify-center font-bold bg-slate-900"
              style={`border-color:${h.color}; box-shadow:0 0 16px ${h.color}33;`}
            >
              <span class="text-[9px] uppercase tracking-wide" style={`color:${h.color};`}>
                {h.name.slice(0, 4)}
              </span>
            </div>
            <span class="text-[10px] text-slate-500 text-center leading-tight w-16">{h.name}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Right col: SKIP/PASS destination (row 1) -->
    <div style="grid-column:3; grid-row:1; padding-left:20px;">
      <div id="dest-skip" class="rounded-lg border border-dashed border-slate-600 bg-slate-900/60 p-3 text-xs h-full">
        <div class="text-slate-400 font-semibold text-sm mb-1.5">SKIP / PASS</div>
        <div class="space-y-1">
          {skipHarnesses.map((h) => (
            <div class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background:${h.color};`}></span>
              <span class="font-medium text-[11px]" style={`color:${h.color};`}>{h.name}</span>
              <span class="text-slate-500 text-[10px]">— {h.pickLabel}</span>
              {h.confidence && (
                <span class="ml-auto text-slate-500 text-[10px]">{h.confidence}%</span>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Right col: per-candidate harness tier breakdown -->
    {candidates.map((c, i) => {
      const tiers = candidateTiers[c.id];
      return (
        <div style={`grid-column:3; grid-row:${i + 2}; padding-left:20px;`}>
          <div
            id={`dest-${c.id}`}
            class="rounded-lg border border-slate-700 bg-slate-900 p-3 text-xs h-full"
            style={`border-left-color:${c.color}; border-left-width:3px;`}
          >
            <div class="mb-2">
              <div class="flex items-center justify-between gap-1.5">
                <span class="font-semibold text-white text-[11px]">{c.player}</span>
                <span class={`text-[10px] font-semibold ${boardResultColor[c.boardResult]}`}>
                  {boardResultLabel[c.boardResult]}
                </span>
              </div>
              <div class="text-slate-500 text-[10px]">{c.direction} {c.line} {c.market}</div>
            </div>
            <div class="space-y-1">
              {harnesses.map((h) => {
                const tier = tiers[h.id];
                const isChosen = h.pick === c.id;
                const choseOther = !isChosen && h.pick !== "skip";
                const choseSkip = !isChosen && h.pick === "skip";
                return (
                  <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background:${h.color};`}></span>
                    <span class="text-[10px]" style={`color:${h.color};`}>{h.name}</span>
                    {tier !== null ? (
                      <span class={`ml-1 text-[9px] font-bold px-1 py-0.5 rounded border ${tierColor(tier)}`}>
                        T{tier}
                      </span>
                    ) : (
                      <span class="ml-1 text-[9px] text-slate-600">—</span>
                    )}
                    {isChosen && <span class="ml-auto text-[9px] text-emerald-400 font-semibold">✓ pick</span>}
                    {choseSkip && <span class="ml-auto text-[9px] text-slate-600">→ SKIP</span>}
                    {choseOther && <span class="ml-auto text-[9px] text-slate-600">→ {h.pickLabel}</span>}
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      );
    })}

  </div>
</div>

<!-- ── Harness results ─────────────────────────────────────── -->
<div class="grid grid-cols-5 gap-3">
  {harnesses.map((h) => (
    <div class="rounded-lg border border-slate-800 bg-slate-900 p-3 text-xs space-y-1.5">
      <div class="flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full" style={`background:${h.color};`}></span>
        <span class="font-semibold text-[11px]" style={`color:${h.color};`}>{h.name}</span>
      </div>
      <div class="text-white font-medium">{h.pickLabel}</div>
      {h.confidence && (
        <div class="text-slate-500 text-[10px]">{h.confidence}% {h.confidenceLabel}</div>
      )}
      <div class={`font-semibold text-[11px] ${h.result === "correct" ? "text-emerald-400" : "text-red-400"}`}>
        {h.result === "correct" ? "✓ Correct" : "✗ Loss"}
      </div>
      <div class="text-slate-600 text-[10px] leading-snug">{h.resultNote}</div>
    </div>
  ))}
</div>

<!-- ── Final decision ─────────────────────────────────────── -->
<div class="rounded-xl border border-slate-700 bg-slate-900 p-6">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div>
      <p class="text-[10px] uppercase tracking-widest text-slate-500 mb-1">Final Decision</p>
      <h2 class="text-2xl font-bold text-white">{finalDecision.action}</h2>
      <p class="mt-1 text-slate-400 text-sm max-w-md">{finalDecision.reason}</p>
    </div>
    <div class="sm:text-right shrink-0">
      <div class={`font-bold text-lg ${finalDecision.result === "correct" ? "text-emerald-400" : "text-red-400"}`}>
        {finalDecision.result === "correct" ? "✓ Correct" : "✗ Loss"}
      </div>
      <p class="text-slate-500 text-xs mt-1 max-w-[220px] leading-snug sm:ml-auto">
        {finalDecision.resultNote}
      </p>
    </div>
  </div>
</div>

<script define:vars={{ pickConfig, harnessConfig }}>
  function drawLines() {
    const svg = document.getElementById("pipeline-svg");
    const container = document.getElementById("pipeline-container");
    if (!svg || !container) return;

    while (svg.firstChild) svg.removeChild(svg.firstChild);

    const cr = container.getBoundingClientRect();

    function rel(id) {
      const el = document.getElementById(id);
      if (!el) return null;
      const r = el.getBoundingClientRect();
      return {
        cx:     r.left - cr.left + r.width / 2,
        cy:     r.top  - cr.top  + r.height / 2,
        left:   r.left - cr.left,
        right:  r.right - cr.left,
      };
    }

    function addPath(d, stroke, dashed, opacity) {
      const p = document.createElementNS("http://www.w3.org/2000/svg", "path");
      p.setAttribute("d", d);
      p.setAttribute("fill", "none");
      p.setAttribute("stroke", stroke);
      p.setAttribute("stroke-width", dashed ? "1.5" : "2");
      p.setAttribute("stroke-opacity", String(opacity));
      if (dashed) p.setAttribute("stroke-dasharray", "4 4");
      svg.appendChild(p);
    }

    function addDot(x, y, color) {
      const c = document.createElementNS("http://www.w3.org/2000/svg", "circle");
      c.setAttribute("cx", String(x));
      c.setAttribute("cy", String(y));
      c.setAttribute("r", "3");
      c.setAttribute("fill", color);
      svg.appendChild(c);
    }

    const hFirst = rel("hnode-" + harnessConfig[0].id);
    const hLast  = rel("hnode-" + harnessConfig[harnessConfig.length - 1].id);
    if (!hFirst || !hLast) return;

    const centerY = hFirst.cy;

    // Gray background track
    addPath(`M ${hFirst.cx},${centerY} L ${hLast.cx},${centerY}`, "#334155", false, 0.5);

    const chosenPicks = new Set(
      harnessConfig.filter((h) => h.pick !== "skip").map((h) => h.pick)
    );

    const yOffsets = pickConfig.map((_, i) => {
      const total = pickConfig.length;
      const step = 10;
      return (i - (total - 1) / 2) * step;
    });

    for (let i = 0; i < pickConfig.length; i++) {
      const pick   = pickConfig[i];
      const pl     = rel("pick-" + pick.id);
      const pr     = rel("dest-" + pick.id);
      if (!pl || !pr) continue;

      const hy     = centerY + yOffsets[i];
      const chosen = chosenPicks.has(pick.id);
      const lMid   = (hFirst.cx - pl.right) / 2;
      const rMid   = (pr.left   - hLast.cx) / 2;

      const d = [
        `M ${pl.right},${pl.cy}`,
        `C ${pl.right + lMid},${pl.cy} ${hFirst.cx - lMid},${hy} ${hFirst.cx},${hy}`,
        `L ${hLast.cx},${hy}`,
        `C ${hLast.cx + rMid},${hy} ${pr.left - rMid},${pr.cy} ${pr.left},${pr.cy}`,
      ].join(" ");

      addPath(d, pick.color, !chosen, chosen ? 0.9 : 0.5);
      addDot(pl.right, pl.cy, pick.color);
      addDot(pr.left,  pr.cy, pick.color);
    }
  }

  if (document.readyState === "complete") {
    drawLines();
  } else {
    window.addEventListener("load", drawLines);
  }
  window.addEventListener("resize", drawLines);
</script>
