---
import type { DayLog } from "@/data/betsLog/types";

interface Props {
  log: DayLog;
}

const { log } = Astro.props;
const { candidates, harnesses, candidateTiers, finalDecision, mode = "pick-best" } = log;
const isAvoidWorst = mode === "avoid-worst";

const tierLabel = (t: number | null): string => {
  if (t === 1) return "T1";
  if (t === 2) return "T2";
  if (t === 3) return "T3";
  return "—";
};

const tierCls = (t: number | null): string => {
  if (t === 1) return "t1";
  if (t === 2) return "t2";
  if (t === 3) return "t3";
  return "tn";
};

const boardLabel: Record<string, string> = { win: "Win", loss: "Loss", void: "Void", push: "Push" };
const boardCls = (r: string): string => r === "win" ? "win" : r === "loss" ? "loss" : "neut";
const hCls     = (r: string): string => r === "correct" ? "win" : "loss";
---

<div class="root">

  <!-- ── Tier Matrix ────────────────────────────────────────── -->
  <section>
    <div class="section-head">
      <div class="section-head-left">
        <h2 class="section-label">Harness Analysis</h2>
        {isAvoidWorst && <span class="mode-badge">avoid worst</span>}
      </div>
      <div class="legend">
        {isAvoidWorst ? (
          <>
            <span class="leg t1">T1</span>worst
            <span class="leg t2">T2</span>risky
            <span class="leg t3">T3</span>safer
            <span class="leg tn">—</span>n/a
          </>
        ) : (
          <>
            <span class="leg t1">T1</span>strongest
            <span class="leg t2">T2</span>lean
            <span class="leg t3">T3</span>weak
            <span class="leg tn">—</span>reject / n/a
          </>
        )}
      </div>
    </div>

    <div class="matrix-wrap">
      <table class="matrix">
        <thead>
          <tr>
            <th class="th-cand">Candidate</th>
            {harnesses.map(h => (
              <th class="th-h" style={`--hc: ${h.color}`}>{h.name}</th>
            ))}
            <th class="th-board">Board</th>
          </tr>
        </thead>
        <tbody>
          {candidates.map(c => {
            const tiers = candidateTiers[c.id] ?? {};
            return (
              <tr>
                <td class="td-cand">
                  <div class="td-cand-inner">
                    <span class="cand-pip" style={`background:${c.color}`}></span>
                    <div>
                      <div class="cand-name">{c.player}</div>
                      <div class="cand-bet">
                        <span class={c.direction === "Under" ? "dir-u" : "dir-o"}>{c.direction}</span>
                        {" "}<span class="cand-line">{c.line}</span>
                        <span class="cand-mkt"> {c.market}</span>
                      </div>
                    </div>
                  </div>
                </td>
                {harnesses.map(h => {
                  const t: number | null = tiers[h.id] ?? null;
                  return (
                    <td class={`td-h ${tierCls(t)}`}>{tierLabel(t)}</td>
                  );
                })}
                <td class={`td-board ${boardCls(c.boardResult)}`}>
                  {boardLabel[c.boardResult]}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── Final Decision ────────────────────────────────────── -->
  <section>
    <h2 class="section-label">Final Decision</h2>
    <div class="decision">
      <div class="dec-left">
        <div class="dec-action">{finalDecision.action}</div>
        <p class="dec-reason">{finalDecision.reason}</p>
      </div>
      <div class="dec-right">
        <div class={`dec-result ${hCls(finalDecision.result)}`}>
          {finalDecision.result === "correct" ? "✓ Correct" : "✗ Loss"}
        </div>
        <p class="dec-note">{finalDecision.resultNote}</p>
      </div>
    </div>
  </section>

  <!-- ── Candidates ────────────────────────────────────────── -->
  <section>
    <h2 class="section-label">Candidates</h2>
    <div class="cands">
      {candidates.map(c => (
        <div class="cand-card" style={`--c:${c.color}`}>
          <div class="cc-head">
            <div>
              <div class="cc-name">{c.player}</div>
              <div class="cc-sub">{c.matchup}{c.gameTime ? ` · ${c.gameTime}` : ""}</div>
            </div>
            <span class={`cc-board ${boardCls(c.boardResult)}`}>{boardLabel[c.boardResult]}</span>
          </div>

          <div class="cc-bet">
            <span class={c.direction === "Under" ? "dir-u" : "dir-o"}>{c.direction}</span>
            {" "}<strong>{c.line}</strong> {c.market}
            <span class="cc-odds">{c.odds}</span>
          </div>

          <dl class="cc-stats">
            <div class="stat">
              <dt>Rithmm</dt>
              <dd class="win">{c.rithmm}%</dd>
            </div>
            <div class="stat">
              <dt>BE</dt>
              <dd>{c.breakEven}%</dd>
            </div>
            <div class="stat">
              <dt>DTM</dt>
              <dd class={c.dtm > 10 ? "loss" : ""}>{c.dtm}%</dd>
            </div>
            <div class="stat">
              <dt>Recent</dt>
              <dd>{c.recent || "—"}</dd>
            </div>
          </dl>

          {c.projection && <div class="cc-proj">{c.projection}</div>}
        </div>
      ))}
    </div>
  </section>

  <!-- ── Harness Notes ─────────────────────────────────────── -->
  <section>
    <h2 class="section-label">Harness Notes</h2>
    <div class="harnesses">
      {harnesses.map(h => (
        <div class="h-card" style={`--hc:${h.color}`}>
          <div class="hc-name">{h.name}</div>
          <div class="hc-pick">{h.pickLabel}</div>
          {h.confidence && (
            <div class="hc-conf">{h.confidence}%<span class="hc-conf-lbl"> {h.confidenceLabel}</span></div>
          )}
          <div class={`hc-result ${hCls(h.result)}`}>
            {h.result === "correct" ? "✓ Correct" : "✗ Loss"}
          </div>
          <p class="hc-note">{h.resultNote}</p>
        </div>
      ))}
    </div>
  </section>

</div>

<style>
  .root {
    --s1:    oklch(13% 0.009 255);
    --s2:    oklch(17% 0.009 255);
    --bdr:   oklch(27% 0.009 255);
    --t1:    oklch(96% 0.005 255);
    --t2:    oklch(68% 0.012 255);
    --t3:    oklch(42% 0.010 255);
    --win:   oklch(72% 0.17  162);
    --loss:  oklch(62% 0.20   25);
    --neut:  oklch(52% 0.01  255);
    --fd:    'Darker Grotesque', system-ui, sans-serif;
    --fm:    'Azeret Mono', ui-monospace, monospace;

    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  /* ── Section headers ── */
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    margin-bottom: 1rem;
  }

  .section-head-left {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .mode-badge {
    font-family: var(--fm);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    background: oklch(16% 0.06 25);
    color: oklch(66% 0.15 25);
    border: 1px solid oklch(30% 0.08 25);
  }

  section > .section-label { margin-bottom: 1rem; }

  .section-label {
    font-family: var(--fm);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--t3);
  }

  /* ── Legend ── */
  .legend {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--fm);
    font-size: 0.62rem;
    color: var(--t3);
  }

  .leg {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.58rem;
    font-weight: 700;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-family: var(--fm);
    margin-left: 0.5rem;
  }

  .leg.t1 { background: oklch(16% 0.06 162); color: oklch(74% 0.16 162); }
  .leg.t2 { background: oklch(17% 0.05  70); color: oklch(79% 0.15  70); }
  .leg.t3 { background: oklch(16% 0.05  25); color: oklch(66% 0.15  25); }
  .leg.tn { color: var(--t3); }

  /* ── Matrix ── */
  .matrix-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--bdr);
    border-radius: 8px;
  }

  .matrix {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--fm);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
  }

  /* Header row */
  .matrix thead th {
    background: var(--s1);
    padding: 0.55rem 0.75rem;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--bdr);
    white-space: nowrap;
  }

  .th-cand { text-align: left; color: var(--t3); }
  .th-h    { text-align: center; min-width: 74px; color: var(--hc, var(--t3)); }
  .th-board{ text-align: center; min-width: 72px; color: var(--t3); }

  /* Body rows */
  .matrix tbody tr { border-bottom: 1px solid var(--bdr); }
  .matrix tbody tr:last-child { border-bottom: none; }

  /* Candidate cell */
  .td-cand {
    padding: 0.75rem 1rem;
    min-width: 200px;
    background: var(--s2);
    position: sticky;
    left: 0;
    z-index: 1;
  }

  .td-cand-inner {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .cand-pip {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    flex-shrink: 0;
    margin-top: 0.3rem;
  }

  .cand-name {
    font-family: var(--fd);
    font-size: 0.875rem;
    font-weight: 800;
    color: var(--t1);
    line-height: 1.2;
  }

  .cand-bet {
    font-size: 0.63rem;
    color: var(--t3);
    margin-top: 0.15rem;
  }

  .cand-line { color: var(--t2); font-weight: 600; }
  .cand-mkt  { color: var(--t3); }

  /* Tier cells */
  .td-h {
    text-align: center;
    padding: 0.75rem 0.5rem;
    font-size: 0.68rem;
    font-weight: 700;
    vertical-align: middle;
    letter-spacing: 0.04em;
  }

  .td-h.t1 { background: oklch(16% 0.06 162); color: oklch(74% 0.16 162); }
  .td-h.t2 { background: oklch(17% 0.05  70); color: oklch(79% 0.15  70); }
  .td-h.t3 { background: oklch(16% 0.05  25); color: oklch(66% 0.15  25); }
  .td-h.tn { color: var(--t3); }

  /* Board column */
  .td-board {
    text-align: center;
    padding: 0.75rem 0.5rem;
    font-size: 0.68rem;
    font-weight: 700;
    vertical-align: middle;
    letter-spacing: 0.06em;
  }

  /* Shared outcome colors */
  .win  { color: var(--win);  }
  .loss { color: var(--loss); }
  .neut { color: var(--neut); }

  /* Direction colors */
  .dir-u { color: oklch(65% 0.16 245); }
  .dir-o { color: oklch(79% 0.15  70); }

  /* ── Final Decision ── */
  .decision {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 1.75rem 2rem;
    background: var(--s1);
    border: 1px solid var(--bdr);
    border-radius: 8px;
  }

  @media (max-width: 600px) {
    .decision { grid-template-columns: 1fr; padding: 1.25rem; gap: 1.25rem; }
  }

  .dec-action {
    font-family: var(--fd);
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--t1);
    margin-bottom: 0.75rem;
  }

  .dec-reason {
    font-size: 0.8rem;
    color: var(--t2);
    line-height: 1.65;
    max-width: 58ch;
  }

  .dec-result {
    font-family: var(--fd);
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.625rem;
  }

  .dec-note {
    font-family: var(--fm);
    font-size: 0.68rem;
    color: var(--t3);
    line-height: 1.75;
  }

  /* ── Candidates ── */
  .cands {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .cand-card {
    background: var(--s1);
    border: 1px solid var(--bdr);
    border-top: 2px solid var(--c);
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cc-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .cc-name {
    font-family: var(--fd);
    font-size: 1rem;
    font-weight: 800;
    color: var(--t1);
    line-height: 1.2;
  }

  .cc-sub {
    font-family: var(--fm);
    font-size: 0.62rem;
    color: var(--t3);
    margin-top: 0.2rem;
  }

  .cc-board {
    font-family: var(--fm);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .cc-bet {
    font-family: var(--fm);
    font-size: 0.75rem;
    color: var(--t2);
    font-variant-numeric: tabular-nums;
  }

  .cc-bet strong { color: var(--t1); font-weight: 600; }
  .cc-odds { margin-left: 0.5rem; color: var(--t3); }

  .cc-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    padding-top: 0.625rem;
    border-top: 1px solid var(--bdr);
    margin: 0;
  }

  @media (max-width: 400px) {
    .cc-stats { grid-template-columns: repeat(2, 1fr); }
  }

  .stat dt {
    font-family: var(--fm);
    font-size: 0.55rem;
    color: var(--t3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.15rem;
  }

  .stat dd {
    font-family: var(--fm);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--t2);
    font-variant-numeric: tabular-nums;
    margin: 0;
  }

  .cc-proj {
    font-family: var(--fm);
    font-size: 0.63rem;
    color: var(--t3);
    font-style: italic;
    padding-top: 0.125rem;
  }

  /* ── Harness Notes ── */
  .harnesses {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.75rem;
  }

  .h-card {
    background: var(--s1);
    border: 1px solid var(--bdr);
    border-radius: 8px;
    padding: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .hc-name {
    font-family: var(--fd);
    font-size: 0.875rem;
    font-weight: 800;
    color: var(--hc);
    margin-bottom: 0.125rem;
  }

  .hc-pick {
    font-family: var(--fm);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--t1);
    line-height: 1.4;
  }

  .hc-conf {
    font-family: var(--fm);
    font-size: 0.63rem;
    color: var(--t3);
    font-variant-numeric: tabular-nums;
  }

  .hc-conf-lbl { opacity: 0.75; }

  .hc-result {
    font-family: var(--fm);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-top: 0.125rem;
  }

  .hc-note {
    font-size: 0.7rem;
    color: var(--t3);
    line-height: 1.65;
    margin-top: 0.25rem;
  }
</style>
