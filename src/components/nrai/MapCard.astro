---
interface Props {
	href: string;
	image: string;
	imageAlt?: string;
	name: string;
	tab: string;
	sub?: string;
	class?: string;
	eager?: boolean;
}

const { href, image, imageAlt, name, tab, sub, class: className, eager = false } = Astro.props;
---

<a class:list={['map-card filmgrain', className]} href={href}>
	<img
		src={`/no-reserv-ai-tions/${image}.webp`}
		alt={imageAlt}
		loading={eager ? 'eager' : 'lazy'}
		decoding="async"
	/>
	<span class="map-card-third">
		<span class="ep-tab">{tab}</span>
		<span class="map-card-name">{name}</span>
		{sub && <span class="map-card-sub">{sub}</span>}
	</span>
</a>

<style>
	.map-card {
		display: block;
		overflow: hidden;
		background: var(--nrai-panel);
		text-decoration: none;
		color: var(--nrai-ink);
	}
	.map-card img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(0.7) contrast(1.05) brightness(0.85);
		transition: filter 0.5s ease-out, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.map-card::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		background: linear-gradient(to top, oklch(0% 0 0 / 0.72), oklch(0% 0 0 / 0.15) 45%, transparent 70%);
	}
	.map-card-third {
		position: absolute;
		inset-inline: 0;
		bottom: 0;
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.45rem;
		padding: clamp(0.9rem, 2vw, 1.5rem);
	}
	.map-card-third .ep-tab {
		font-size: clamp(0.68rem, 1vw, 0.8rem);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.map-card-name {
		font-family: var(--font-display);
		font-size: clamp(1.4rem, 2.6vw, 2.2rem);
		line-height: 1;
		text-transform: uppercase;
		letter-spacing: 0.01em;
		transition: color 0.3s ease-out;
	}
	.map-card-sub {
		font-family: var(--font-type);
		font-size: clamp(0.72rem, 1vw, 0.85rem);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--nrai-smoke);
	}

	@media (hover: hover) {
		.map-card:hover img {
			filter: saturate(1) contrast(1.02) brightness(0.95);
			transform: scale(1.04);
		}
		.map-card:hover .map-card-name {
			color: var(--nrai-red-bright);
		}
	}
</style>
