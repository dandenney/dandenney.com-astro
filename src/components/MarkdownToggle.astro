---
// Links from a rendered HTML article to its Markdown twin (.md URL).
// Neutral, theme-inheriting styling so it sits in any section's meta row.
interface Props {
  href: string;
  class?: string;
}
const { href, class: className } = Astro.props;
---

<a
  href={href}
  class:list={["md-twin-toggle", className]}
  title="View this page as Markdown (for LLMs & agents)"
>View as markdown</a>

<style>
  .md-twin-toggle {
    display: inline-flex;
    align-items: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    line-height: 1;
    padding: 0.2em 0.45em;
    border: 1px solid currentColor;
    border-radius: 0.3rem;
    opacity: 0.75;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .md-twin-toggle:hover,
  .md-twin-toggle:focus-visible {
    opacity: 1;
  }
</style>
