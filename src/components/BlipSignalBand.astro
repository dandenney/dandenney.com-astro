---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entries: CollectionEntry<'blips'>[];
	/** Prepended to the `#blip-slug` anchors, e.g. "/blips" when the band lives on another page */
	linkPrefix?: string;
	compact?: boolean;
}

const { entries, linkPrefix = '', compact = false } = Astro.props;

const sorted = [...entries].sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
);

const W = 1000;
const H = 100;
const PAD = 10;
const BASELINE = H - 6;
const CEILING = 10;

const t0 = sorted[0].data.pubDate.valueOf();
const t1 = Date.now();
const span = Math.max(t1 - t0, 1);
const xFor = (ms: number) => PAD + ((ms - t0) / span) * (W - PAD * 2);

const ticks = sorted.map((entry) => {
	const slug = entry.id.replace(/\.mdx?$/, '');
	const chars = entry.body?.length ?? 0;
	const tier = chars > 2400 ? 0.85 : chars > 900 ? 0.58 : 0.32;
	return {
		slug,
		x: xFor(entry.data.pubDate.valueOf()),
		y: BASELINE - tier * (BASELINE - CEILING),
		title: entry.data.title,
		dateStr: entry.data.pubDate.toLocaleDateString('en-US', {
			month: 'short',
			day: 'numeric',
			year: 'numeric',
			timeZone: 'UTC',
		}),
	};
});
const latestSlug = ticks[ticks.length - 1].slug;

const firstYear = sorted[0].data.pubDate.getUTCFullYear();
const lastYear = new Date().getUTCFullYear();
const yearMarks: { year: number; x: number }[] = [];
for (let y = firstYear + 1; y <= lastYear; y++) {
	yearMarks.push({ year: y, x: xFor(Date.UTC(y, 0, 1)) });
}

const readoutDefault = `${entries.length} signals · ${firstYear} – ${lastYear}`;
---

<div
	class:list={['signal-band', compact && 'signal-band-compact']}
	data-signal-band
	aria-hidden="true"
>
	<svg
		class="signal-band-svg"
		viewBox={`0 0 ${W} ${H}`}
		preserveAspectRatio="none"
		fill="none"
	>
		{yearMarks.map(({ x }) => (
			<line class="signal-gridline" x1={x} y1={CEILING} x2={x} y2={BASELINE} vector-effect="non-scaling-stroke" />
		))}
		<line class="signal-baseline" x1="0" y1={BASELINE} x2={W} y2={BASELINE} vector-effect="non-scaling-stroke" />
		{ticks.map(({ slug, x, y, title, dateStr }) => (
			<a
				href={`${linkPrefix}#blip-${slug}`}
				class:list={['signal-tick', slug === latestSlug && 'signal-tick-latest']}
				data-slug={slug}
				data-title={title}
				data-date={dateStr}
				tabindex="-1"
				style={`--d: ${((x / W) * 1.5).toFixed(3)}s`}
			>
				<line class="signal-tick-hit" x1={x} y1="0" x2={x} y2={H} vector-effect="non-scaling-stroke" />
				<line class="signal-tick-mark" x1={x} y1={BASELINE} x2={x} y2={y} vector-effect="non-scaling-stroke" />
			</a>
		))}
		<line class="signal-sweep" x1="0" y1={CEILING} x2="0" y2={BASELINE} vector-effect="non-scaling-stroke" />
	</svg>

	{!compact && (
		<div class="signal-years font-mono">
			{yearMarks.map(({ year, x }, i) => (
				<span class:list={[i % 2 === 1 && 'signal-year-alt']} style={`left: ${(x / W) * 100}%`}>
					&rsquo;{String(year).slice(2)}
				</span>
			))}
		</div>
	)}

	<p
		class="signal-readout font-mono text-xs uppercase tracking-widest text-gray-400 dark:text-slate-500"
		data-readout
		data-default={`[ ${readoutDefault} ]`}
	>
		[&nbsp;{readoutDefault}&nbsp;]
	</p>
</div>

<style>
	.signal-band {
		--tick-color: #94a3b8;
		--tick-hot: #b91c1c;
		--baseline-color: #cbd5e1;
		--gridline-color: #f1f5f9;
		position: relative;
	}

	:global(.dark) .signal-band {
		--tick-color: #64748b;
		--tick-hot: #f87171;
		--baseline-color: #475569;
		--gridline-color: #1e293b;
	}

	.signal-band-svg {
		display: block;
		width: 100%;
		height: clamp(6rem, 12vw, 9rem);
	}

	.signal-band-compact .signal-band-svg {
		height: clamp(3.5rem, 6vw, 4.5rem);
	}

	.signal-gridline {
		stroke: var(--gridline-color);
		stroke-width: 1px;
	}

	.signal-baseline {
		stroke: var(--baseline-color);
		stroke-width: 1px;
	}

	.signal-tick-hit {
		stroke: transparent;
		stroke-width: 9px;
	}

	.signal-tick-mark {
		stroke: var(--tick-color);
		stroke-width: 2px;
		transition: stroke 0.2s ease;
	}

	.signal-tick:hover .signal-tick-mark,
	.signal-tick.tick-hot .signal-tick-mark {
		stroke: var(--tick-hot);
		stroke-width: 3px;
	}

	.signal-tick-latest .signal-tick-mark {
		stroke: var(--tick-hot);
	}

	.signal-sweep {
		stroke: var(--tick-hot);
		stroke-width: 2px;
		opacity: 0;
	}

	@media (prefers-reduced-motion: no-preference) {
		.signal-tick {
			animation: signal-tick-in 0.35s ease-out both;
			animation-delay: var(--d);
		}

		/* `backwards` fill: red while the sweep arrives, then releases to the
		   cascade so hover/hot states aren't pinned by the animation */
		.signal-tick-mark {
			animation: signal-tick-flash 0.7s ease-out backwards;
			animation-delay: var(--d);
		}

		/* The latest tick is already hot; it just starts its live pulse */
		.signal-tick-latest .signal-tick-mark {
			animation: signal-live 2.4s ease-in-out calc(var(--d) + 0.7s) infinite;
		}

		.signal-sweep {
			animation: signal-sweep 1.5s linear both;
		}
	}

	@keyframes signal-tick-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@keyframes signal-tick-flash {
		0% {
			stroke: var(--tick-hot);
		}
		100% {
			stroke: var(--tick-color);
		}
	}

	@keyframes signal-live {
		0%,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.35;
		}
	}

	@keyframes signal-sweep {
		0% {
			transform: translateX(0);
			opacity: 0.9;
		}
		85% {
			opacity: 0.9;
		}
		100% {
			transform: translateX(1000px);
			opacity: 0;
		}
	}

	.signal-years {
		position: relative;
		height: 1rem;
		margin-top: 0.375rem;
	}

	.signal-years span {
		position: absolute;
		transform: translateX(-50%);
		font-size: 10px;
		letter-spacing: 0.1em;
		color: #94a3b8;
	}

	:global(.dark) .signal-years span {
		color: #64748b;
	}

	@media (max-width: 640px) {
		.signal-year-alt {
			display: none;
		}
	}

	.signal-readout {
		margin-top: 0.75rem;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
</style>

<script>
	// Delegated so it survives ClientRouter page swaps without re-init.
	const readoutFor = (el: Element) =>
		el
			.closest('[data-signal-band]')
			?.querySelector<HTMLElement>('[data-readout]') ?? null;

	const setReadout = (readout: HTMLElement, title: string, date: string) => {
		readout.textContent = `[ ${date} ] ${title}`;
	};

	const resetReadout = (readout: HTMLElement) => {
		readout.textContent = readout.dataset.default ?? '';
	};

	document.addEventListener('mouseover', (e) => {
		const target = e.target as Element | null;
		if (!target?.closest) return;

		const tick = target.closest<HTMLElement>('.signal-tick');
		if (tick) {
			const readout = readoutFor(tick);
			if (readout && tick.dataset.title && tick.dataset.date) {
				setReadout(readout, tick.dataset.title, tick.dataset.date);
			}
			return;
		}

		const row = target.closest<HTMLElement>('.blip-row');
		if (row?.dataset.slug) {
			const tickEl = document.querySelector<HTMLElement>(
				`.signal-tick[data-slug="${CSS.escape(row.dataset.slug)}"]`
			);
			if (tickEl) {
				tickEl.classList.add('tick-hot');
				const readout = readoutFor(tickEl);
				if (readout && tickEl.dataset.title && tickEl.dataset.date) {
					setReadout(readout, tickEl.dataset.title, tickEl.dataset.date);
				}
			}
		}
	});

	document.addEventListener('mouseout', (e) => {
		const target = e.target as Element | null;
		if (!target?.closest) return;

		const tick = target.closest<HTMLElement>('.signal-tick');
		if (tick && !tick.contains(e.relatedTarget as Node | null)) {
			const readout = readoutFor(tick);
			if (readout) resetReadout(readout);
			return;
		}

		const row = target.closest<HTMLElement>('.blip-row');
		if (row?.dataset.slug && !row.contains(e.relatedTarget as Node | null)) {
			const tickEl = document.querySelector<HTMLElement>(
				`.signal-tick[data-slug="${CSS.escape(row.dataset.slug)}"]`
			);
			if (tickEl) {
				tickEl.classList.remove('tick-hot');
				const readout = readoutFor(tickEl);
				if (readout) resetReadout(readout);
			}
		}
	});
</script>
