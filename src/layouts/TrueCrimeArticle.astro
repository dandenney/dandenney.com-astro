---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

const { title, summary, pubDate } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={summary} type="blogpost" datePublished={pubDate} />
    <ClientRouter />
  </head>
  <body class="bg-white dark:bg-slate-900">
    <Header />
    <main id="main-content" tabindex="-1" class="bg-white relative shadow-xs z-10 dark:bg-slate-900 dark:text-slate-200">
      <article class="longform max-w-3xl mx-auto pb-16 pt-8 px-8 lg:px-0 blogpost">
        <h1 class="text-4xl font-black tracking-tight sm:text-6xl mb-8">{title}</h1>
        <slot />
      </article>
    </main>
    <Footer />
  </body>
</html>
