---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";

const { title, summary, pubDate, sport } = Astro.props;

const dateStr = new Date(pubDate).toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
  timeZone: "UTC",
});

const sportLabel = sport === "nba" ? "NBA" : sport === "mlb" ? "MLB" : sport === "both" ? "NBA + MLB" : null;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead title={`${title} | Plus EV`} description={summary} />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen antialiased">

    <div class="relative z-10 border-b border-white/5 backdrop-blur-sm">
      <Header title={SITE_TITLE} />
    </div>

    <div class="mx-auto max-w-2xl px-4 pt-10">

      <!-- Back link -->
      <a href="/plus-ev" class="inline-flex items-center gap-1.5 text-xs text-slate-500 hover:text-emerald-400 transition-colors mb-10">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 11L5 7l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Plus EV
      </a>

      <!-- Post header -->
      <header class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <time class="text-xs text-slate-500 font-mono">{dateStr}</time>
          {sportLabel && (
            <span class="text-xs px-2 py-0.5 bg-emerald-900/30 border border-emerald-800/40 text-emerald-400 font-mono">{sportLabel}</span>
          )}
        </div>
        <h1 class="text-3xl font-black text-white leading-snug">{title}</h1>
        <p class="mt-2 text-slate-400 text-sm">{summary}</p>

        <!-- Byline -->
        <div class="flex items-center gap-3 mt-6 pt-6 border-t border-slate-800">
          <div class="w-8 h-8 rounded-full bg-emerald-900 flex items-center justify-center flex-shrink-0">
            <span class="text-emerald-400 text-sm font-bold">G</span>
          </div>
          <div>
            <p class="text-sm font-medium text-slate-300">Gale</p>
            <p class="text-xs text-slate-600">Resident data analyst &amp; reluctant martingale tracker</p>
          </div>
        </div>
      </header>

    </div>

    <!-- Article is full-width so the table can size freely -->
    <article class="longform px-4 pb-12">
      <slot />
    </article>

    <div class="mx-auto max-w-2xl px-4 pb-12">
      <!-- Dashboard links footer -->
      <footer class="mt-16 pt-8 border-t border-slate-800">
        <p class="text-xs text-slate-600 uppercase tracking-widest font-mono mb-4">Live data</p>
        <div class="flex flex-wrap gap-3">
          <a href="/betting/martingale-tracker" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded border border-slate-700 text-xs text-slate-400 hover:border-emerald-700 hover:text-emerald-400 transition-colors">
            Martingale Tracker
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/betting/expert-picks" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded border border-slate-700 text-xs text-slate-400 hover:border-emerald-700 hover:text-emerald-400 transition-colors">
            NBA Expert Picks
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/betting/mlb-expert-picks" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded border border-slate-700 text-xs text-slate-400 hover:border-emerald-700 hover:text-emerald-400 transition-colors">
            MLB Expert Picks
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </footer>
    </div>

  </body>
</html>

<style>
  /* Constrain prose to readable width, centered */
  article :global(p),
  article :global(ul),
  article :global(ol),
  article :global(h2),
  article :global(h3),
  article :global(h4) {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* Scrollable wrapper — injected via JS */
  article :global(.table-wrapper) {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
    margin: 2.5rem auto 0;
  }

  /* Table sizes to content and centers freely */
  article :global(table) {
    display: table;
    border-collapse: collapse;
    font-size: 0.8125rem; /* 13px */
    line-height: 1.4;
    margin: 0;
    white-space: nowrap;
  }

  article :global(th) {
    font-family: ui-monospace, monospace;
    font-size: 0.6875rem; /* 11px */
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-weight: 600;
    padding: 0.5rem 1rem;
    text-align: left;
    border-bottom: 1px solid #334155; /* slate-700 */
    color: #64748b; /* slate-500 */
  }

  article :global(td) {
    padding: 0.625rem 1rem;
    text-align: left;
    border-bottom: 1px solid #1e293b; /* slate-800 */
    color: #cbd5e1; /* slate-300 */
  }

  article :global(tr:hover td) {
    background: #0f172a; /* slate-900 */
  }

  article :global(td.cell-win) {
    color: #34d399; /* emerald-400 */
  }

  article :global(td.cell-loss) {
    color: #f87171; /* red-400 */
  }
</style>

<script>
  // Wrap each table in a scrollable container for mobile
  document.querySelectorAll("article table").forEach((table) => {
    const wrapper = document.createElement("div");
    wrapper.className = "table-wrapper";
    table.parentNode?.insertBefore(wrapper, table);
    wrapper.appendChild(table);
  });

  document.querySelectorAll("article table").forEach((table) => {
    const headers = Array.from(table.querySelectorAll("th")).map((th) =>
      th.textContent?.trim().toLowerCase()
    );
    const resultIdx = headers.indexOf("result");
    const coloredCols = ["final", "perplexity", "claude", "placed"];
    const coloredIdxs = coloredCols.map((name) => headers.indexOf(name)).filter((i) => i !== -1);
    if (resultIdx === -1) return;

    table.querySelectorAll("tbody tr").forEach((row) => {
      const cells = row.querySelectorAll("td");
      const result = cells[resultIdx]?.textContent?.trim().toLowerCase();
      if (!result) return;

      const isWin = result === "win";
      const isLoss = result === "loss";
      if (!isWin && !isLoss) return;

      const cls = isWin ? "cell-win" : "cell-loss";
      coloredIdxs.forEach((i) => {
        const cell = cells[i];
        if (cell && cell.textContent?.trim() !== "—") cell.classList.add(cls);
      });
    });
  });
</script>
