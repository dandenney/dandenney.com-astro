---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from 'astro:transitions';

const {
  title,
  artist,
  album,
  releaseDate,
  spotifyUrl,
  albumArt,
  duration,
  genres,
  tags,
  aiGenerated,
} = Astro.props;

// Format duration from ms to mm:ss
const formatDuration = (ms: number) => {
  const minutes = Math.floor(ms / 60000);
  const seconds = ((ms % 60000) / 1000).toFixed(0);
  return `${minutes}:${seconds.toString().padStart(2, "0")}`;
};

// Format release date without timezone shift
const formatDate = (dateStr: string) => {
  const [year, month, day] = dateStr.split("-").map(Number);
  return new Date(year, month - 1, day).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};
---

<html lang="en">
  <head>
    <BaseHead
      title={`${title} by ${artist}`}
      description={`A review of ${title} by ${artist}`}
    />
    <ClientRouter />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MusicRecording",
        name: title,
        byArtist: { "@type": "MusicGroup", name: artist },
        inAlbum: { "@type": "MusicAlbum", name: album },
        url: spotifyUrl,
        ...(albumArt ? { image: albumArt } : {}),
      })}
    />
    <style>
      @media screen and (min-width: 768px) {
        .longform {
          font-size: 1.125rem;
        }
      }

      /* Drop cap on opening paragraph */
      .review-body p:first-child::first-letter {
        float: left;
        font-size: 3.5em;
        line-height: 0.82;
        font-weight: 800;
        margin-right: 0.08em;
        margin-top: 0.04em;
        color: #16a34a;
      }

      .dark .review-body p:first-child::first-letter {
        color: #4ade80;
      }
    </style>
  </head>
  <body class="bg-white dark:bg-slate-900">
    <Header />
    <main
      class="bg-white relative shadow-xs z-10 dark:bg-slate-900 dark:text-slate-200"
    >
      <article
        class="max-w-(--breakpoint-xl) mx-auto px-4 py-8 lg:py-12 lg:grid lg:grid-cols-[280px_1fr] xl:grid-cols-[320px_1fr] lg:gap-16 lg:items-start"
      >
        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-8">
          <!-- Album Art -->
          {
            albumArt && (
              <div class="w-56 sm:w-64 lg:w-full mx-auto lg:mx-0 mb-6">
                <img
                  class="w-full aspect-square rounded-xl shadow-2xl ring-1 ring-black/10 dark:ring-white/5 object-cover"
                  src={albumArt}
                  alt={`Album art for ${album}`}
                  loading="eager"
                />
              </div>
            )
          }

          <!-- Title & Artist -->
          <div
            class="w-56 sm:w-64 lg:w-full mx-auto lg:mx-0 mb-5 text-center lg:text-left"
          >
            <h1 class="text-xl font-bold leading-tight tracking-tight">
              {title}
            </h1>
            <p class="text-sm text-gray-500 dark:text-slate-400 mt-1 font-medium">
              {artist}
            </p>
          </div>

          <!-- Metadata -->
          <dl
            class="w-56 sm:w-64 lg:w-full mx-auto lg:mx-0 mb-5 divide-y divide-gray-100 dark:divide-slate-700/50 text-xs"
          >
            <div class="flex justify-between items-baseline gap-2 py-2">
              <dt class="text-gray-400 dark:text-slate-500 shrink-0">Album</dt>
              <dd
                class="font-medium text-right text-gray-700 dark:text-slate-300 truncate"
              >
                {album}
              </dd>
            </div>
            {
              genres && genres.length > 0 && (
                <div class="flex justify-between items-baseline gap-2 py-2">
                  <dt class="text-gray-400 dark:text-slate-500 shrink-0">
                    Genre
                  </dt>
                  <dd class="font-medium text-right text-gray-700 dark:text-slate-300">
                    {genres.join(" · ")}
                  </dd>
                </div>
              )
            }
            <div class="flex justify-between items-baseline gap-2 py-2">
              <dt class="text-gray-400 dark:text-slate-500 shrink-0">
                Released
              </dt>
              <dd class="font-medium text-gray-700 dark:text-slate-300">
                {formatDate(releaseDate)}
              </dd>
            </div>
            <div class="flex justify-between items-baseline gap-2 py-2">
              <dt class="text-gray-400 dark:text-slate-500 shrink-0">
                Duration
              </dt>
              <dd class="font-medium text-gray-700 dark:text-slate-300">
                {formatDuration(duration)}
              </dd>
            </div>
          </dl>

          <!-- Spotify Button -->
          <div class="w-56 sm:w-64 lg:w-full mx-auto lg:mx-0 mb-5">
            <a
              href={spotifyUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full bg-[#1DB954] hover:bg-[#1ed760] active:scale-[0.98] text-white font-semibold py-2.5 px-4 rounded-full text-sm transition-all duration-150 shadow-sm hover:shadow-md hover:shadow-green-500/25"
            >
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"
                ></path>
              </svg>
              Listen on Spotify
            </a>
          </div>

          <!-- Tags -->
          {
            tags && tags.length > 0 && (
              <div class="w-56 sm:w-64 lg:w-full mx-auto lg:mx-0">
                <ul class="flex flex-wrap justify-center lg:justify-start gap-1.5">
                  {tags.map((tag: string) => (
                    <li>
                      <a
                        href={`/music/reviews/tags/${tag}`}
                        class="inline-block px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-slate-700/60 text-gray-500 dark:text-slate-400 hover:bg-green-50 hover:text-green-700 dark:hover:bg-green-900/30 dark:hover:text-green-400 transition-colors"
                      >
                        {tag}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </aside>

        <!-- Review Content -->
        <div class="mt-10 lg:mt-0">
          <div class="review-body longform max-w-2xl pb-8">
            <slot />
          </div>

          {
            aiGenerated && (
              <p class="flex items-center gap-1.5 mt-6 pt-6 border-t border-gray-100 dark:border-slate-700/50 text-xs text-gray-400 dark:text-slate-500">
                <svg
                  class="w-3.5 h-3.5 shrink-0"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                </svg>
                Review generated with AI assistance
              </p>
            )
          }

          <nav class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-6 pb-12 lg:pb-24 text-sm">
            <a
              href="/music/reviews"
              class="text-gray-500 dark:text-slate-400 hover:text-green-600 dark:hover:text-green-400 transition-colors"
              >← Music Reviews</a
            >
            <span class="text-gray-200 dark:text-slate-700 select-none">|</span>
            <a
              href="/music"
              class="text-gray-500 dark:text-slate-400 hover:text-green-600 dark:hover:text-green-400 transition-colors"
              >Listening History</a
            >
          </nav>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
