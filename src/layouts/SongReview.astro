---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MarkdownToggle from "../components/MarkdownToggle.astro";
import { ClientRouter } from "astro:transitions";

const {
  title,
  artist,
  album,
  releaseDate,
  spotifyUrl,
  albumArt,
  duration,
  genres,
  tags,
  aiGenerated,
  slug,
  trackNumber,
  totalTracks,
  next,
  markdownTwin,
} = Astro.props;

// Format duration from ms to mm:ss
const formatDuration = (ms: number) => {
  const minutes = Math.floor(ms / 60000);
  const seconds = ((ms % 60000) / 1000).toFixed(0);
  return `${minutes}:${seconds.toString().padStart(2, "0")}`;
};

// Format release date without timezone shift
const formatDate = (dateStr: string) => {
  const [year, month, day] = dateStr.split("-").map(Number);
  return new Date(year, month - 1, day).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const trackNo = String(trackNumber).padStart(2, "0");
const nextNo = String((trackNumber % totalTracks) + 1).padStart(2, "0");
const soundsLike = [...new Set([...(genres ?? []), ...(tags ?? [])])] as string[];
---

<html lang="en">
  <head>
    <BaseHead
      title={`${title} by ${artist}`}
      description={`A review of ${title} by ${artist}`}
      markdownTwin={markdownTwin}
    />
    <ClientRouter />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MusicRecording",
        name: title,
        byArtist: { "@type": "MusicGroup", name: artist },
        inAlbum: { "@type": "MusicAlbum", name: album },
        url: spotifyUrl,
        ...(albumArt ? { image: albumArt } : {}),
      })}
    />
  </head>
  <body class="bg-white dark:bg-slate-900">
    <Header />
    <main
      id="main-content"
      tabindex="-1"
      class="song-page bg-white relative shadow-xs z-10 dark:bg-slate-900 dark:text-slate-200"
    >
      <article>
        <section class="song-hero px-8">
          <div class="song-hero-text">
            <p class="hero-fade text-xs font-mono uppercase tracking-widest text-gray-400 dark:text-slate-500">
              <span class="whitespace-nowrap">[&nbsp;Heavy Rotation &middot; Track {trackNo} / {totalTracks}&nbsp;]</span>
              {markdownTwin && <MarkdownToggle href={markdownTwin} class="song-md" />}
            </p>
            <h1 class="song-title text-slate-900 dark:text-slate-100">
              <span class="song-title-inner">{title}</span>
            </h1>
            <p class="song-artist hero-fade">{artist}</p>
          </div>

          <div class="song-record">
            <div class="record">
              {albumArt ? (
                <>
                  <img class="record-glow" src={albumArt} alt="" aria-hidden="true" />
                  <span class="record-vinyl" aria-hidden="true"></span>
                  <img
                    class="record-cover"
                    src={albumArt}
                    alt={`Album art for ${album}`}
                    loading="eager"
                    transition:name={`song-art-${slug}`}
                  />
                </>
              ) : (
                <>
                  <span class="record-vinyl" aria-hidden="true"></span>
                  <span class="record-cover record-cover-fallback" aria-hidden="true">
                    {title.charAt(0)}
                  </span>
                </>
              )}
            </div>
            <a
              href={spotifyUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="spotify-btn flex items-center justify-center gap-2 bg-[#1DB954] hover:bg-[#1ed760] active:scale-[0.98] text-white font-semibold py-2.5 px-4 rounded-full text-sm transition-all duration-150 shadow-sm hover:shadow-md hover:shadow-green-500/25"
            >
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"
                ></path>
              </svg>
              Listen on Spotify
            </a>
          </div>
        </section>

        <div class="hatch-band" aria-hidden="true"></div>

        <dl class="credits px-8">
          <div class="credit">
            <dt>Album</dt>
            <dd>{album}</dd>
          </div>
          <div class="credit">
            <dt>Released</dt>
            <dd>{formatDate(releaseDate)}</dd>
          </div>
          <div class="credit">
            <dt>Runtime</dt>
            <dd>{formatDuration(duration)}</dd>
          </div>
          {soundsLike.length > 0 && (
            <div class="credit">
              <dt>Sounds like</dt>
              <dd>{soundsLike.join(" · ")}</dd>
            </div>
          )}
        </dl>

        <div class="review-wrap px-8">
          <div class="review-body longform">
            <slot />
          </div>
          {aiGenerated && (
            <p class="ai-note text-xs font-mono uppercase tracking-widest text-gray-400 dark:text-slate-500">
              [&nbsp;Written with AI assistance &middot; the taste is all mine&nbsp;]
            </p>
          )}
        </div>

        <div class="hatch-band" aria-hidden="true"></div>

        <section class="up-next">
          <p class="up-next-label px-8 text-xs font-mono uppercase tracking-widest text-gray-400 dark:text-slate-500">
            [&nbsp;Up next in the rotation&nbsp;]
          </p>
          <a href={`/music/reviews/${next.slug}/`} class="next-link">
            <span class="next-num" aria-hidden="true">{nextNo}</span>
            {next.albumArt && (
              <img
                class="next-thumb"
                src={next.albumArt}
                alt=""
                width="96"
                height="96"
                loading="lazy"
              />
            )}
            <span class="next-main">
              <span class="next-title">{next.title}</span>
              <span class="next-meta">{next.artist}</span>
            </span>
            <span class="next-side">{formatDuration(next.duration)}</span>
            <span class="next-arrow" aria-hidden="true">&rarr;</span>
          </a>
          <nav class="next-nav px-8">
            <a
              href="/music/reviews/"
              class="text-sm font-semibold text-red-700 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300"
              >&larr; All {totalTracks} tracks</a
            >
            <a
              href="/music"
              class="text-sm font-semibold text-red-700 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300"
              >Listening history &rarr;</a
            >
          </nav>
        </section>
      </article>
    </main>
    <Footer />

    <style>
      .song-page {
        --ink: #0f172a;
        --paper: #ffffff;
        --accent: #b91c1c;
        --hatch: #cbd5e1;
        --rule: #e2e8f0;
        --groove-a: #0b1120;
        --groove-b: #1e293b;
        --record-size: clamp(14rem, 26vw, 20rem);
        --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
      }
      :global(.dark) .song-page {
        --ink: #f1f5f9;
        --paper: #0f172a;
        --accent: #f87171;
        --hatch: #1e293b;
        --rule: #334155;
        --groove-a: #1e293b;
        --groove-b: #3e4c63;
      }

      /* ---------- Hero ---------- */
      .song-hero {
        display: grid;
        gap: clamp(2.5rem, 5vw, 4rem);
        align-items: center;
        padding-top: clamp(3rem, 7vh, 5.5rem);
        padding-bottom: clamp(2.5rem, 6vh, 4rem);
      }

      @media (min-width: 64rem) {
        .song-hero {
          grid-template-columns: minmax(0, 1fr) auto;
        }
      }

      .song-md {
        margin-left: 0.75rem;
        vertical-align: middle;
      }

      .song-title {
        margin-top: 1.25rem;
        overflow: hidden;
        font-weight: 900;
        text-transform: uppercase;
        font-size: clamp(2.25rem, 6vw, 5rem);
        line-height: 0.98;
        letter-spacing: -0.02em;
        text-wrap: balance;
        padding-right: 0.05em;
      }

      .song-title-inner {
        display: inline-block;
        will-change: transform;
      }

      .song-artist {
        margin-top: clamp(0.75rem, 2vh, 1.25rem);
        font-size: clamp(1.125rem, 2vw, 1.5rem);
        font-weight: 700;
        color: var(--accent);
      }

      /* ---------- Record ---------- */
      .song-record {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: var(--record-size);
        margin-inline: auto;
      }

      @media (min-width: 64rem) {
        .song-record {
          margin-inline: 0 clamp(3rem, 6vw, 5.5rem);
        }
      }

      .record {
        position: relative;
        width: var(--record-size);
        aspect-ratio: 1;
      }

      .record-glow {
        position: absolute;
        inset: -10%;
        width: 120%;
        height: 120%;
        border-radius: 30%;
        object-fit: cover;
        filter: blur(36px) saturate(1.5);
        opacity: 0.4;
      }

      .record-vinyl {
        position: absolute;
        inset: 4%;
        border-radius: 50%;
        transform: translateX(24%);
        background:
          radial-gradient(
            circle,
            var(--paper) 0 4.5%,
            #b91c1c 4.5% 33%,
            transparent 33%
          ),
          repeating-radial-gradient(
            circle,
            var(--groove-a) 0 1.5%,
            var(--groove-b) 1.5% 2.6%
          );
        box-shadow: 0 8px 24px rgb(2 6 23 / 0.35);
      }

      .record-vinyl::after {
        content: "";
        position: absolute;
        top: 10%;
        left: 48%;
        width: 4%;
        height: 4%;
        border-radius: 50%;
        background: rgb(241 245 249 / 0.55);
      }

      .record-cover {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 0.375rem;
        background: var(--ink);
        box-shadow:
          0 1px 2px rgb(2 6 23 / 0.2),
          0 16px 40px rgb(2 6 23 / 0.3);
      }

      .record-cover-fallback {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: calc(var(--record-size) / 2.5);
        font-weight: 900;
        color: var(--accent);
        background-color: var(--paper);
        background-image: repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 4px,
          var(--hatch) 4px,
          var(--hatch) 5px
        );
        border: 1px solid var(--rule);
      }

      .spotify-btn {
        width: 100%;
      }

      /* ---------- Hatch band ---------- */
      .hatch-band {
        height: 0.875rem;
        border-block: 1px solid var(--rule);
        background-image: repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 4px,
          var(--hatch) 4px,
          var(--hatch) 5px
        );
      }

      /* ---------- Credits ---------- */
      .credits {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem clamp(2.5rem, 6vw, 5rem);
        margin: 0;
        padding-block: 1.375rem;
        border-bottom: 1px solid var(--rule);
      }

      .credit dt {
        font-family: var(--font-mono, ui-monospace, monospace);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #94a3b8;
      }

      .credit dd {
        margin: 0.25rem 0 0;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--ink);
      }

      /* ---------- Review body ---------- */
      .review-wrap {
        padding-block: clamp(2.5rem, 6vw, 4.5rem) clamp(2.5rem, 5vw, 3.5rem);
      }

      .review-body {
        max-width: 65ch;
        font-size: 1.0625rem;
        line-height: 1.85;
        color: #334155;
      }

      :global(.dark) .review-body {
        color: #cbd5e1;
      }

      @media (min-width: 48rem) {
        .review-body {
          font-size: 1.125rem;
        }
      }

      .review-body :global(p + p) {
        margin-top: 1.5em;
      }

      .review-body :global(p:first-child)::first-letter {
        float: left;
        font-size: 3.6em;
        line-height: 0.82;
        font-weight: 900;
        margin-right: 0.09em;
        margin-top: 0.04em;
        color: var(--accent);
      }

      .ai-note {
        margin-top: clamp(2rem, 4vw, 3rem);
      }

      /* ---------- Up next ---------- */
      .up-next {
        padding-top: 2.5rem;
      }

      .up-next-label {
        margin-bottom: 1rem;
      }

      .next-link {
        display: flex;
        align-items: center;
        gap: clamp(1rem, 2.5vw, 2rem);
        padding: clamp(1rem, 2.2vw, 1.625rem) 2rem;
        border-block: 1px solid var(--rule);
        text-decoration: none;
        color: inherit;
      }

      .next-link:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: -2px;
      }

      .next-num {
        flex: none;
        width: 2.25rem;
        font-family: var(--font-mono, ui-monospace, monospace);
        font-size: 0.8125rem;
        font-variant-numeric: tabular-nums;
        color: #94a3b8;
        transition: color 0.2s var(--ease-out-quart);
      }

      .next-thumb {
        flex: none;
        width: 3.5rem;
        height: 3.5rem;
        border-radius: 0.25rem;
        object-fit: cover;
      }

      .next-main {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        transition: transform 0.35s var(--ease-out-quart);
      }

      .next-title {
        font-size: clamp(1.25rem, 2.3vw, 2rem);
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.01em;
        color: var(--ink);
        transition: color 0.2s var(--ease-out-quart);
      }

      .next-meta {
        font-size: 0.8125rem;
        color: #64748b;
      }

      :global(.dark) .next-meta {
        color: #94a3b8;
      }

      .next-side {
        flex: none;
        font-family: var(--font-mono, ui-monospace, monospace);
        font-variant-numeric: tabular-nums;
        font-size: 0.8125rem;
        color: #94a3b8;
      }

      .next-arrow {
        flex: none;
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--accent);
        opacity: 0;
        transform: translateX(-0.375rem);
        transition:
          opacity 0.25s var(--ease-out-quart),
          transform 0.25s var(--ease-out-quart);
      }

      @media (hover: hover) and (pointer: fine) {
        .next-link:hover .next-title,
        .next-link:hover .next-num {
          color: var(--accent);
        }
        .next-link:hover .next-main {
          transform: translateX(0.5rem);
        }
        .next-link:hover .next-arrow {
          opacity: 1;
          transform: translateX(0);
        }
      }

      .next-link:focus-visible .next-title,
      .next-link:focus-visible .next-num {
        color: var(--accent);
      }
      .next-link:focus-visible .next-arrow {
        opacity: 1;
        transform: translateX(0);
      }

      .next-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem 2.5rem;
        padding-block: 2rem clamp(3rem, 8vh, 6rem);
      }

      @media (prefers-reduced-motion: reduce) {
        .next-main,
        .next-arrow,
        .next-num,
        .next-title {
          transition: none;
        }
      }
    </style>

    <script>
      import gsap from "gsap";

      let kill: (() => void) | null = null;

      function init() {
        const hero = document.querySelector<HTMLElement>(".song-hero");
        if (!hero) return;

        kill?.();

        const reduceMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        if (reduceMotion) return;

        const titleInner = hero.querySelector(".song-title-inner");
        const fades = hero.querySelectorAll(".hero-fade");
        const record = hero.querySelector(".record");
        const vinyl = hero.querySelector(".record-vinyl");

        const tl = gsap.timeline({ defaults: { ease: "expo.out" } });
        if (titleInner) {
          gsap.set(titleInner, { yPercent: 110 });
          tl.to(titleInner, { yPercent: 0, duration: 1 }, 0.1);
        }
        gsap.set(fades, { opacity: 0, y: 16 });
        tl.to(fades, { opacity: 1, y: 0, duration: 0.7, stagger: 0.1 }, 0.4);

        let spin: gsap.core.Tween | null = null;
        if (record && vinyl) {
          // The CSS resting transform (translateX(24%)) is for no-JS/reduced
          // motion; clear it so GSAP owns the transform from a clean slate.
          (vinyl as HTMLElement).style.transform = "none";
          gsap.set(record, { opacity: 0, y: 28, scale: 0.97 });
          tl.to(record, { opacity: 1, y: 0, scale: 1, duration: 0.9 }, 0.35);
          tl.fromTo(
            vinyl,
            { xPercent: 0 },
            { xPercent: 24, duration: 0.7, ease: "power3.out" },
            0.95,
          );
          spin = gsap.to(vinyl, {
            rotation: 360,
            duration: 3.5,
            repeat: -1,
            ease: "none",
          });
        }

        kill = () => {
          tl.kill();
          spin?.kill();
        };
      }

      document.addEventListener("astro:page-load", init);
      document.addEventListener("astro:before-swap", () => {
        kill?.();
        kill = null;
      });
    </script>
  </body>
</html>
