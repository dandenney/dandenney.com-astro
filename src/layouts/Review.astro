---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import toTitleCase from '@/helpers/toTitleCase.js';
import { episodeMap } from '@/helpers/nrai';
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import '@/styles/nrai.css';

interface Props {
	id?: string;
	city: string;
	country: string;
	description: string;
	state?: string;
	tags?: string[];
	heroImageAlt?: string;
	heroImage?: string;
	heroImageUrl?: string;
	heroImageAttribution?: string;
	title: string;
	pubDate?: Date;
}

const { id, city, country, description, state, tags, heroImageAlt, heroImage, heroImageUrl, heroImageAttribution, title, pubDate } = Astro.props;

const ep = id ? episodeMap(await getCollection('reviews')).get(id) : undefined;
const airDate = pubDate
	? pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase()
	: undefined;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} type="restaurant" image={heroImage ? `/no-reserv-ai-tions/${heroImage}.webp` : undefined} />
		<link href="https://fonts.googleapis.com/css2?family=Anton&family=Special+Elite&display=swap" rel="stylesheet">
		<ClientRouter />
	</head>
	<body class="nrai">
		<main id="main-content" tabindex="-1" class="relative shadow-xs z-10">
			<Header />

			<article class="rev">
				<header class="rev-open">
					<p class="rev-meta tw-links">
						{ep && <span class="ep-tab">Ep. {ep}</span>}
						<span>
							<a href={`/no-reserv-ai-tions/cities/${city}`}>{toTitleCase(city)}</a>{state
								? <>, <a href={`/no-reserv-ai-tions/states/${state}`}>{toTitleCase(state)}</a></>
								: country !== 'United States' && <>, <a href="/no-reserv-ai-tions/international">{country}</a></>}
						</span>
						{airDate && <span>Air date: {airDate}</span>}
					</p>

					<h1 class="rev-title">{title}</h1>

					<p class="rev-log">{description}</p>
				</header>

				{heroImage && (
					<figure class="rev-still filmgrain" id="hero-wrapper">
						<img id="photo" src={`/no-reserv-ai-tions/${heroImage}.webp`} alt={heroImageAlt} fetchpriority="high" />
					</figure>
				)}
				{heroImageAttribution && (
					<p class="rev-credit tw-links">Photo credit: <a href={heroImageUrl}>{heroImageAttribution}</a></p>
				)}

				<div class="longform review rev-body">
					<slot />
				</div>

				{tags && (
					<p class="rev-tags tw-links">
						Filed under:
						{tags.map((tag, index) => (
							<>
								{index > 0 ? ' · ' : ' '}
								<a href={`/no-reserv-ai-tions/${tag}`}>{toTitleCase(tag)}</a>
							</>
						))}
					</p>
				)}

				<nav class="rev-nav tw-links" aria-label="Browse reviews">
					<a class="cue-btn" href="/no-reserv-ai-tions"><span aria-hidden="true">&larr;</span> The cold open</a>
					<p>Or by <a href="/no-reserv-ai-tions/1">newest</a>, <a href="/no-reserv-ai-tions/cities">city</a>, <a href="/no-reserv-ai-tions/states">state</a>, <a href="/no-reserv-ai-tions/tags">tag</a>, or <a href="/no-reserv-ai-tions/international">country</a></p>
				</nav>
			</article>
		</main>
		<Footer />

		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>

		<script is:inline>
			document.addEventListener('astro:page-load', () => {
				if (!document.getElementById('photo')) return;
				gsap.registerPlugin(ScrollTrigger);

				gsap.matchMedia().add('(prefers-reduced-motion: no-preference)', () => {
					gsap.to('#photo', {
						yPercent: -8,
						ease: 'none',
						scrollTrigger: {
							trigger: '#hero-wrapper',
							start: 'top bottom',
							end: 'bottom top',
							scrub: true,
						},
					});
				});
			});
		</script>

		<style>
			.rev {
				max-width: 64rem;
				margin-inline: auto;
				padding: clamp(1.5rem, 4vw, 3.5rem) clamp(1rem, 4vw, 2rem) clamp(3rem, 6vw, 5rem);
			}

			.rev-open {
				max-width: 48rem;
				margin-inline: auto;
			}
			.rev-meta {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.5rem 1.25rem;
				font-family: var(--font-type);
				font-size: clamp(0.78rem, 1.1vw, 0.95rem);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--nrai-smoke);
			}
			.rev-title {
				font-family: var(--font-display);
				font-weight: 400;
				font-size: clamp(2.4rem, 6vw, 5.5rem);
				line-height: 0.95;
				text-transform: uppercase;
				letter-spacing: 0.01em;
				color: var(--nrai-ink);
				margin-top: 1.25rem;
				text-wrap: balance;
			}
			.rev-log {
				font-family: var(--font-serif);
				font-style: italic;
				font-size: clamp(1.15rem, 1.8vw, 1.45rem);
				line-height: 1.55;
				color: var(--nrai-smoke);
				margin-top: 1rem;
				max-width: 58ch;
			}

			.rev-still {
				overflow: hidden;
				margin-top: clamp(2rem, 4vw, 3rem);
				background: var(--nrai-panel);
			}
			.rev-still img {
				display: block;
				width: 100%;
				height: auto;
				filter: saturate(0.85) contrast(1.05) brightness(0.94);
			}
			.rev-still::before {
				content: '';
				position: absolute;
				inset: 0;
				z-index: 1;
				pointer-events: none;
				background: radial-gradient(130% 100% at 50% 40%, transparent 60%, oklch(0% 0 0 / 0.35));
			}
			.rev-credit {
				font-family: var(--font-type);
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--nrai-smoke);
				text-align: right;
				margin-top: 0.6rem;
			}

			.rev-body {
				max-width: 48rem;
				margin-inline: auto;
				margin-top: clamp(2rem, 4vw, 3rem);
			}

			.rev-tags {
				max-width: 48rem;
				margin-inline: auto;
				margin-top: clamp(2rem, 4vw, 3rem);
				font-family: var(--font-type);
				font-size: clamp(0.78rem, 1.1vw, 0.95rem);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--nrai-smoke);
			}

			.rev-nav {
				max-width: 48rem;
				margin-inline: auto;
				margin-top: clamp(2.5rem, 5vw, 4rem);
				padding-top: clamp(1.5rem, 3vw, 2.5rem);
				border-top: 1px solid var(--nrai-line);
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 1rem 1.5rem;
				justify-content: space-between;
			}
			.rev-nav p {
				font-family: var(--font-type);
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--nrai-smoke);
			}
		</style>
	</body>
</html>
