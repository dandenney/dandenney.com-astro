---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import toTitleCase from '../../helpers/toTitleCase.js';
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';

import ReviewLinkItem from '../../components/ReviewLinkItem.astro';
import ReviewLinkItemJs from '../../components/ReviewLinkItemJs.astro';

export const prerender = true;

export async function getStaticPaths() {
  const allReviews = await getCollection('reviews');

  const uniqueTags = [...new Set(allReviews.map((review) => review.data.tags).flat())];

  return uniqueTags.map((tag) => {
    const filteredReviews = allReviews.filter((review) =>
      review.data.tags.includes(tag)
    );

    return {
      params: { tag },
      props: { reviews: filteredReviews },
    };
  });
}

const { tag } = Astro.params;
const { reviews } = Astro.props;

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="No ReservAItions" description="Reviews of food, music, and events with the help of AI" />
		<ClientRouter />
	</head>
	<body class="bg-slate-50 dark:bg-slate-900">
		<Header />
		<main class="bg-slate-50 dark:bg-slate-900 relative shadow-xs z-10 dark:text-slate-200" style="min-height: 90dvh;">
			<section class="max-w-(--breakpoint-xl) mx-auto pb-24 pt-8 px-4">
				<h2 class="border-b text-center text-4xl font-bold pb-4 tracking-tight text-gray-900 dark:text-slate-100 md:shrink-0 md:text-left xl:border-0 xl:text-6xl">{toTitleCase(tag)}</h2>
				<ul class="md:flex md:flex-wrap gap-y-8 mt-8">
					{reviews.map((review) => {
						return(
              <ReviewLinkItem review={review} />
					)})}
				</ul>
      </section>
		</main>
		<Footer />
    <ReviewLinkItemJs />
	</body>
</html>