---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import toTitleCase from '@/helpers/toTitleCase.js';
import EpisodeRow from '@/components/nrai/EpisodeRow.astro';
import { episodeMap } from '@/helpers/nrai';
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import '@/styles/nrai.css';

export const prerender = true;

export async function getStaticPaths() {
	const allReviews = await getCollection('reviews');

	const uniqueTags = [...new Set(allReviews.map((review) => review.data.tags).flat())];

	return uniqueTags.map((tag) => {
		const filteredReviews = allReviews.filter((review) => review.data.tags.includes(tag));

		return {
			params: { tag },
			props: { reviews: filteredReviews },
		};
	});
}

const { tag } = Astro.params;
const { reviews } = Astro.props;

const eps = episodeMap(await getCollection('reviews'));
const sorted = [...reviews].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`No ReservAItions: ${toTitleCase(tag)}`} description="Reviews of food, music, and events with the help of AI" />
		<link href="https://fonts.googleapis.com/css2?family=Anton&family=Special+Elite&display=swap" rel="stylesheet">
		<ClientRouter />
	</head>
	<body class="nrai">
		<main id="main-content" class="relative shadow-xs z-10">
			<Header />
			<section class="run">
				<h2 class="slate">
					<span class="slate-mark" aria-hidden="true"></span>{toTitleCase(tag)}
					<span class="slate-note">tagged craving &middot; {sorted.length} {sorted.length === 1 ? 'episode' : 'episodes'}</span>
				</h2>
				<ul role="list">
					{sorted.map((review, i) => (
						<EpisodeRow review={review} ep={eps.get(review.id) ?? 0} eager={i < 3} />
					))}
				</ul>
				<nav class="run-nav" aria-label="Browse">
					<a class="cue-btn" href="/no-reserv-ai-tions/tags"><span aria-hidden="true">&larr;</span> All tags</a>
				</nav>
			</section>
		</main>
		<Footer />

		<style>
			.run {
				max-width: 80rem;
				margin-inline: auto;
				padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 4rem) clamp(3rem, 6vw, 5rem);
			}
			.run ul {
				border-bottom: 1px solid var(--nrai-line);
			}
			.run-nav {
				display: flex;
				justify-content: center;
				padding-top: clamp(2rem, 4vw, 3rem);
			}
		</style>
	</body>
</html>
