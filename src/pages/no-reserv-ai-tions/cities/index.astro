---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import toTitleCase from '@/helpers/toTitleCase.js';
import MapCard from '@/components/nrai/MapCard.astro';
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import '@/styles/nrai.css';

export const prerender = true;

const allReviews = await getCollection('reviews');

// Build city data: name, review count, and a representative image
const cityMap = new Map();
for (const review of allReviews) {
	const cityKey = String(review.data.city).toLowerCase();
	if (!cityMap.has(cityKey)) {
		cityMap.set(cityKey, {
			name: cityKey,
			count: 0,
			image: review.data.heroImage,
			imageAlt: review.data.heroImageAlt,
			state: review.data.state,
			country: review.data.country,
		});
	}
	cityMap.get(cityKey).count++;
}

const cities = [...cityMap.values()].sort((a, b) => b.count - a.count);
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="No ReservAItions Cities | Dan Denney" description="Reviews of food, music, and events with the help of AI" />
		<link href="https://fonts.googleapis.com/css2?family=Anton&family=Special+Elite&display=swap" rel="stylesheet">
		<ClientRouter />
	</head>
	<body class="nrai">
		<main id="main-content" class="relative shadow-xs z-10">
			<Header />
			<section class="map">
				<h2 class="slate">
					<span class="slate-mark" aria-hidden="true"></span>Cities
					<span class="slate-note">{cities.length} cities &middot; {allReviews.length} episodes &middot; in the spirit of Bourdain</span>
				</h2>

				<nav class="map-grid grid grid-cols-2 gap-3 md:grid-cols-3 lg:grid-cols-4 xl:gap-4">
					{cities.map((city, i) => (
						<MapCard
							href={`/no-reserv-ai-tions/cities/${city.name}`}
							image={city.image}
							imageAlt={city.imageAlt}
							name={toTitleCase(city.name)}
							tab={`${city.count} ${city.count === 1 ? 'ep' : 'eps'}`}
							sub={city.country === 'United States' && city.state ? toTitleCase(city.state) : city.country}
							class={i < 3 ? 'aspect-[4/5] md:col-span-1 lg:first:col-span-2 lg:first:row-span-2' : 'aspect-square'}
							eager={i < 8}
						/>
					))}
				</nav>
			</section>
		</main>
		<Footer />

		<style>
			.map {
				max-width: 96rem;
				margin-inline: auto;
				padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 4rem) clamp(3rem, 6vw, 5rem);
			}
		</style>
	</body>
</html>
