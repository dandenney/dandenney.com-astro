---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import toTitleCase from '@/helpers/toTitleCase.js';
import MapCard from '@/components/nrai/MapCard.astro';
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import '@/styles/nrai.css';

export const prerender = true;

const allReviews = await getCollection('reviews');

// Build tag data: name, count, and a representative image
const tagMap = new Map();
for (const review of allReviews) {
	const tags = review.data.tags || [];
	for (const tag of tags) {
		const tagKey = String(tag).toLowerCase();
		if (!tagMap.has(tagKey)) {
			tagMap.set(tagKey, {
				name: tagKey,
				count: 0,
				image: review.data.heroImage,
				imageAlt: review.data.heroImageAlt,
			});
		}
		tagMap.get(tagKey).count++;
	}
}

const tags = [...tagMap.values()].sort((a, b) => b.count - a.count);
const maxCount = tags[0]?.count || 1;
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="No ReservAItions Tags | Dan Denney" description="Reviews of food, music, and events with the help of AI" />
		<link href="https://fonts.googleapis.com/css2?family=Anton&family=Special+Elite&display=swap" rel="stylesheet">
		<ClientRouter />
	</head>
	<body class="nrai">
		<main id="main-content" class="relative shadow-xs z-10">
			<Header />
			<section class="map">
				<h2 class="slate">
					<span class="slate-mark" aria-hidden="true"></span>Tags
					<span class="slate-note">{tags.length} cravings across {allReviews.length} episodes</span>
				</h2>

				<!-- Top tags as film frames -->
				<div class="grid grid-cols-2 gap-3 md:grid-cols-4 lg:grid-cols-6 xl:gap-4">
					{tags.slice(0, 12).map((tag, i) => (
						<MapCard
							href={`/no-reserv-ai-tions/${tag.name}`}
							image={tag.image}
							imageAlt={tag.imageAlt}
							name={toTitleCase(tag.name)}
							tab={`${tag.count} ${tag.count === 1 ? 'ep' : 'eps'}`}
							class={`aspect-square ${i < 2 ? 'col-span-2 row-span-2 md:col-span-2 md:row-span-2' : ''}`}
							eager
						/>
					))}
				</div>

				<!-- Remaining tags -->
				{tags.length > 12 && (
					<div class="ledger">
						<h3 class="ledger-head">The rest of the manifest</h3>
						<nav class="ledger-list">
							{tags.slice(12).map((tag) => {
								const ratio = tag.count / maxCount;
								const size = ratio > 0.3 ? 'ledger-lg' : ratio > 0.15 ? 'ledger-md' : 'ledger-sm';
								return (
									<a href={`/no-reserv-ai-tions/${tag.name}`} class={size}>
										{toTitleCase(tag.name)}<sup>({tag.count})</sup>
									</a>
								);
							})}
						</nav>
					</div>
				)}
			</section>
		</main>
		<Footer />

		<style>
			.map {
				max-width: 96rem;
				margin-inline: auto;
				padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 4rem) clamp(3rem, 6vw, 5rem);
			}
			.ledger {
				margin-top: clamp(2.5rem, 5vw, 4rem);
				border-top: 1px solid var(--nrai-line);
				padding-top: clamp(1.5rem, 3vw, 2.5rem);
			}
			.ledger-head {
				font-family: var(--font-type);
				font-size: clamp(0.8rem, 1.2vw, 0.95rem);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--nrai-smoke);
				margin-bottom: 1.5rem;
			}
			.ledger-list {
				display: flex;
				flex-wrap: wrap;
				align-items: baseline;
				gap: 0.9rem 1.75rem;
			}
			.ledger-list a {
				font-family: var(--font-display);
				text-transform: uppercase;
				letter-spacing: 0.02em;
				color: var(--nrai-ink);
				text-decoration: none;
				transition: color 0.2s ease-out;
			}
			.ledger-list a:hover {
				color: var(--nrai-red-bright);
			}
			.ledger-list sup {
				font-family: var(--font-type);
				font-size: 0.6em;
				color: var(--nrai-red-bright);
				margin-left: 0.3rem;
				letter-spacing: 0.05em;
			}
			.ledger-lg {
				font-size: clamp(1.6rem, 2.6vw, 2.2rem);
			}
			.ledger-md {
				font-size: clamp(1.2rem, 1.9vw, 1.6rem);
			}
			.ledger-sm {
				font-size: clamp(0.95rem, 1.4vw, 1.15rem);
			}
		</style>
	</body>
</html>
