---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Review from '../../layouts/Review.astro';
import { twinUrlForId } from '@/lib/markdownTwin';

export const prerender = true;

export async function getStaticPaths() {
	const reviews = await getCollection('reviews');
	return reviews.map((review) => ({
		params: { slug: review.id.replace(/\.mdx?$/, '') },
		props: review,
	}));
}
type Props = CollectionEntry<'reviews'>;

const review = Astro.props;
const { Content } = await render(review);
---

<Review {...review.data} id={review.id} markdownTwin={twinUrlForId('reviews', review.id)}>
	<Content />
</Review>
