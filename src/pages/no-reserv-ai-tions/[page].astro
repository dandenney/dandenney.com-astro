---
import { type CollectionEntry, getCollection } from 'astro:content';
import type { Page } from 'astro';
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import EpisodeRow from '@/components/nrai/EpisodeRow.astro';
import { ClientRouter } from 'astro:transitions';
import '@/styles/nrai.css';

export const prerender = true;

type Props = { page: Page<CollectionEntry<'reviews'>> };

export async function getStaticPaths({ paginate }: { paginate: Function }) {
	const reviews = (await getCollection('reviews')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
	);
	return paginate(reviews, { pageSize: 6 });
}

const { page } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="No ReservAItions" description="Reviews of food, music, and events with the help of AI" />
		<link href="https://fonts.googleapis.com/css2?family=Anton&family=Special+Elite&display=swap" rel="stylesheet">
		<ClientRouter />
	</head>
	<body class="nrai">
		<main id="main-content" class="relative shadow-xs z-10">
			<Header />
			<section class="run">
				<h2 class="slate">
					<span class="slate-mark" aria-hidden="true"></span>The full run
					<span class="slate-note">page {page.currentPage} of {page.lastPage} &middot; {page.total} episodes</span>
				</h2>
				<ul role="list">
					{page.data.map((review, i) => (
						<EpisodeRow review={review} ep={page.total - (page.start + i)} eager={i < 3} />
					))}
				</ul>
				<nav class="run-nav" aria-label="Pagination">
					{page.url.prev && <a class="cue-btn" href={page.url.prev}><span aria-hidden="true">&larr;</span> Prev</a>}
					<span class="run-nav-where">Reel {page.currentPage} / {page.lastPage}</span>
					{page.url.next && <a class="cue-btn" href={page.url.next}>Next <span aria-hidden="true">&rarr;</span></a>}
				</nav>
			</section>
		</main>
		<Footer />

		<style>
			.run {
				max-width: 80rem;
				margin-inline: auto;
				padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 4rem) clamp(3rem, 6vw, 5rem);
			}
			.run ul {
				border-bottom: 1px solid var(--nrai-line);
			}
			.run-nav {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 1.5rem;
				padding-top: clamp(2rem, 4vw, 3rem);
			}
			.run-nav-where {
				font-family: var(--font-type);
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--nrai-smoke);
			}
		</style>
	</body>
</html>
