---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import toTitleCase from '@/helpers/toTitleCase.js';
import MapCard from '@/components/nrai/MapCard.astro';
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import '@/styles/nrai.css';

export const prerender = true;

const allReviews = await getCollection('reviews');

// Build state data: name, review count, representative image, and cities
const stateMap = new Map();
for (const review of allReviews) {
	const stateKey = String(review.data.state).toLowerCase();
	if (!stateKey || stateKey === 'undefined') continue;
	if (!stateMap.has(stateKey)) {
		stateMap.set(stateKey, {
			name: stateKey,
			count: 0,
			image: review.data.heroImage,
			imageAlt: review.data.heroImageAlt,
			cities: new Set(),
		});
	}
	const entry = stateMap.get(stateKey);
	entry.count++;
	const city = String(review.data.city).toLowerCase();
	if (city) entry.cities.add(city);
}

const states = [...stateMap.values()].sort((a, b) => b.count - a.count);
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="No ReservAItions States | Dan Denney" description="Reviews of food, music, and events with the help of AI" />
		<link href="https://fonts.googleapis.com/css2?family=Anton&family=Special+Elite&display=swap" rel="stylesheet">
		<ClientRouter />
	</head>
	<body class="nrai">
		<main id="main-content" class="relative shadow-xs z-10">
			<Header />
			<section class="map">
				<h2 class="slate">
					<span class="slate-mark" aria-hidden="true"></span>States
					<span class="slate-note">{states.length} states &middot; {allReviews.filter((r) => r.data.state).length} episodes</span>
				</h2>

				<nav class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
					{states.map((state, i) => (
						<MapCard
							href={`/no-reserv-ai-tions/states/${state.name}`}
							image={state.image}
							imageAlt={state.imageAlt}
							name={toTitleCase(state.name)}
							tab={`${state.count} ${state.count === 1 ? 'ep' : 'eps'}`}
							sub={`${state.cities.size} ${state.cities.size === 1 ? 'city' : 'cities'}`}
							class={i === 0 ? 'aspect-[16/9] sm:col-span-2 lg:col-span-2' : 'aspect-[4/3]'}
							eager={i < 4}
						/>
					))}
				</nav>
			</section>
		</main>
		<Footer />

		<style>
			.map {
				max-width: 96rem;
				margin-inline: auto;
				padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 4rem) clamp(3rem, 6vw, 5rem);
			}
		</style>
	</body>
</html>
