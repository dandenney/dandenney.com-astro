---
import BaseHead from "@/components/BaseHead.astro";
import CaseBoard from "@/components/case-file/CaseBoard.astro";
import CaseGallery from "@/components/case-file/CaseGallery.astro";
import CasePoster from "@/components/case-file/CasePoster.astro";
import CaseSources from "@/components/case-file/CaseSources.astro";
import CaseTimeline from "@/components/case-file/CaseTimeline.astro";
import { mitriceRichardsonCase } from "@/data/cases/mitriceRichardson";
import { caseFileToTimeline } from "@/data/cases/utils";

export const prerender = true;

const title = "The Death of Mitrice Richardson";
const summary =
  "An interactive case file on the death of Mitrice Richardson: released from a Malibu-area sheriff's station at 12:28 a.m. in 2009 with no money, phone, or vehicle, found in a canyon eleven months later, and still no answers.";
const pubDate = new Date("2026-07-08");
const ogImage = "/true-crime/cases/mitrice-richardson/mitrice-richardson.jpg";

const mitrice = mitriceRichardsonCase.people.find((p) => p.id === "mitrice-richardson")!;
const record = caseFileToTimeline(mitriceRichardsonCase, { hrefFor: (event) => `#t:${event.id}` });
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead title={title} description={summary} image={ogImage} type="blogpost" datePublished={pubDate} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,100..900&family=Fragment+Mono&display=swap"
      rel="stylesheet"
    />
    <link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet" />
  </head>
  <body class="cp">
    <header class="cp-nav">
      <a href="/">dandenney.com</a>
      <a href="https://www.truecrimeresearchers.com/cases/mitrice-richardson">See the original 2019 case file</a>
    </header>

    <section class="cp-hero">
      <p class="cp-meta">
        <span>Case file</span>
        <span>Malibu, California</span>
        <span>2009–2010</span>
      </p>
      <h1 class="cp-title">Mitrice<br />Richardson</h1>
      <div class="cp-lede">
        <p>
          Mitrice Richardson was a 24-year-old psychology graduate of Cal State Fullerton. On the evening of
          September 16, 2009, she was acting unusually at a Malibu restaurant and was taken into custody by
          sheriff's deputies. At approximately 12:28 a.m., she walked out of the Lost Hills Sheriff Station with no
          money, no phone, and no vehicle, 12 to 15 miles from her car, and went missing.
        </p>
        <p>
          On August 9, 2010, human remains found in a canyon were confirmed to be Mitrice. In the months before she
          was found, and continually afterward, an overwhelming number of contradictions and negligence by the
          department came to light. The board below holds the timeline of that night and everything after. She is a
          person, like you and me, and her story deserves to be told.
        </p>
      </div>
      <p class="cp-hint" aria-hidden="true">↓</p>
    </section>

    <section class="cp-poster">
      <CasePoster
        kicker="Suspicious death"
        tone="remains"
        name={mitrice.name}
        statusLine="Last seen September 17, 2009 · Found August 9, 2010 · Malibu, California"
        photo={mitrice.photo}
        photoAlt={mitrice.photoAlt}
        facts={mitrice.facts}
      >
        <p>
          The family eventually won a settlement based on the negligence of the department, but there are still no
          answers as to what happened to Mitrice. Her case remains open and is documented at
          <a href="https://uncovered.com/cases/mitrice-richardson">Uncovered</a>.
        </p>
      </CasePoster>
    </section>

    {mitriceRichardsonCase.exhibits && (
      <section class="cp-exhibits">
        <header class="cp-section-head">
          <p class="cp-kicker">Evidence</p>
          <h2>The exhibits</h2>
          <p>
            Photographs and documents from the file, kept from the original research. Select any exhibit to view
            it with its notes.
          </p>
        </header>
        <CaseGallery exhibits={mitriceRichardsonCase.exhibits} />
      </section>
    )}

    <section class="cp-record">
      <header class="cp-section-head">
        <p class="cp-kicker">Chronology</p>
        <h2>The record</h2>
        <p>
          Eleven months, from the night at Geoffrey's to the canyon where she was found. Select any entry to open it
          on the board below.
        </p>
      </header>
      <CaseTimeline groups={record} />
    </section>

    <CaseBoard caseFile={mitriceRichardsonCase} />

    <section class="cp-outro">
      <div class="cp-outro-col">
        <h2>Only questions</h2>
        <p>
          How did she end up deep in a wooded area, and how did she die? Her remains were found miles from the
          station that released her into the dark, and only about a mile from the house where a woman many believe
          was Mitrice had been reported, inside the radius the searches had covered. The negligence was acknowledged
          in a settlement. The answers never came.
        </p>
        <p>
          If you haven't yet heard Mitrice's story, Los Angeles Magazine's longform piece
          <a href="https://www.lamag.com/longform/what-happened-to-mitrice-richardson/">What Happened To Mitrice
          Richardson?</a> is a thorough place to start, and the podcast coverage in the sources below goes deeper.
        </p>
      </div>
      <div class="cp-outro-col">
        <h2>If you know something</h2>
        <p>
          The case is still open. <a href="https://uncovered.com/cases/mitrice-richardson">Uncovered</a> maintains
          an active case file, and any information can be shared with the Los Angeles County Sheriff's Department's
          Homicide Bureau.
        </p>
        <h2>About this page</h2>
        <p>
          This is a rebuild of a case file from
          <a href="https://www.truecrimeresearchers.com/cases/mitrice-richardson">True Crime Researchers</a>, an
          older project of mine. The remains marker is the general area given to the coroner and the family, not
          exact coordinates; the other locations come from the original research.
        </p>
      </div>
    </section>

    <section class="cp-sources">
      <header class="cp-section-head">
        <p class="cp-kicker">Citations</p>
        <h2>Sources</h2>
        <p>The reporting, research, and coverage this case file draws on.</p>
      </header>
      <CaseSources groups={mitriceRichardsonCase.sources ?? []} />
    </section>

    <footer class="cp-footer">
      <a href="/">dandenney.com</a>
      <span>Made with care for Mitrice and her family</span>
    </footer>

    <script is:inline src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
  }

  .cp {
    margin: 0;
    background: #0b0d12;
    color: #e9ebef;
    font-family: "Archivo", system-ui, sans-serif;
  }

  .cp a {
    color: inherit;
    text-decoration-color: rgba(233, 235, 239, 0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 200ms ease;
  }

  .cp a:hover {
    text-decoration-color: #e3a94f;
  }

  .cp-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem clamp(1rem, 4vw, 3rem);
    font-family: "Fragment Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
  }

  .cp-nav a {
    text-decoration: none;
    color: #a3abba;
  }

  .cp-nav a:hover {
    color: #e9ebef;
  }

  /* ---------- Hero ---------- */

  .cp-hero {
    padding: clamp(3rem, 9vh, 6.5rem) clamp(1rem, 4vw, 3rem) clamp(2.5rem, 7vh, 5rem);
    max-width: 78rem;
    margin: 0 auto;
  }

  .cp-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.75rem;
    margin: 0 0 1.75rem;
    font-family: "Fragment Mono", ui-monospace, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #a3abba;
  }

  .cp-meta span + span {
    position: relative;
  }

  .cp-meta span + span::before {
    content: "";
    position: absolute;
    left: -1rem;
    top: 50%;
    width: 3px;
    height: 3px;
    border-radius: 999px;
    translate: 0 -50%;
    background: #666e7d;
  }

  .cp-title {
    margin: 0 0 2.25rem;
    font-size: clamp(3rem, 10vw, 8rem);
    font-weight: 870;
    font-variation-settings: "wdth" 118;
    line-height: 0.94;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .cp-lede {
    max-width: 62ch;
    display: grid;
    gap: 1rem;
  }

  .cp-lede p {
    margin: 0;
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.7;
    color: #c3c9d4;
  }

  .cp-hint {
    margin: 3rem 0 0;
    font-family: "Fragment Mono", ui-monospace, monospace;
    color: #666e7d;
    animation: cp-drift 2.4s ease-in-out infinite;
  }

  @keyframes cp-drift {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ---------- Poster ---------- */

  .cp-poster {
    max-width: 62rem;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem) clamp(3rem, 8vh, 5.5rem);
  }

  /* ---------- The exhibits ---------- */

  .cp-exhibits {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 9vh, 6.5rem) clamp(1rem, 4vw, 3rem) clamp(1.5rem, 4vh, 3rem);
  }

  /* ---------- The record ---------- */

  .cp-record,
  .cp-sources {
    max-width: 62rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 9vh, 6.5rem) clamp(1rem, 4vw, 3rem) clamp(1.5rem, 4vh, 3rem);
  }

  .cp-sources {
    padding-top: 0;
    padding-bottom: clamp(3.5rem, 9vh, 6.5rem);
  }

  .cp-kicker {
    margin: 0 0 0.9rem;
    font-family: "Fragment Mono", ui-monospace, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #666e7d;
  }

  .cp-section-head {
    margin-bottom: clamp(2.25rem, 5vh, 3.5rem);
  }

  .cp-section-head h2 {
    margin: 0 0 0.9rem;
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    font-weight: 820;
    font-variation-settings: "wdth" 112;
    letter-spacing: -0.015em;
    line-height: 1;
    text-transform: uppercase;
  }

  .cp-section-head p:last-child {
    margin: 0;
    max-width: 58ch;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #a3abba;
  }

  /* ---------- Outro ---------- */

  .cp-outro {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: clamp(2rem, 5vw, 4.5rem);
    max-width: 78rem;
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 5.5rem) clamp(1rem, 4vw, 3rem);
  }

  .cp-outro h2 {
    margin: 0 0 1rem;
    font-size: 1.4rem;
    font-weight: 780;
    font-variation-settings: "wdth" 110;
    letter-spacing: -0.01em;
  }

  .cp-outro h2 + p + h2 {
    margin-top: 2.25rem;
  }

  .cp-outro p {
    margin: 0 0 1rem;
    max-width: 58ch;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #a3abba;
  }

  .cp-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem clamp(1rem, 4vw, 3rem) 2rem;
    border-top: 1px solid rgba(233, 235, 239, 0.12);
    font-family: "Fragment Mono", ui-monospace, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    color: #666e7d;
  }

  .cp-footer a {
    color: #a3abba;
    text-decoration: none;
  }

  .cp-footer a:hover {
    color: #e9ebef;
  }

  @media (prefers-reduced-motion: reduce) {
    .cp-hint {
      animation: none;
    }
  }
</style>
