---
import BaseHead from "@/components/BaseHead.astro";
import CaseBoard from "@/components/case-file/CaseBoard.astro";
import CasePoster from "@/components/case-file/CasePoster.astro";
import CaseSources from "@/components/case-file/CaseSources.astro";
import CaseTimeline from "@/components/case-file/CaseTimeline.astro";
import { emmaFillipoffCase } from "@/data/cases/emmaFillipoff";
import { caseFileToTimeline } from "@/data/cases/utils";

export const prerender = true;

const title = "The Disappearance of Emma Fillipoff";
const summary =
  "An interactive case file on the 2012 disappearance of Emma Fillipoff from Victoria, British Columbia: her last day, the places at the center of it, and the questions that remain.";
const pubDate = new Date("2026-07-08");
const ogImage = "/true-crime/cases/emma-fillipoff/emma-fillipoff.jpg";

const emma = emmaFillipoffCase.people.find((p) => p.id === "emma-fillipoff")!;
const record = caseFileToTimeline(emmaFillipoffCase, { hrefFor: (event) => `#t:${event.id}` });
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead title={title} description={summary} image={ogImage} type="blogpost" datePublished={pubDate} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,100..900&family=Fragment+Mono&display=swap"
      rel="stylesheet"
    />
    <link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet" />
  </head>
  <body class="cp">
    <header class="cp-nav">
      <a href="/">dandenney.com</a>
      <a href="https://www.truecrimeresearchers.com/cases/emma-fillipoff">See the original 2019 case file</a>
    </header>

    <section class="cp-hero">
      <p class="cp-meta">
        <span>Case file</span>
        <span>Victoria, British Columbia</span>
        <span>2012–</span>
      </p>
      <h1 class="cp-title">Emma<br />Fillipoff</h1>
      <div class="cp-lede">
        <p>
          Emma Fillipoff was 26 when she was last seen in Victoria, British Columbia, on November 28, 2012. She was
          an intelligent and artistic young woman who had moved across the country by herself to live there. Some
          growing psychological issues and a series of unusual events leading up to her disappearance leave us with
          only questions.
        </p>
        <p>
          There is no crime scene. Emma was interviewed by police on the street across from the Empress Hotel, and
          less than an hour later she was gone. The board below holds the timeline of her last day and the places at
          the center of it. She is a person, like you and me, and her story deserves to be told.
        </p>
      </div>
      <p class="cp-hint" aria-hidden="true">↓</p>
    </section>

    <section class="cp-poster">
      <CasePoster
        kicker="Missing person"
        name={emma.name}
        statusLine="Last seen November 28, 2012 · Victoria, British Columbia"
        photo={emma.photo}
        photoAlt={emma.photoAlt}
        facts={emma.facts}
      >
        <p>
          Emma's family and a team of volunteers are actively looking for her. If you have any unreported
          information, please contact them through
          <a href="http://www.helpfindemmafillipoff.com">helpfindemmafillipoff.com</a> or the
          <a href="https://www.facebook.com/groups/FindEmma/">Find Emma Facebook group</a>.
        </p>
      </CasePoster>
    </section>

    <section class="cp-record">
      <header class="cp-section-head">
        <p class="cp-kicker">Chronology</p>
        <h2>The record</h2>
        <p>
          From her last day of work to the search that has never stopped. Select any entry to open it on the board
          below.
        </p>
      </header>
      <CaseTimeline groups={record} />
    </section>

    <CaseBoard caseFile={emmaFillipoffCase} />

    <section class="cp-outro">
      <div class="cp-outro-col">
        <h2>Only questions</h2>
        <p>
          Did she willingly disappear? Was she a victim of foul play? A prepaid credit card she bought that day
          turned up west of the city a week later, a man tore down one of her posters claiming she wanted to be left
          alone, and neither thread has led to her. The answers are out there somewhere.
        </p>
        <p>
          If you haven't yet heard Emma's story, the CBC documentary
          <a href="https://www.youtube.com/watch?v=b3FPSmlCmJk">Finding Emma</a> follows her mother's determined
          search, and looks at how hard it is to find any of the roughly 60,000 people reported missing in Canada
          every year.
        </p>
      </div>
      <div class="cp-outro-col">
        <h2>If you know something</h2>
        <p>
          Emma's family and a team of volunteers are actively looking for her. If you have any unreported
          information, please contact them via
          <a href="http://www.helpfindemmafillipoff.com">helpfindemmafillipoff.com</a> or their
          <a href="https://www.facebook.com/groups/FindEmma/">Facebook page</a>.
        </p>
        <h2>About this page</h2>
        <p>
          This is a rebuild of a case file from
          <a href="https://www.truecrimeresearchers.com/cases/emma-fillipoff">True Crime Researchers</a>, an older
          project of mine. The downtown locations come from the original research; the two locations tied to the
          credit card are approximate.
        </p>
      </div>
    </section>

    <section class="cp-sources">
      <header class="cp-section-head">
        <p class="cp-kicker">Citations</p>
        <h2>Sources</h2>
        <p>The reporting, research, and family resources this case file draws on.</p>
      </header>
      <CaseSources groups={emmaFillipoffCase.sources ?? []} />
    </section>

    <footer class="cp-footer">
      <a href="/">dandenney.com</a>
      <span>Made with care for Emma and her family</span>
    </footer>

    <script is:inline src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
  }

  .cp {
    margin: 0;
    background: #0b0d12;
    color: #e9ebef;
    font-family: "Archivo", system-ui, sans-serif;
  }

  .cp a {
    color: inherit;
    text-decoration-color: rgba(233, 235, 239, 0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 200ms ease;
  }

  .cp a:hover {
    text-decoration-color: #e3a94f;
  }

  .cp-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem clamp(1rem, 4vw, 3rem);
    font-family: "Fragment Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
  }

  .cp-nav a {
    text-decoration: none;
    color: #a3abba;
  }

  .cp-nav a:hover {
    color: #e9ebef;
  }

  /* ---------- Hero ---------- */

  .cp-hero {
    padding: clamp(3rem, 9vh, 6.5rem) clamp(1rem, 4vw, 3rem) clamp(2.5rem, 7vh, 5rem);
    max-width: 78rem;
    margin: 0 auto;
  }

  .cp-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.75rem;
    margin: 0 0 1.75rem;
    font-family: "Fragment Mono", ui-monospace, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #a3abba;
  }

  .cp-meta span + span {
    position: relative;
  }

  .cp-meta span + span::before {
    content: "";
    position: absolute;
    left: -1rem;
    top: 50%;
    width: 3px;
    height: 3px;
    border-radius: 999px;
    translate: 0 -50%;
    background: #666e7d;
  }

  .cp-title {
    margin: 0 0 2.25rem;
    font-size: clamp(3rem, 11vw, 8.5rem);
    font-weight: 870;
    font-variation-settings: "wdth" 118;
    line-height: 0.94;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .cp-lede {
    max-width: 62ch;
    display: grid;
    gap: 1rem;
  }

  .cp-lede p {
    margin: 0;
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.7;
    color: #c3c9d4;
  }

  .cp-hint {
    margin: 3rem 0 0;
    font-family: "Fragment Mono", ui-monospace, monospace;
    color: #666e7d;
    animation: cp-drift 2.4s ease-in-out infinite;
  }

  @keyframes cp-drift {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ---------- Poster ---------- */

  .cp-poster {
    max-width: 62rem;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem) clamp(3rem, 8vh, 5.5rem);
  }

  /* ---------- The record ---------- */

  .cp-record,
  .cp-sources {
    max-width: 62rem;
    margin: 0 auto;
    padding: clamp(3.5rem, 9vh, 6.5rem) clamp(1rem, 4vw, 3rem) clamp(1.5rem, 4vh, 3rem);
  }

  .cp-sources {
    padding-top: 0;
    padding-bottom: clamp(3.5rem, 9vh, 6.5rem);
  }

  .cp-kicker {
    margin: 0 0 0.9rem;
    font-family: "Fragment Mono", ui-monospace, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #666e7d;
  }

  .cp-section-head {
    margin-bottom: clamp(2.25rem, 5vh, 3.5rem);
  }

  .cp-section-head h2 {
    margin: 0 0 0.9rem;
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    font-weight: 820;
    font-variation-settings: "wdth" 112;
    letter-spacing: -0.015em;
    line-height: 1;
    text-transform: uppercase;
  }

  .cp-section-head p:last-child {
    margin: 0;
    max-width: 58ch;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #a3abba;
  }

  /* ---------- Outro ---------- */

  .cp-outro {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: clamp(2rem, 5vw, 4.5rem);
    max-width: 78rem;
    margin: 0 auto;
    padding: clamp(3rem, 8vh, 5.5rem) clamp(1rem, 4vw, 3rem);
  }

  .cp-outro h2 {
    margin: 0 0 1rem;
    font-size: 1.4rem;
    font-weight: 780;
    font-variation-settings: "wdth" 110;
    letter-spacing: -0.01em;
  }

  .cp-outro h2 + p + h2 {
    margin-top: 2.25rem;
  }

  .cp-outro p {
    margin: 0 0 1rem;
    max-width: 58ch;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #a3abba;
  }

  .cp-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.5rem clamp(1rem, 4vw, 3rem) 2rem;
    border-top: 1px solid rgba(233, 235, 239, 0.12);
    font-family: "Fragment Mono", ui-monospace, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    color: #666e7d;
  }

  .cp-footer a {
    color: #a3abba;
    text-decoration: none;
  }

  .cp-footer a:hover {
    color: #e9ebef;
  }

  @media (prefers-reduced-motion: reduce) {
    .cp-hint {
      animation: none;
    }
  }
</style>
