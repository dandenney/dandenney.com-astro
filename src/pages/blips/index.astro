---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import BlipSignalBand from '@/components/BlipSignalBand.astro';
import BlipLedgerRow from '@/components/BlipLedgerRow.astro';
import { SITE_TITLE } from '@/consts';
import { getCollection } from 'astro:content';
import { ClientRouter } from 'astro:transitions';

const blips = (await getCollection('blips')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const byYear = new Map<number, typeof blips>();
for (const blip of blips) {
	const year = blip.data.pubDate.getUTCFullYear();
	const group = byYear.get(year);
	if (group) {
		group.push(blip);
	} else {
		byYear.set(year, [blip]);
	}
}
const yearGroups = [...byYear.entries()];

const firstYear = blips[blips.length - 1].data.pubDate.getUTCFullYear();
const lastYear = new Date().getUTCFullYear();
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Blips | Dan Denney" description="Shorter than a blog post, longer than a tweet" />
		<ClientRouter />
	</head>
	<body class="bg-white dark:bg-slate-900">
		<main class="bg-white relative shadow-xs z-10 dark:bg-slate-900 dark:text-slate-200">
			<Header title={SITE_TITLE} />

			<section class="pt-16 pb-24 md:pt-24">
				<div class="px-8">
					<h1 class="blips-title text-slate-900 dark:text-slate-100" aria-label="Blips">
						<span aria-hidden="true">Bl<span class="blips-i">&#305;<span class="blips-i-dot"></span></span>ps</span>
					</h1>
					<p class="mt-6 max-w-2xl text-lg leading-8 text-gray-600 dark:text-slate-100">
						Shorter than a blog post, longer than a tweet. Quick reactions or things I want to remember.
						Every tick below is one of them; taller ticks ran longer.
					</p>
				</div>

				<div class="mt-14 px-8">
					<BlipSignalBand entries={blips} />
				</div>

				<div class="mt-16 border-t border-slate-200 dark:border-slate-800">
					{yearGroups.map(([year, entries]) => (
						<section class="year-group border-b border-slate-200 px-8 lg:grid lg:grid-cols-[minmax(9rem,14rem)_1fr] lg:gap-x-12 dark:border-slate-800">
							<h2 class="year-heading pt-8 lg:pt-10">
								<span class="sr-only">{year}</span>
								<span class="year-ghost font-black tracking-tighter text-slate-200 select-none lg:sticky lg:top-24 dark:text-slate-800" aria-hidden="true">
									{year}
								</span>
							</h2>
							<ol class="divide-y divide-slate-200 lg:border-l lg:border-slate-200 lg:pl-12 dark:divide-slate-800 dark:lg:border-slate-800">
								{entries.map((blip) => (
									<li>
										<BlipLedgerRow entry={blip} />
									</li>
								))}
							</ol>
						</section>
					))}
				</div>
			</section>
		</main>
		<Footer />

		<style>
			.blips-title {
				font-size: clamp(4.5rem, 15vw, 12rem);
				font-weight: 900;
				letter-spacing: -0.04em;
				line-height: 1;
			}

			.blips-i {
				position: relative;
			}

			/* The tittle of the "i" is a live radar core */
			.blips-i-dot {
				position: absolute;
				top: 0.28em;
				left: 50%;
				width: 0.135em;
				height: 0.135em;
				border-radius: 9999px;
				background: #b91c1c;
				transform: translateX(-50%);
			}

			:global(.dark) .blips-i-dot {
				background: #f87171;
			}

			.blips-i-dot::before,
			.blips-i-dot::after {
				content: '';
				position: absolute;
				inset: 0;
				border-radius: 9999px;
				border: 1.5px solid #b91c1c;
				opacity: 0;
			}

			:global(.dark) .blips-i-dot::before,
			:global(.dark) .blips-i-dot::after {
				border-color: #f87171;
			}

			@media (prefers-reduced-motion: no-preference) {
				.blips-i-dot::before {
					animation: blips-title-ping 2.8s ease-out infinite;
				}

				.blips-i-dot::after {
					animation: blips-title-ping 2.8s ease-out 1.4s infinite;
				}
			}

			@keyframes blips-title-ping {
				0% {
					transform: scale(1);
					opacity: 0.8;
				}
				70% {
					transform: scale(2.6);
					opacity: 0;
				}
				100% {
					transform: scale(2.6);
					opacity: 0;
				}
			}

			.year-ghost {
				display: block;
				font-size: clamp(3rem, 7vw, 6rem);
				line-height: 1;
			}
		</style>
	</body>
</html>
