---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import Blip from '../../layouts/Blip.astro';
import { twinUrlForId } from '@/lib/markdownTwin';

export const prerender = true;

export async function getStaticPaths() {
	const blips = await getCollection('blips');
	return blips.map((blip) => ({
		params: { slug: blip.id.replace(/\.mdx?$/, '') },
		props: blip,
	}));
}
type Props = CollectionEntry<'blips'>;

const blip = Astro.props;
const { Content } = await render(blip);
---

<Blip {...blip.data} markdownTwin={twinUrlForId('blips', blip.id)}>
	<Content />
</Blip>
