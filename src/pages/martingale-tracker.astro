---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
import { ViewTransitions } from "astro:transitions";
import {
  martingaleBets,
  startingBalance,
  hysaBenchmark,
  getStakeOut,
  getReturnAmount,
  getNetImpact,
  type MartingaleBet,
} from "../data/martingaleBets";
import { readShippState } from "@/server/shipp/state";

const currency = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
  minimumFractionDigits: 2,
  maximumFractionDigits: 2,
});

const getOwner = (bet: MartingaleBet) => bet.owner ?? "Dan";

const orderedBets = [...martingaleBets]
  .filter((bet) => getOwner(bet) === "Dan")
  .sort((a, b) => a.date.localeCompare(b.date) || a.id - b.id);

const gardenOrderedBets = [...martingaleBets]
  .filter((bet) => getOwner(bet) === "GardenOf")
  .sort((a, b) => a.date.localeCompare(b.date) || a.id - b.id);

const totalWagers = orderedBets.length;
const settledBets = orderedBets.filter((bet) => bet.result !== "pending");
const pendingBets = orderedBets.filter((bet) => bet.result === "pending").length;
const wins = settledBets.filter((bet) => bet.result === "win").length;
const totalReturns = orderedBets.reduce((sum, bet) => sum + getReturnAmount(bet), 0);
const totalStaked = orderedBets.reduce((sum, bet) => sum + getStakeOut(bet), 0);
const netPL = Number((totalReturns - totalStaked).toFixed(2));
const currentBalance = Number((startingBalance + netPL).toFixed(2));
const winRate = settledBets.length ? (wins / settledBets.length) * 100 : 0;

const withRunningBalance = orderedBets.map((bet, index) => ({
  ...bet,
  stakeOut: getStakeOut(bet),
  returnAmount: getReturnAmount(bet),
  netImpact: getNetImpact(bet),
  runningBalance: Number(
    (
      startingBalance +
      orderedBets
        .slice(0, index + 1)
        .reduce((sum, current) => sum + getNetImpact(current), 0)
    ).toFixed(2),
  ),
}));

type SeriesStatus = "In Progress" | "Won" | "Full Fail";

interface SeriesSummary {
  seriesId: string;
  betsCount: number;
  lossesCount: number;
  status: SeriesStatus;
  netImpact: number;
}

const seriesMap = new Map<string, MartingaleBet[]>();
for (const bet of orderedBets) {
  const existing = seriesMap.get(bet.seriesId) ?? [];
  existing.push(bet);
  seriesMap.set(bet.seriesId, existing);
}

const seriesSummaries: SeriesSummary[] = Array.from(seriesMap.entries()).map(
  ([seriesId, bets]) => {
    const lossesCount = bets.filter((bet) => bet.result === "loss").length;
    const hasWin = bets.some((bet) => bet.result === "win");
    const status: SeriesStatus = hasWin
      ? "Won"
      : lossesCount >= 3
        ? "Full Fail"
        : "In Progress";
    return {
      seriesId,
      betsCount: bets.length,
      lossesCount,
      status,
      netImpact: Number(bets.reduce((sum, bet) => sum + getNetImpact(bet), 0).toFixed(2)),
    };
  },
);

const formatDate = (dateString: MartingaleBet["date"]) =>
  new Date(`${dateString}T00:00:00`).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });

const firstBetDate = orderedBets[0]?.date;
const benchmarkAsOfDate = hysaBenchmark.asOfDate ?? new Date().toISOString().slice(0, 10);

let hysaCurrentValue = hysaBenchmark.principal;
if (firstBetDate) {
  const startDateMs = new Date(`${firstBetDate}T00:00:00`).getTime();
  const asOfDateMs = new Date(`${benchmarkAsOfDate}T00:00:00`).getTime();
  const elapsedMs = Math.max(asOfDateMs - startDateMs, 0);
  const elapsedYears = elapsedMs / (1000 * 60 * 60 * 24 * 365.25);
  hysaCurrentValue =
    hysaBenchmark.principal * Math.pow(1 + hysaBenchmark.annualYield, elapsedYears);
}

const strategyVsHysaDelta = currentBalance - hysaCurrentValue;

const shippState = await readShippState();
const pendingBetCheckpoints = orderedBets
  .filter((bet) => bet.result === "pending")
  .map((bet) => {
    const packets = shippState.checkpoints?.byBetId?.[String(bet.id)] ?? [];
    const latestPacket = [...packets].sort((a, b) => b.generatedAt.localeCompare(a.generatedAt))[0] ?? null;
    return { bet, latestPacket };
  });

const gardenSettledBets = gardenOrderedBets.filter((bet) => bet.result !== "pending");
const gardenPendingBets = gardenOrderedBets.filter((bet) => bet.result === "pending").length;
const gardenWins = gardenSettledBets.filter((bet) => bet.result === "win").length;
const gardenTotalReturns = gardenOrderedBets.reduce((sum, bet) => sum + getReturnAmount(bet), 0);
const gardenTotalStaked = gardenOrderedBets.reduce((sum, bet) => sum + getStakeOut(bet), 0);
const gardenNetPL = Number((gardenTotalReturns - gardenTotalStaked).toFixed(2));
const gardenCurrentBalance = Number((startingBalance + gardenNetPL).toFixed(2));
const gardenWinRate = gardenSettledBets.length ? (gardenWins / gardenSettledBets.length) * 100 : 0;

const gardenWithRunningBalance = gardenOrderedBets.map((bet, index) => ({
  ...bet,
  stakeOut: getStakeOut(bet),
  returnAmount: getReturnAmount(bet),
  netImpact: getNetImpact(bet),
  runningBalance: Number(
    (
      startingBalance +
      gardenOrderedBets
        .slice(0, index + 1)
        .reduce((sum, current) => sum + getNetImpact(current), 0)
    ).toFixed(2),
  ),
}));

const gardenSeriesMap = new Map<string, MartingaleBet[]>();
for (const bet of gardenOrderedBets) {
  const existing = gardenSeriesMap.get(bet.seriesId) ?? [];
  existing.push(bet);
  gardenSeriesMap.set(bet.seriesId, existing);
}

const gardenSeriesSummaries: SeriesSummary[] = Array.from(gardenSeriesMap.entries()).map(
  ([seriesId, bets]) => {
    const lossesCount = bets.filter((bet) => bet.result === "loss").length;
    const hasWin = bets.some((bet) => bet.result === "win");
    const status: SeriesStatus = hasWin ? "Won" : lossesCount >= 3 ? "Full Fail" : "In Progress";
    return {
      seriesId,
      betsCount: bets.length,
      lossesCount,
      status,
      netImpact: Number(bets.reduce((sum, bet) => sum + getNetImpact(bet), 0).toFixed(2)),
    };
  },
);

const gardenPendingBetCheckpoints = gardenOrderedBets
  .filter((bet) => bet.result === "pending")
  .map((bet) => {
    const packets = shippState.checkpoints?.byBetId?.[String(bet.id)] ?? [];
    const latestPacket = [...packets].sort((a, b) => b.generatedAt.localeCompare(a.generatedAt))[0] ?? null;
    return { bet, latestPacket };
  });

// Hero active bets with checkpoint data merged in
const danActiveBets = orderedBets
  .filter((bet) => bet.result === "pending")
  .map((bet) => ({
    ...bet,
    latestPacket: pendingBetCheckpoints.find((c) => c.bet.id === bet.id)?.latestPacket ?? null,
  }));

const gardenActiveBetsList = gardenOrderedBets
  .filter((bet) => bet.result === "pending")
  .map((bet) => ({
    ...bet,
    latestPacket: gardenPendingBetCheckpoints.find((c) => c.bet.id === bet.id)?.latestPacket ?? null,
  }));

// Descending order for tables
const withRunningBalanceDesc = [...withRunningBalance].reverse();
const gardenWithRunningBalanceDesc = [...gardenWithRunningBalance].reverse();
const seriesSummariesDesc = [...seriesSummaries].reverse();
const gardenSeriesSummariesDesc = [...gardenSeriesSummaries].reverse();

---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead
      title="Martingale Bet Tracker | Dan Denney"
      description="A clean snapshot of a Martingale betting streak with summary metrics and a bet-by-bet ledger."
    />
    <ViewTransitions />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen overflow-x-hidden">
    <main class="relative z-10 bg-slate-950">

    <!-- ═══════════════════════════════════════════════════════
         HERO — full-bleed image with active bet objectives
    ═══════════════════════════════════════════════════════ -->
    <section class="relative w-full min-h-[80vh] flex flex-col overflow-hidden">
      <!-- Background image -->
      <img
        src="/Gemini_Generated_Image_1oadbf1oadbf1oad.webp"
        class="absolute inset-0 w-full h-full object-cover object-center"
        alt=""
        loading="eager"
      />
      <!-- Dark gradient overlays -->
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950/40 via-slate-950/65 to-slate-950"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950/80 via-transparent to-slate-950/50"></div>
      <!-- Tactical grid -->
      <div class="absolute inset-0 [background-image:linear-gradient(rgba(6,182,212,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(6,182,212,0.04)_1px,transparent_1px)] [background-size:48px_48px]"></div>
      <!-- Corner accent marks -->
      <div class="absolute top-0 left-0 w-20 h-20 border-t-2 border-l-2 border-cyan-500/50"></div>
      <div class="absolute top-0 right-0 w-20 h-20 border-t-2 border-r-2 border-cyan-500/50"></div>
      <div class="absolute bottom-0 left-0 w-12 h-12 border-b border-l border-cyan-500/20"></div>
      <div class="absolute bottom-0 right-0 w-12 h-12 border-b border-r border-cyan-500/20"></div>

      <!-- Nav -->
      <div class="relative z-10 border-b border-white/5 backdrop-blur-sm">
        <Header title={SITE_TITLE} />
      </div>

      <!-- Hero body -->
      <div class="relative z-10 flex-1 flex flex-col lg:flex-row lg:items-end gap-8 lg:gap-12 px-6 lg:px-12 xl:px-16 pb-12 pt-8">

        <!-- Left column: identity -->
        <div class="flex flex-col justify-end lg:w-[38%] flex-shrink-0">
          <!-- HUD label -->
          <div class="flex items-center gap-3 mb-4">
            <div class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse shadow-[0_0_8px_rgba(34,211,238,0.8)]"></div>
            <p class="font-mono text-[10px] uppercase tracking-[0.5em] text-cyan-400/80">Martingale Command Center · Live</p>
          </div>

          <h1 class="text-6xl lg:text-8xl font-black uppercase tracking-tighter text-white leading-none drop-shadow-2xl">
            Bet<br />Tracker
          </h1>
        </div>

        <!-- Right column: featured active objective card -->
        <div class="flex-1">
          <div class="relative border border-slate-700/40 bg-slate-950/75 backdrop-blur-md overflow-hidden">
            <!-- Dual-owner accent line -->
            <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-cyan-500 via-violet-400 to-violet-500"></div>

            <!-- Header -->
            <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b border-slate-700/40">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse shadow-[0_0_8px_rgba(34,211,238,0.8)]"></div>
                <p class="font-mono text-[9px] uppercase tracking-[0.45em] text-cyan-400/80">Active Objective</p>
              </div>
              {danActiveBets.length > 0 ? (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-amber-500/15 border border-amber-500/35 text-amber-300 font-mono text-[8px] uppercase tracking-[0.2em]">
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
                  Pending
                </span>
              ) : (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-slate-700/50 border border-slate-600/40 text-slate-400 font-mono text-[8px] uppercase tracking-[0.2em]">
                  Standby
                </span>
              )}
            </div>

            <!-- Featured pick name -->
            <div class="px-6 py-6">
              {danActiveBets.length > 0 ? (
                <p class="text-3xl lg:text-4xl xl:text-5xl font-black text-white uppercase tracking-tight leading-none">{danActiveBets[0].pick}</p>
              ) : (
                <p class="text-3xl lg:text-4xl xl:text-5xl font-black text-slate-600 uppercase tracking-tight leading-none">No Active Bet</p>
              )}
            </div>

            <!-- Per-owner metadata: Dan | GardenOf -->
            <div class="grid grid-cols-2 divide-x divide-slate-700/40 border-t border-slate-700/40">

              <!-- Dan -->
              <div class="px-6 py-4">
                <p class="font-mono text-[9px] uppercase tracking-[0.4em] text-cyan-400 mb-3">// Dan</p>
                {danActiveBets.length > 0 ? (
                  danActiveBets.map((bet) => (
                    <div>
                      <div class="grid grid-cols-3 gap-3">
                        <div>
                          <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Series</p>
                          <p class="font-mono text-xl font-bold text-cyan-300">{bet.seriesId}</p>
                        </div>
                        <div>
                          <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Line</p>
                          <p class="font-mono text-xl font-bold text-white">{bet.line}</p>
                        </div>
                        <div>
                          <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Stake</p>
                          <p class="font-mono text-xl font-bold text-rose-300">{currency.format(getStakeOut(bet))}</p>
                        </div>
                      </div>
                      {bet.latestPacket ? (
                        <div class="mt-3 border-t border-slate-700/40 pt-3">
                          <span class="font-mono text-[7px] uppercase tracking-wider text-slate-400">{bet.latestPacket.checkpoint} · {bet.latestPacket.status}</span>
                          <div class="flex items-baseline gap-2 mt-1">
                            <p class:list={["font-mono text-sm font-bold uppercase tracking-wide", bet.latestPacket.recommendation === "PLAY" || bet.latestPacket.recommendation === "BET" ? "text-emerald-400" : "text-rose-400"]}>{bet.latestPacket.recommendation}</p>
                            <p class="font-mono text-[9px] text-slate-400">{bet.latestPacket.confidence}% confidence</p>
                          </div>
                          <p class="mt-1 font-mono text-[9px] text-slate-400 leading-relaxed line-clamp-2">{bet.latestPacket.reason}</p>
                        </div>
                      ) : (
                        <div class="mt-3 border-t border-slate-700/40 pt-3">
                          <p class="font-mono text-[8px] uppercase tracking-wider text-amber-400">No Checkpoint Yet</p>
                          <p class="font-mono text-[8px] text-slate-500 mt-0.5">Fallback: no bet until T-120 captured</p>
                        </div>
                      )}
                    </div>
                  ))
                ) : (
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Rec. Stake</p>
                      <p class="font-mono text-xl font-bold text-cyan-300">$30.00</p>
                    </div>
                    <div>
                      <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Status</p>
                      <p class="font-mono text-xl font-bold text-white">New Series</p>
                    </div>
                  </div>
                )}
              </div>

              <!-- GardenOf -->
              <div class="px-6 py-4">
                <p class="font-mono text-[9px] uppercase tracking-[0.4em] text-violet-400 mb-3">// GardenOf</p>
                {gardenActiveBetsList.length > 0 ? (
                  gardenActiveBetsList.map((bet) => (
                    <div>
                      <div class="grid grid-cols-3 gap-3">
                        <div>
                          <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Series</p>
                          <p class="font-mono text-xl font-bold text-violet-300">{bet.seriesId}</p>
                        </div>
                        <div>
                          <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Line</p>
                          <p class="font-mono text-xl font-bold text-white">{bet.line}</p>
                        </div>
                        <div>
                          <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Stake</p>
                          <p class="font-mono text-xl font-bold text-rose-300">{currency.format(getStakeOut(bet))}</p>
                        </div>
                      </div>
                      {bet.latestPacket ? (
                        <div class="mt-3 border-t border-slate-700/40 pt-3">
                          <span class="font-mono text-[7px] uppercase tracking-wider text-slate-400">{bet.latestPacket.checkpoint} · {bet.latestPacket.status}</span>
                          <div class="flex items-baseline gap-2 mt-1">
                            <p class:list={["font-mono text-base font-bold uppercase tracking-wide", bet.latestPacket.recommendation === "PLAY" || bet.latestPacket.recommendation === "BET" ? "text-emerald-400" : "text-rose-400"]}>{bet.latestPacket.recommendation}</p>
                            <p class="font-mono text-[9px] text-slate-400">{bet.latestPacket.confidence}% confidence</p>
                          </div>
                          <p class="mt-1 font-mono text-[9px] text-slate-400 leading-relaxed line-clamp-2">{bet.latestPacket.reason}</p>
                        </div>
                      ) : (
                        <div class="mt-3 border-t border-slate-700/40 pt-3">
                          <p class="font-mono text-[8px] uppercase tracking-wider text-amber-400">No Checkpoint Yet</p>
                          <p class="font-mono text-[8px] text-slate-500 mt-0.5">Fallback: no bet until T-120 captured</p>
                        </div>
                      )}
                    </div>
                  ))
                ) : (
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Rec. Stake</p>
                      <p class="font-mono text-xl font-bold text-violet-300">$30.00</p>
                    </div>
                    <div>
                      <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-500 mb-1">Status</p>
                      <p class="font-mono text-xl font-bold text-white">New Series</p>
                    </div>
                  </div>
                )}
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         STATS — performance metrics for both accounts
    ═══════════════════════════════════════════════════════ -->
    <section class="w-full bg-slate-950 px-6 lg:px-12 xl:px-16 py-16">
      <div class="flex items-center gap-4 mb-10">
        <div class="h-px w-10 bg-cyan-500/60"></div>
        <p class="font-mono text-[10px] uppercase tracking-[0.5em] text-slate-500">// Performance Metrics</p>
        <div class="h-px flex-1 bg-slate-800/60"></div>
      </div>

      <div class="grid gap-10 lg:grid-cols-2">

        <!-- Dan stats -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-1 h-7 bg-cyan-400 shadow-[0_0_10px_rgba(34,211,238,0.5)]"></div>
            <p class="font-mono text-xs uppercase tracking-[0.4em] text-cyan-300 font-bold">Dan</p>
            <p class="font-mono text-[9px] text-slate-400 uppercase tracking-wider">· {totalWagers} bets · {settledBets.length} settled · {pendingBets} pending</p>
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden col-span-2 sm:col-span-1">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-slate-600/60 to-transparent"></div>
              <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-400 mb-2">Starting Balance</p>
              <p class="font-mono text-2xl font-bold text-white">{currency.format(startingBalance)}</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-cyan-500/40 to-transparent"></div>
              <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-400 mb-2">Current Balance</p>
              <p class:list={["font-mono text-2xl font-bold", currentBalance >= startingBalance ? "text-emerald-400" : "text-rose-400"]}>{currency.format(currentBalance)}</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-cyan-500/40 to-transparent"></div>
              <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-400 mb-2">Net P/L</p>
              <p class:list={["font-mono text-2xl font-bold", netPL >= 0 ? "text-emerald-400" : "text-rose-400"]}>{netPL >= 0 ? "+" : ""}{currency.format(netPL)}</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-slate-600/60 to-transparent"></div>
              <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-400 mb-2">Win Rate</p>
              <p class="font-mono text-2xl font-bold text-white">{settledBets.length ? `${winRate.toFixed(0)}%` : "—"}</p>
            </div>
            <div class="relative border border-cyan-500/20 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-cyan-500/40 to-transparent"></div>
              <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-400 mb-2">HYSA Benchmark</p>
              <p class="font-mono text-2xl font-bold text-cyan-300">{currency.format(hysaCurrentValue)}</p>
              <p class="font-mono text-[8px] text-slate-600 mt-1 uppercase">4.2% APY · Sim only</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-slate-600/60 to-transparent"></div>
              <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-400 mb-2">vs HYSA Delta</p>
              <p class:list={["font-mono text-2xl font-bold", strategyVsHysaDelta >= 0 ? "text-emerald-400" : "text-rose-400"]}>{strategyVsHysaDelta >= 0 ? "+" : ""}{currency.format(strategyVsHysaDelta)}</p>
            </div>
          </div>
        </div>

        <!-- GardenOf stats -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-1 h-7 bg-violet-400 shadow-[0_0_10px_rgba(167,139,250,0.5)]"></div>
            <p class="font-mono text-xs uppercase tracking-[0.4em] text-violet-300 font-bold">GardenOf</p>
            <p class="font-mono text-[9px] text-slate-400 uppercase tracking-wider">· {gardenOrderedBets.length} bets · {gardenSettledBets.length} settled · {gardenPendingBets} pending</p>
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden col-span-2 sm:col-span-1">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-slate-600/60 to-transparent"></div>
              <p class="font-mono text-[8px] uppercase tracking-[0.2em] text-slate-400 mb-2">Starting Balance</p>
              <p class="font-mono text-2xl font-bold text-white">{currency.format(startingBalance)}</p>
            </div>
