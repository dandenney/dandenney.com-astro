---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import { ClientRouter } from 'astro:transitions';

const experiments = (await getCollection('artificially-intelligent')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Artificially Intelligent | Dan Denney" description="Experiments at the intersection of AI and front-end development" />
    <ClientRouter />
  </head>
  <body class="bg-white dark:bg-slate-900">
    <main class="bg-white relative shadow-xs z-10 dark:bg-slate-900 dark:text-slate-200">
      <Header title={SITE_TITLE} />

      <section class="pt-16 pb-24">
        <div class="px-8">
          <p class="text-xs font-mono uppercase tracking-widest text-gray-400 dark:text-slate-500">
            <span class="whitespace-nowrap">[&nbsp;{experiments.length} experiment{experiments.length !== 1 ? 's' : ''}&nbsp;]</span>
          </p>
          <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-slate-100">Artificially Intelligent</h1>
          <p class="mt-4 max-w-2xl text-lg leading-8 text-gray-600 dark:text-slate-100">
            Experiments at the intersection of AI and front-end development.
          </p>
        </div>

        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 border-y border-gray-200 dark:border-slate-700">
          {experiments.map((experiment, i) => {
            const wideIndices = new Set([0, 5, 11, 18, 24, 31, 37, 44]);
            const isWide = wideIndices.has(i);
            const dateStr = experiment.data.pubDate.toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric',
            });
            return (
              <a
                href={`/artificially-intelligent/${experiment.id.replace(/\.mdx?$/, '')}/`}
                class:list={[
                  "group relative flex items-center justify-between no-underline p-6 md:p-8 bg-slate-50 dark:bg-slate-800",
                  isWide ? "md:col-span-2" : "",
                ]}
              >
                <div class="min-w-0 flex-1 pr-4 md:pr-6">
                  <p class="text-xs font-mono uppercase tracking-widest text-gray-400 dark:text-slate-500">
                    <span class="whitespace-nowrap">[&nbsp;{dateStr}&nbsp;]</span>
                  </p>
                  <h3 class="mt-3 text-lg font-semibold leading-snug text-red-700 transition-colors group-hover:text-red-800 dark:text-red-400 dark:group-hover:text-red-300">
                    {experiment.data.title}
                  </h3>
                  {experiment.data.summary && (
                    <p class="mt-3 text-sm leading-relaxed text-gray-500 dark:text-slate-400">
                      {experiment.data.summary}
                    </p>
                  )}
                  {experiment.data.tags && experiment.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {experiment.data.tags.map((tag: string) => (
                        <span class="text-xs font-mono uppercase tracking-wider text-gray-400 dark:text-slate-500 bg-gray-100 dark:bg-slate-700 px-2 py-0.5 rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <svg class="shrink-0 h-8 w-8 text-gray-300 dark:text-slate-600 transition-colors group-hover:text-red-300 dark:group-hover:text-red-700" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
              </a>
            );
          })}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
