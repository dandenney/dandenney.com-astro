---
export const prerender = true;
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

type YilMeta = { date: string; headline: string; summary: string; accent?: string };
const pages = import.meta.glob<{ yilMeta: YilMeta }>('./*.astro', { eager: true });

const entries = Object.entries(pages)
  .filter(([path]) => !path.endsWith('index.astro'))
  .map(([path, mod]) => ({
    url: path.replace('./', '/yil/').replace('.astro', ''),
    ...mod.yilMeta,
  }))
  .sort((a, b) => b.date.localeCompare(a.date));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Yesterday I Learned | Dan Denney"
      description="Daily captures turned into designed pages — AI engineering, agents, front-end development, and learning in public. A new entry every weekday."
    />
    <ClientRouter />
    <style>
      @keyframes fade-up {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .entry {
        opacity: 0;
        animation: fade-up 0.5s ease forwards;
      }
    </style>
  </head>
  <body class="bg-[#090909]">
    <main class="relative z-10 bg-[#090909] shadow-xs">
      <Header />

      <!-- Hero -->
      <section class="border-b border-[#1a1a1a]">
        <div class="mx-auto max-w-4xl px-6 pb-16 pt-20">
          <p
            class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#444]"
          >[ YIL ]</p>
          <h1
            class="mt-4 text-[2.5rem] font-semibold leading-[1.05] tracking-tight text-white sm:text-[3.5rem]"
          >Yesterday I Learned</h1>
          <p class="mt-5 max-w-lg text-[17px] leading-relaxed text-[#666]">
            Daily captures from Obsidian turned into designed pages. Each day gets its own visual personality — typography, color, layout all chosen for the content.
          </p>
          <div class="mt-8 flex items-center gap-4">
            <span class="font-mono text-xs text-[#333]">{entries.length} entries</span>
            <div class="h-px flex-1 bg-[#1a1a1a]"></div>
          </div>
        </div>
      </section>

      <!-- Entries -->
      <section class="mx-auto max-w-4xl px-6 pb-24 pt-4">
        <ol class="mt-4">
          {entries.map((entry, i) => {
            const accent = entry.accent ?? '#666666';
            return (
              <li
                class="entry border-b border-[#141414]"
                style={`animation-delay: ${i * 60}ms;`}
              >
                <a
                  href={entry.url}
                  class="group relative flex items-start gap-6 py-8 transition-colors hover:bg-[#0f0f0f]"
                >
                  <!-- Accent strip -->
                  <div
                    class="mt-1.5 h-5 w-1 shrink-0 rounded-full transition-all duration-300 group-hover:h-full group-hover:rounded-none"
                    style={`background: ${accent};`}
                  ></div>

                  <!-- Content -->
                  <div class="min-w-0 flex-1 pr-4">
                    <p
                      class="font-mono text-[10px] uppercase tracking-[0.2em] transition-colors"
                      style={`color: ${accent};`}
                    >{entry.date}</p>
                    <h2 class="mt-1.5 text-[1.25rem] font-semibold leading-tight text-white transition-colors group-hover:text-white">
                      {entry.headline}
                    </h2>
                    {entry.summary && (
                      <p class="mt-2 text-sm leading-relaxed text-[#555] transition-colors group-hover:text-[#666]">
                        {entry.summary}
                      </p>
                    )}
                  </div>

                  <!-- Arrow -->
                  <div
                    class="mt-2 shrink-0 font-mono text-xs opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0 translate-x-[-4px]"
                    style={`color: ${accent};`}
                    aria-hidden="true"
                  >→</div>
                </a>
              </li>
            );
          })}
        </ol>
      </section>
    </main>
    <Footer />
  </body>
</html>
