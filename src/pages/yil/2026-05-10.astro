---
export const prerender = true;
export const yilMeta = {
  date: '2026-05-10',
  headline: 'Give It the Destination, Not the Directions',
  summary:
    'Four tools and a single idea: when you hand an agent the outcome instead of the steps, you get judgment instead of a script — and that difference compounds.',
  accent: '#0066cc',
  designRef: { name: 'Apple', url: 'https://www.apple.com' },
};

import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import YilSeriesNav from '@/components/YilSeriesNav.astro';
---

<!doctype html>
<html lang="en" style="color-scheme: light;">
  <head>
    <BaseHead
      title="Yesterday I Learned: Give It the Destination, Not the Directions | Dan Denney"
      description="Four tools and a single idea: when you hand an agent the outcome instead of the steps, you get judgment instead of a script — and that difference compounds."
      type="blogpost"
      datePublished={new Date(yilMeta.date)}
    />
    <style>
      @keyframes reveal {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @media (prefers-reduced-motion: reduce) {
        @keyframes reveal {
          from { opacity: 0; }
          to   { opacity: 1; }
        }
      }
      .yil-section {
        opacity: 0;
      }
      .yil-section.is-visible {
        animation: reveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      .yil-hero {
        animation: reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
    </style>
    <noscript><style>.yil-section { opacity: 1 !important; }</style></noscript>
  </head>
  <body class="bg-white">
    <main class="relative z-10 bg-white shadow-xs">
      <Header />

      <!-- Hero: centered-editorial — white canvas, centered column, date + h1 stacked -->
      <section class="yil-hero bg-white">
        <div class="mx-auto max-w-2xl px-6 pb-20 pt-24">
          <p
            class="text-[10px] uppercase tracking-[0.25em] text-[#6e6e73]"
            style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 400;"
          >
            2026-05-10 — Yesterday I Learned
          </p>
          <div class="mt-4 h-px bg-[#e0e0e0]"></div>
          <h1
            class="mt-6 text-[#1d1d1f]"
            style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-size: clamp(2.125rem, 4vw, 3.5rem); font-weight: 600; line-height: 1.07; letter-spacing: -0.28px;"
          >
            Give It the Destination, Not the Directions
          </h1>
          <p
            class="mt-5 text-[17px] leading-[1.47] text-[#1d1d1f]"
            style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 400;"
          >
            Four tools and a single idea: when you hand an agent the outcome instead of the steps,
            you get judgment instead of a script — and that difference compounds.
          </p>
        </div>
      </section>

      <!-- Quote: standalone-dark-band — near-black #272729 -->
      <section class="yil-section" style="background: #272729;">
        <div class="relative mx-auto max-w-5xl overflow-hidden px-6 py-20">
          <div
            aria-hidden="true"
            class="pointer-events-none absolute -left-2 -top-8 select-none text-[16rem] leading-none"
            style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 600; color: rgba(255,255,255,0.05);"
          >
            "
          </div>
          <blockquote class="relative max-w-3xl">
            <p
              class="text-2xl text-white sm:text-3xl"
              style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 400; line-height: 1.4; letter-spacing: -0.01em;"
            >
              Turn-by-turn directions tell every move. Telling the destination trusts the GPS. One
              approach takes over; the other lets the tool do its job.
            </p>
            <footer class="mt-6 flex items-center gap-3">
              <div class="h-px w-8" style="background: rgba(41,151,255,0.6);"></div>
              <cite
                class="not-italic text-sm"
                style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 400; color: #cccccc;"
              >
                Yar Newsletter — prompt-framing analogy
              </cite>
            </footer>
          </blockquote>
        </div>
      </section>

      <!-- Prompting: pill-h2-bar, split layout, parchment surface -->
      <section class="yil-section bg-[#f5f5f7]">
        <div class="mx-auto max-w-5xl px-6 py-20">
          <!-- pill-h2-bar -->
          <div
            class="inline-flex items-center rounded-full border border-[#0066cc]/20 bg-[#0066cc]/10 px-3 py-1"
          >
            <span
              class="text-[10px] uppercase tracking-[0.15em] text-[#0066cc]"
              style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 600;"
              >Prompting</span
            >
          </div>
          <h2
            class="mt-3 text-[#1d1d1f]"
            style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 600; line-height: 1.1; letter-spacing: -0.28px;"
          >
            Two Prompts, Same Task
          </h2>

          <!-- Split: two code-window cards -->
          <div class="mt-10 grid gap-8 lg:grid-cols-2">
            <!-- Left: process-first prompt -->
            <div>
              <div
                class="rounded-[18px] p-6"
                style="background: #1c1c1e;"
              >
                <p
                  class="mb-4 text-[10px] uppercase tracking-[0.15em]"
                  style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 600; color: #6e6e73;"
                >
                  Process-first
                </p>
                <pre
                  class="overflow-x-auto text-[14px] leading-[1.6]"
                  style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 400; color: #ffffff; white-space: pre-wrap; word-break: break-word;"
                ><span style="color: #6e6e73;">1.</span> First check history.
<span style="color: #6e6e73;">2.</span> Second look up policy.
<span style="color: #6e6e73;">3.</span> Third compare.
<span style="color: #6e6e73;">4.</span> Fourth write reply.</pre>
              </div>
              <p
                class="mt-3 text-sm text-[#6e6e73]"
                style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 400;"
              >
                Scripted. Brittle. Grows with every edge case.
              </p>
            </div>

            <!-- Right: outcome-first prompt -->
            <div>
              <div
                class="rounded-[18px] p-6"
                style="background: #1c1c1e;"
              >
                <p
                  class="mb-4 text-[10px] uppercase tracking-[0.15em]"
                  style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 600; color: #2997ff;"
                >
                  Outcome-first
                </p>
                <pre
                  class="overflow-x-auto text-[14px] leading-[1.6]"
                  style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 400; color: #ffffff; white-space: pre-wrap; word-break: break-word;"
                >Resolve the issue end-to-end.
<span style="color: #6e6e73;">Success means</span> a decision is
made from available data,
allowed actions are completed,
and the final answer includes
X, Y, Z.
<span style="color: #6e6e73;">If evidence is missing,</span>
ask for it.</pre>
              </div>
              <p
                class="mt-3 text-sm text-[#6e6e73]"
                style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 400;"
              >
                Shorter. Maintainable. Compounds as the library grows.
              </p>
            </div>
          </div>

          <p
            class="mt-8 max-w-2xl text-[17px] leading-[1.47] text-[#6e6e73]"
            style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 400;"
          >
            The outcome-first version gives the model more room to reason. As a prompt library
            grows, that maintainability compounds — fewer updates when adjacent steps change,
            because the outcome stays stable even when the path shifts.
          </p>
        </div>
      </section>

      <!-- Browser Agents: eyebrow-h2, prose layout, white surface -->
      <section class="yil-section bg-white">
        <div class="mx-auto max-w-5xl px-6 py-20">
          <p
            class="text-[10px] uppercase tracking-[0.25em] text-[#0066cc]"
            style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 600;"
          >Browser</p>
          <h2
            class="mt-2 text-[#1d1d1f]"
            style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 600; line-height: 1.1; letter-spacing: -0.28px;"
          >
            The Browser as a Coworker
          </h2>

          <div class="mt-8 max-w-2xl space-y-5">
            <p
              class="text-[17px] leading-[1.47] text-[#1d1d1f]"
              style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 400;"
            >
              Claude Code can connect directly to a browser — not just to check rendered output
              during implementation, but to run repeatable business-flow validation the way a QA
              coworker would. The Prompt Warrior tutorial walks through three ways to wire this up.
            </p>
            <p
              class="text-[17px] leading-[1.47] text-[#1d1d1f]"
              style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 400;"
            >
              The immediate use case I want to try: automated validation of promo item entries and
              market submission flows at DataCamp. These are repetitive, multi-step browser
              interactions — exactly the kind of work where a browser-connected agent can replace
              manual spot-checking and catch regressions before they ship.
            </p>
          </div>

          <div class="mt-8">
            <a
              href="https://www.thepromptwarrior.com/p/3-ways-to-make-claude-code-use-your-browser-full-tutorial"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center rounded-full bg-[#0066cc] px-5 py-2.5 text-[14px] font-normal text-white transition-transform active:scale-95"
              style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;"
            >
              Read the tutorial →
            </a>
          </div>
        </div>
      </section>

      <!-- Markdown Bridge: bare-h2, feature layout, parchment surface -->
      <section class="yil-section bg-[#f5f5f7]">
        <div class="mx-auto max-w-5xl px-6 py-20 text-center">
          <h2
            class="text-[#1d1d1f]"
            style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 600; line-height: 1.07; letter-spacing: -0.28px;"
          >
            The Web, Extracted
          </h2>

          <p
            class="mx-auto mt-8 max-w-xl text-[#1d1d1f]"
            style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-size: 1.25rem; font-weight: 400; line-height: 1.5;"
