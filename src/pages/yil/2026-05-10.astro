                style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 600;"
              >
                Branding
              </p>
              <h3
                class="mt-2 text-base text-white"
                style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 600; line-height: 1.2;"
              >
                Animated Title Cards
              </h3>
              <p
                class="mt-2 text-sm leading-relaxed"
                style="color: #cccccc; font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 400;"
              >
                Generate branded, motion-ready title sequences for any video project.
              </p>
            </div>

            <div
              class="rounded-[18px] p-6"
              style="background: #1c1c1e; border: 1px solid rgba(255,255,255,0.08);"
            >
              <p
                class="text-[10px] uppercase tracking-[0.15em] text-[#2997ff]"
                style="font-family: ui-monospace, SFMono-Regular, Menlo, 'Courier New', monospace; font-weight: 600;"
              >
                Social
              </p>
              <h3
                class="mt-2 text-base text-white"
                style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; font-weight: 600; line-height: 1.2;"
