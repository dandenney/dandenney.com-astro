---
export const prerender = true;
export const yilMeta = {
  date: '2026-05-17',
  headline: 'Steer While It Runs',
  summary:
    'The agent workflow is shifting from prompt-and-wait to live direction: redirect mid-run, queue jobs, and move repeated loops into durable memory.',
  accent: '#a78bfa',
};

import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import YilSeriesNav from '@/components/YilSeriesNav.astro';

const commands = [
  { cmd: '/new', label: 'fresh session', color: 'text-blue-400', ring: 'border-blue-400/30 bg-blue-400/10' },
  { cmd: '/steer', label: 'redirect without stopping', color: 'text-violet-400', ring: 'border-violet-400/40 bg-violet-400/10' },
  { cmd: '/queue', label: 'stack the next task', color: 'text-emerald-400', ring: 'border-emerald-400/30 bg-emerald-400/10' },
  { cmd: '/goal', label: 'unlock long loops', color: 'text-emerald-400', ring: 'border-emerald-400/30 bg-emerald-400/10' },
  { cmd: '/background', label: 'run side tasks', color: 'text-emerald-400', ring: 'border-emerald-400/30 bg-emerald-400/10' },
  { cmd: '/compress', label: 'save tokens', color: 'text-amber-300', ring: 'border-amber-300/30 bg-amber-300/10' },
];

const references = [
  {
    label: 'CHRONICLE',
    title: 'Pasted X post from gdb about Codex Chronicle',
    url: 'https://x.com/gdb/status/2055769256399114677?s=20',
    accent: '#60a5fa',
  },
  {
    label: 'HERMES',
    title: 'Pasted X post from AntoineRSX about Hermes slash-command workflow',
    url: 'https://x.com/AntoineRSX/status/2055813424882291158',
    accent: '#a78bfa',
  },
];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead
      title="Yesterday I Learned: Steer While It Runs | Dan Denney"
      description={yilMeta.summary}
      type="blogpost"
      datePublished={new Date(yilMeta.date)}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --font-display: "Space Grotesk", Inter, system-ui, -apple-system, sans-serif;
        --font-body: Inter, system-ui, -apple-system, sans-serif;
        --font-mono: "JetBrains Mono", "IBM Plex Mono", ui-monospace, monospace;
      }

      @keyframes fade-up {
        from { opacity: 0; transform: translateY(18px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes terminal-pulse {
        0%, 100% { opacity: 0.35; }
        50% { opacity: 0.8; }
      }

      @media (prefers-reduced-motion: reduce) {
        @keyframes fade-up {
          from { opacity: 0; }
          to { opacity: 1; }
        }
        @keyframes terminal-pulse {
          0%, 100% { opacity: 0.5; }
        }
      }

      .f-display { font-family: var(--font-display); }
      .f-body { font-family: var(--font-body); }
      .f-mono { font-family: var(--font-mono); }
      .yil-hero { animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both; }
      .yil-section { opacity: 0; }
      .yil-section.is-visible { animation: fade-up 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
      .terminal-grid {
        background-image:
          linear-gradient(rgba(96, 165, 250, 0.08) 1px, transparent 1px),
          linear-gradient(90deg, rgba(167, 139, 250, 0.08) 1px, transparent 1px);
        background-size: 48px 48px;
      }
      .command-caret::after {
        content: '_';
        display: inline-block;
        color: #a78bfa;
        animation: terminal-pulse 1.1s ease-in-out infinite;
      }
      .dark-nav a span.leading-snug { color: #d4d4d8; }
    </style>
    <noscript><style>.yil-section { opacity: 1 !important; }</style></noscript>
  </head>
  <body class="bg-zinc-950">
    <main class="relative z-10 bg-zinc-950 shadow-xs">
      <Header />

      <!-- HERO: terminal-command-map -->
      <section class="yil-hero terminal-grid relative isolate overflow-hidden bg-zinc-950">
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-violet-400/50 to-transparent"></div>
        <div class="absolute -right-32 top-24 h-72 w-72 rounded-full bg-violet-500/20 blur-3xl"></div>
        <div class="absolute -left-28 bottom-8 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>

        <div class="mx-auto max-w-6xl px-6 py-28 md:py-36">
          <div class="max-w-4xl">
            <p class="f-mono text-[11px] uppercase tracking-[0.25em] text-gray-400">
              2026-05-17 / AGENT CONTROL PANEL
            </p>
            <h1
              class="f-display mt-8 max-w-4xl font-bold leading-[0.95] tracking-[-0.05em] text-zinc-50"
              style="font-size: clamp(3rem, 8vw, 6.5rem);"
            >
              Steer While It Runs
            </h1>
            <p class="f-body mt-8 max-w-2xl text-lg leading-relaxed text-gray-300 md:text-xl">
              The workflow is shifting from prompt-and-wait to live direction: start clean, redirect
              mid-run, queue the next job, background side work, preserve context, and turn repetition
              into Chronicle-supported routines.
            </p>
          </div>

          <div class="mt-14 rounded-3xl border border-white/10 bg-gray-900/80 p-4 shadow-2xl shadow-black/40 backdrop-blur md:p-6">
            <div class="flex items-center gap-2 border-b border-white/10 pb-4">
              <span class="h-3 w-3 rounded-full bg-red-400/80"></span>
              <span class="h-3 w-3 rounded-full bg-amber-300/80"></span>
              <span class="h-3 w-3 rounded-full bg-emerald-400/80"></span>
              <span class="f-mono ml-3 text-[11px] uppercase tracking-[0.2em] text-gray-500">session-control.sh</span>
            </div>
            <div class="grid gap-3 pt-5 md:grid-cols-6">
              {commands.map((item, index) => (
                <div class={`rounded-2xl border p-4 ${item.ring}`}>
                  <p class={`f-mono text-sm font-bold ${item.color}`}>{item.cmd}</p>
                  <p class="f-mono mt-3 text-[10px] uppercase leading-relaxed tracking-[0.12em] text-gray-400">
                    {String(index + 1).padStart(2, '0')} / {item.label}
                  </p>
                </div>
              ))}
            </div>
            <p class="f-mono command-caret mt-5 text-sm leading-relaxed text-gray-300">
              user notices wrong target → /steer “Actually make it for Hermes not OpenClaw” → task continues
            </p>
          </div>
        </div>
      </section>

      <!-- QUOTE: annotated-command-callout -->
      <section class="yil-section bg-zinc-950 py-24">
        <div class="mx-auto max-w-6xl px-6">
          <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-stretch">
            <aside class="rounded-3xl border border-violet-400/30 bg-violet-400/10 p-8">
              <p class="f-mono text-[11px] uppercase tracking-[0.22em] text-violet-300">/STEER</p>
              <p class="f-display mt-6 text-3xl font-bold leading-tight text-zinc-50 md:text-4xl">
                Correction is no longer a restart.
              </p>
              <p class="f-body mt-5 leading-relaxed text-gray-300">
                The command changes the emotional model of an agent run: a mistake in direction becomes
                a steering input, not a failed prompt.
              </p>
            </aside>
            <blockquote class="rounded-3xl border border-white/10 bg-gray-900 p-8 md:p-10">
              <p class="f-body text-2xl font-medium leading-snug text-zinc-50 md:text-4xl">
                “Old way was to stop, retype the whole thing, and lose context. /steer way is to nudge
                it mid-run: ‘Actually make it for Hermes not OpenClaw’ → task continues, corrected.
                It’s like editing a chef’s recipe while he’s still cooking.”
              </p>
              <footer class="f-mono mt-8 text-[11px] uppercase tracking-[0.2em] text-gray-500">
                Dan Denney / TIL 2026-05-17
              </footer>
            </blockquote>
          </div>
        </div>
      </section>

      <!-- CHRONICLE: cards -->
      <section id="chronicle" class="yil-section bg-gray-900 py-24">
        <div class="mx-auto max-w-6xl px-6">
          <p class="f-mono text-[11px] uppercase tracking-[0.22em] text-blue-400">CHRONICLE</p>
          <h2 class="f-display mt-4 max-w-3xl text-4xl font-bold tracking-[-0.04em] text-zinc-50 md:text-6xl">
            Repetition Wants a Memory Layer
          </h2>
          <p class="f-body mt-6 max-w-2xl text-lg leading-relaxed text-gray-300">
            Codex Chronicle landed as a practical signal: repeated tasks should not keep rebuilding
            their scaffolding from scratch. Chronicle is the durable layer; slash commands are the live
            control surface.
          </p>

          <div class="mt-14 grid gap-px overflow-hidden rounded-3xl border border-white/10 bg-white/10 md:grid-cols-3">
            <article class="bg-gray-900 p-8">
              <p class="f-mono text-[10px] uppercase tracking-[0.18em] text-blue-400">01 / signal</p>
              <h3 class="f-display mt-5 text-2xl font-bold text-zinc-50">Codex is getting louder</h3>
              <p class="f-body mt-4 leading-relaxed text-gray-400">
                The interesting part is not only the feature. It is the social reinforcement: more AI
                builders appear to be shifting serious workflows toward Codex.
              </p>
            </article>
            <article class="bg-gray-900 p-8">
              <p class="f-mono text-[10px] uppercase tracking-[0.18em] text-blue-400">02 / scaffold</p>
              <h3 class="f-display mt-5 text-2xl font-bold text-zinc-50">Loops deserve context</h3>
              <p class="f-body mt-4 leading-relaxed text-gray-400">
                Repetitive personal workflows — coding, YIL drafting, betting-board analysis, QA — are
                candidates for durable context instead of copy-pasted setup.
              </p>
            </article>
            <article class="bg-gray-900 p-8">
              <p class="f-mono text-[10px] uppercase tracking-[0.18em] text-blue-400">03 / question</p>
              <h3 class="f-display mt-5 text-2xl font-bold text-zinc-50">What goes first?</h3>
              <p class="f-body mt-4 leading-relaxed text-gray-400">
                The page should keep the audit open: which recurring Dan workflow should become
                Chronicle-backed before the rest?
              </p>
            </article>
          </div>
        </div>
      </section>

      <!-- LIVE STEERING: split -->
      <section class="yil-section bg-zinc-950 py-24">
        <div class="mx-auto max-w-6xl px-6">
          <div class="grid gap-8 lg:grid-cols-2">
            <div class="rounded-3xl border border-red-400/20 bg-red-400/5 p-8">
              <p class="f-mono text-[11px] uppercase tracking-[0.22em] text-red-300/80">OLD MODEL</p>
              <h2 class="f-display mt-5 text-4xl font-bold tracking-[-0.04em] text-zinc-50">Stop. Retype. Hope.</h2>
              <ul class="f-body mt-8 space-y-5 text-gray-400">
                <li class="border-l border-red-300/30 pl-4">Notice halfway through that the prompt was wrong.</li>
                <li class="border-l border-red-300/30 pl-4">Kill the run and lose the useful partial context.</li>
                <li class="border-l border-red-300/30 pl-4">Rewrite the whole request with the correction baked in.</li>
              </ul>
            </div>
            <div class="rounded-3xl border border-violet-400/30 bg-violet-400/10 p-8">
              <p class="f-mono text-[11px] uppercase tracking-[0.22em] text-violet-300">/STEER MODEL</p>
              <h2 class="f-display mt-5 text-4xl font-bold tracking-[-0.04em] text-zinc-50">Nudge. Continue. Correct.</h2>
              <ul class="f-body mt-8 space-y-5 text-gray-300">
                <li class="border-l border-violet-300/50 pl-4">The run keeps its working memory.</li>
                <li class="border-l border-violet-300/50 pl-4">The human stays in the loop without restarting the loop.</li>
                <li class="border-l border-violet-300/50 pl-4">Correction becomes part of directing, not evidence that prompting failed.</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- COMMAND STACK: feature -->
      <section class="yil-section bg-gray-900 py-24">
        <div class="mx-auto max-w-6xl px-6">
          <p class="f-mono text-[11px] uppercase tracking-[0.22em] text-emerald-400">SESSION STACK</p>
          <h2 class="f-display mt-4 max-w-3xl text-4xl font-bold tracking-[-0.04em] text-zinc-50 md:text-6xl">
            A Vocabulary for Long-Running Agent Work
          </h2>

          <div class="mt-14 rounded-3xl border border-white/10 bg-zinc-950 p-6 md:p-8">
            <div class="space-y-4">
              {commands.map((item) => (
                <div class="grid gap-4 rounded-2xl border border-white/10 bg-white/[0.02] p-5 md:grid-cols-[12rem_1fr] md:items-center">
                  <p class={`f-mono text-lg font-bold ${item.color}`}>{item.cmd}</p>
                  <p class="f-body text-gray-300">{item.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- WORKFLOW SHIFT: prose -->
      <section class="yil-section bg-zinc-950 py-24">
        <div class="mx-auto max-w-6xl px-6">
          <div class="max-w-3xl">
            <p class="f-mono text-[11px] uppercase tracking-[0.22em] text-amber-300">WORKFLOW</p>
            <h2 class="f-display mt-4 text-4xl font-bold tracking-[-0.04em] text-zinc-50 md:text-6xl">
              From One-Shot Prompts to Directional Systems
            </h2>
            <div class="f-body mt-10 space-y-6 text-lg leading-relaxed text-gray-300">
              <p>
                The day's synthesis is less about any one command and more about the shape they reveal
                together: live direction, queued intent, background execution, compressed context, and
                reusable memory.
              </p>
              <p>
                The useful move is to preserve the open questions instead of pretending the workflow is
                already solved. Where does `/steer` change behavior first: coding tasks, writing and YIL
                drafting, betting-board analysis, or QA workflows?
              </p>
            </div>
            <div class="mt-10 rounded-3xl border border-amber-300/30 bg-amber-300/10 p-8">
              <p class="f-mono text-[11px] uppercase tracking-[0.18em] text-amber-200">Follow-up to keep alive</p>
              <p class="f-display mt-4 text-2xl font-bold text-zinc-50">
                What should the “full stack” pattern for Hermes sessions be when `/new`, `/steer`,
                `/queue`, `/goal`, `/background`, and `/compress` are used together?
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- REFERENCES -->
      <section class="yil-section bg-gray-900 py-24">
        <div class="mx-auto max-w-6xl px-6">
          <p class="f-mono text-[11px] uppercase tracking-[0.22em] text-gray-500">References</p>
          <div class="mt-8 grid gap-4 md:grid-cols-2">
            {references.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group rounded-3xl border border-white/10 bg-zinc-950 p-6 transition-colors hover:border-white/20"
              >
                <span
                  class="f-mono inline-block rounded-full border px-3 py-1.5 text-[10px] uppercase tracking-[0.14em]"
                  style={`color: ${item.accent}; border-color: ${item.accent}55; background: ${item.accent}11;`}
                >{item.label}</span>
                <p class="f-body mt-5 leading-relaxed text-gray-300 group-hover:text-zinc-50">{item.title}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <div class="dark-nav bg-zinc-950">
        <YilSeriesNav currentDate={yilMeta.date} accent={yilMeta.accent} />
      </div>

      <!-- DESIGN NOTES -->
      <section class="border-t border-white/10 bg-gray-900">
        <div class="mx-auto max-w-6xl px-6 py-12">
          <p class="f-mono text-[10px] uppercase tracking-[0.25em] text-gray-500">Design Notes</p>
          <p class="f-mono mt-2 text-sm text-gray-300">YIL 2026-05-17 — Steering While the Agent Is Still Cooking</p>
          <p class="f-mono mt-1 max-w-3xl text-sm leading-relaxed text-gray-500">
            A day about the move from one-shot agent prompts to durable, interactive agent work:
            Codex Chronicle for repetitive tasks and Hermes slash commands for steering, queueing,
            backgrounding, and compressing live sessions.
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <div class="flex items-center gap-1.5"><span class="h-3 w-3 rounded-full bg-blue-400"></span><span class="f-mono text-[10px] text-gray-500">accent-1 / Chronicle</span></div>
            <div class="flex items-center gap-1.5"><span class="h-3 w-3 rounded-full bg-violet-400"></span><span class="f-mono text-[10px] text-gray-500">accent-2 / Steering</span></div>
            <div class="flex items-center gap-1.5"><span class="h-3 w-3 rounded-full bg-emerald-400"></span><span class="f-mono text-[10px] text-gray-500">accent-3 / Async work</span></div>
            <div class="flex items-center gap-1.5"><span class="h-3 w-3 rounded-full bg-amber-300"></span><span class="f-mono text-[10px] text-gray-500">accent-4 / Compression</span></div>
          </div>
          <p class="mt-6 max-w-3xl text-sm leading-relaxed text-gray-500">
            This draft uses an agent control-panel surface because the captured learning is about a
            user directing a live worker rather than submitting a perfect one-shot prompt. The command
            rail is the visual language; `/steer` is centered because it reframes mid-run correction as
            normal collaboration. Chronicle sits above the command stack as the durable memory layer for
            repeated workflows, while the follow-up questions remain unresolved by design.
          </p>
        </div>
      </section>
    </main>
    <Footer />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.06 }
      );
      document.querySelectorAll('.yil-section').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
