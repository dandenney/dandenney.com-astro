---
import { type CollectionEntry, getCollection, render } from "astro:content";
import PlusEVPost from "../../layouts/PlusEVPost.astro";
import { twinUrlForId } from "@/lib/markdownTwin";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("plus-ev");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.mdx?$/, '') },
    props: post,
  }));
}

type Props = CollectionEntry<"plus-ev">;

const post = Astro.props;
const { Content } = await render(post);
---

<PlusEVPost {...post.data} markdownTwin={twinUrlForId("plus-ev", post.id)}>
  <Content />
</PlusEVPost>
