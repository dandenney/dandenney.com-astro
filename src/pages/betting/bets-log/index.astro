---
export const prerender = true;
import BaseHead from "@/components/BaseHead.astro";
import { allLogs } from "@/data/betsLog";

const sorted = [...allLogs].sort((a, b) => b.date.localeCompare(a.date));
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead
      title="Daily Bets Log | Dan Denney"
      description="AI harness pipeline bets logs — daily pick evaluation and results"
    />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen antialiased">
    <main class="mx-auto max-w-2xl px-4 py-12 space-y-6">

      <header>
        <p class="text-xs uppercase tracking-widest text-slate-500 mb-1">Betting</p>
        <h1 class="text-2xl font-bold text-white tracking-tight">Daily Bets Log</h1>
        <p class="mt-1 text-slate-400 text-sm">AI harness pipeline evaluation — one day at a time</p>
      </header>

      <ul class="space-y-2">
        {sorted.map((log) => (
          <li>
            <a
              href={`/betting/bets-log/${log.date}`}
              class="flex items-center justify-between rounded-lg border border-slate-800 bg-slate-900 px-4 py-3 hover:border-slate-600 transition-colors group"
            >
              <span class="text-white font-medium group-hover:text-slate-100">{log.displayDate}</span>
              <div class="flex items-center gap-3">
                <span class="text-slate-500 text-xs">{log.finalDecision.action}</span>
                <span class={`text-sm font-bold ${log.finalDecision.result === "correct" ? "text-emerald-400" : "text-red-400"}`}>
                  {log.finalDecision.result === "correct" ? "✓" : "✗"}
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>

    </main>
  </body>
</html>
