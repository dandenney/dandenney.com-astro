---
export const prerender = true;
import BaseHead from "@/components/BaseHead.astro";
import BetsLogPipeline from "@/components/betting/BetsLogPipeline.astro";
import { allLogs } from "@/data/betsLog";
import type { DayLog } from "@/data/betsLog";

export function getStaticPaths() {
  return allLogs.map((log) => ({
    params: { date: log.date },
    props: { log },
  }));
}

interface Props {
  log: DayLog;
}

const { log } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead
      title={`Bets Log ${log.displayDate} | Dan Denney`}
      description={`AI harness pipeline bets log for ${log.displayDate}`}
    />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen antialiased">
    <main class="mx-auto max-w-7xl px-4 py-12 space-y-10">

      <header>
        <a href="/betting/bets-log" class="text-xs uppercase tracking-widest text-slate-500 hover:text-slate-400 transition-colors mb-1 block">
          ← Daily Bets Log
        </a>
        <h1 class="text-2xl font-bold text-white tracking-tight">{log.displayDate}</h1>
      </header>

      <BetsLogPipeline log={log} />

    </main>
  </body>
</html>
