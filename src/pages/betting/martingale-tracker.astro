---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE_TITLE } from "@/consts";
import { ViewTransitions } from "astro:transitions";
import {
  martingaleBets,
  startingBalance,
  hysaBenchmark,
  getStakeOut,
  getReturnAmount,
  getNetImpact,
  getNewSeriesStake,
  type MartingaleBet,
} from "@/data/martingaleBets";
const currency = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "USD",
  minimumFractionDigits: 2,
  maximumFractionDigits: 2,
});

const getOwner = (bet: MartingaleBet) => bet.owner ?? "Dan";

const orderedBets = [...martingaleBets]
  .filter((bet) => getOwner(bet) === "Dan")
  .sort((a, b) => a.date.localeCompare(b.date) || a.id - b.id);

const gardenOrderedBets = [...martingaleBets]
  .filter((bet) => getOwner(bet) === "GardenOf")
  .sort((a, b) => a.date.localeCompare(b.date) || a.id - b.id);

const totalWagers = orderedBets.length;
const settledBets = orderedBets.filter((bet) => bet.result !== "pending");
const pendingBets = orderedBets.filter((bet) => bet.result === "pending").length;
const wins = settledBets.filter((bet) => bet.result === "win").length;
const totalReturns = orderedBets.reduce((sum, bet) => sum + getReturnAmount(bet), 0);
const totalStaked = orderedBets.reduce((sum, bet) => sum + getStakeOut(bet), 0);
const netPL = Number((totalReturns - totalStaked).toFixed(2));
const currentBalance = Number((startingBalance + netPL).toFixed(2));
const winRate = settledBets.length ? (wins / settledBets.length) * 100 : 0;

const withRunningBalance = orderedBets.map((bet, index) => ({
  ...bet,
  stakeOut: getStakeOut(bet),
  returnAmount: getReturnAmount(bet),
  netImpact: getNetImpact(bet),
  runningBalance: Number(
    (
      startingBalance +
      orderedBets
        .slice(0, index + 1)
        .reduce((sum, current) => sum + getNetImpact(current), 0)
    ).toFixed(2),
  ),
}));

type SeriesStatus = "In Progress" | "Won" | "Full Fail";

interface SeriesSummary {
  seriesId: string;
  betsCount: number;
  lossesCount: number;
  status: SeriesStatus;
  netImpact: number;
}

interface HeroSeriesState {
  currentSeriesId: string | null;
  nextSeriesId: string | null;
  displaySeriesId: string | null;
  status: "Pending" | "Continuing Series" | "New Series Ready";
  lastBetAmount: number | null;
  nextBetStake: number | null;
  lastBet: MartingaleBet | null;
}

const getNextSeriesId = (seriesId: string | null): string | null => {
  if (!seriesId) return null;
  if (!/^[A-Z]$/.test(seriesId)) return seriesId;
  if (seriesId === "Z") return "AA";
  return String.fromCharCode(seriesId.charCodeAt(0) + 1);
};

const getHeroSeriesState = (bets: MartingaleBet[], balance: number): HeroSeriesState => {
  const lastBet = bets[bets.length - 1] ?? null;
  if (!lastBet) {
    return {
      currentSeriesId: null,
      nextSeriesId: null,
      displaySeriesId: null,
      status: "New Series Ready",
      lastBetAmount: null,
      nextBetStake: getNewSeriesStake(balance),
      lastBet: null,
    };
  }

  const lastBetAmount = getStakeOut(lastBet);
  const nextSeriesId = getNextSeriesId(lastBet.seriesId);
  const seriesBets = bets.filter((bet) => bet.seriesId === lastBet.seriesId);
  const lossesCount = seriesBets.filter((bet) => bet.result === "loss").length;

  if (lastBet.result === "pending") {
    return {
      currentSeriesId: lastBet.seriesId,
      nextSeriesId,
      displaySeriesId: lastBet.seriesId,
      status: "Pending",
      lastBetAmount,
      nextBetStake: Number((lastBetAmount * 2).toFixed(2)),
      lastBet,
    };
  }

  if (lastBet.result === "loss") {
    const fullFail = lossesCount >= 3;
    return {
      currentSeriesId: lastBet.seriesId,
      nextSeriesId,
      displaySeriesId: fullFail ? nextSeriesId : lastBet.seriesId,
      status: fullFail ? "New Series Ready" : "Continuing Series",
      lastBetAmount,
      nextBetStake: fullFail ? getNewSeriesStake(balance) : Number((lastBetAmount * 2).toFixed(2)),
      lastBet,
    };
  }

  // Last bet was a win — series complete, new series starts fresh
  return {
    currentSeriesId: lastBet.seriesId,
    nextSeriesId,
    displaySeriesId: nextSeriesId,
    status: "New Series Ready",
    lastBetAmount,
    nextBetStake: getNewSeriesStake(balance),
    lastBet,
  };
};

const seriesMap = new Map<string, MartingaleBet[]>();
for (const bet of orderedBets) {
  const existing = seriesMap.get(bet.seriesId) ?? [];
  existing.push(bet);
  seriesMap.set(bet.seriesId, existing);
}

const seriesSummaries: SeriesSummary[] = Array.from(seriesMap.entries()).map(
  ([seriesId, bets]) => {
    const lossesCount = bets.filter((bet) => bet.result === "loss").length;
    const hasWin = bets.some((bet) => bet.result === "win");
    const status: SeriesStatus = hasWin
      ? "Won"
      : lossesCount >= 3
        ? "Full Fail"
        : "In Progress";
    return {
      seriesId,
      betsCount: bets.length,
      lossesCount,
      status,
      netImpact: Number(bets.reduce((sum, bet) => sum + getNetImpact(bet), 0).toFixed(2)),
    };
  },
);

const formatDate = (dateString: MartingaleBet["date"]) =>
  new Date(`${dateString}T00:00:00`).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });

const firstBetDate = orderedBets[0]?.date;
const benchmarkAsOfDate = hysaBenchmark.asOfDate ?? new Date().toISOString().slice(0, 10);

let hysaCurrentValue = hysaBenchmark.principal;
if (firstBetDate) {
  const startDateMs = new Date(`${firstBetDate}T00:00:00`).getTime();
  const asOfDateMs = new Date(`${benchmarkAsOfDate}T00:00:00`).getTime();
  const elapsedMs = Math.max(asOfDateMs - startDateMs, 0);
  const elapsedYears = elapsedMs / (1000 * 60 * 60 * 24 * 365.25);
  hysaCurrentValue =
    hysaBenchmark.principal * Math.pow(1 + hysaBenchmark.annualYield, elapsedYears);
}

const strategyVsHysaDelta = currentBalance - hysaCurrentValue;

const danHeroSeriesState = getHeroSeriesState(orderedBets, currentBalance);

const gardenSettledBets = gardenOrderedBets.filter((bet) => bet.result !== "pending");
const gardenPendingBets = gardenOrderedBets.filter((bet) => bet.result === "pending").length;
const gardenWins = gardenSettledBets.filter((bet) => bet.result === "win").length;
const gardenTotalReturns = gardenOrderedBets.reduce((sum, bet) => sum + getReturnAmount(bet), 0);
const gardenTotalStaked = gardenOrderedBets.reduce((sum, bet) => sum + getStakeOut(bet), 0);
const gardenNetPL = Number((gardenTotalReturns - gardenTotalStaked).toFixed(2));
const gardenCurrentBalance = Number((startingBalance + gardenNetPL).toFixed(2));
const gardenWinRate = gardenSettledBets.length ? (gardenWins / gardenSettledBets.length) * 100 : 0;

const gardenWithRunningBalance = gardenOrderedBets.map((bet, index) => ({
  ...bet,
  stakeOut: getStakeOut(bet),
  returnAmount: getReturnAmount(bet),
  netImpact: getNetImpact(bet),
  runningBalance: Number(
    (
      startingBalance +
      gardenOrderedBets
        .slice(0, index + 1)
        .reduce((sum, current) => sum + getNetImpact(current), 0)
    ).toFixed(2),
  ),
}));

const gardenSeriesMap = new Map<string, MartingaleBet[]>();
for (const bet of gardenOrderedBets) {
  const existing = gardenSeriesMap.get(bet.seriesId) ?? [];
  existing.push(bet);
  gardenSeriesMap.set(bet.seriesId, existing);
}

const gardenSeriesSummaries: SeriesSummary[] = Array.from(gardenSeriesMap.entries()).map(
  ([seriesId, bets]) => {
    const lossesCount = bets.filter((bet) => bet.result === "loss").length;
    const hasWin = bets.some((bet) => bet.result === "win");
    const status: SeriesStatus = hasWin ? "Won" : lossesCount >= 3 ? "Full Fail" : "In Progress";
    return {
      seriesId,
      betsCount: bets.length,
      lossesCount,
      status,
      netImpact: Number(bets.reduce((sum, bet) => sum + getNetImpact(bet), 0).toFixed(2)),
    };
  },
);

const gardenHeroSeriesState = getHeroSeriesState(gardenOrderedBets, gardenCurrentBalance);

const danActiveBets = orderedBets.filter((bet) => bet.result === "pending");
const gardenActiveBetsList = gardenOrderedBets.filter((bet) => bet.result === "pending");

// Descending order for tables
const withRunningBalanceDesc = [...withRunningBalance].reverse();
const gardenWithRunningBalanceDesc = [...gardenWithRunningBalance].reverse();
const seriesSummariesDesc = [...seriesSummaries].reverse();
const gardenSeriesSummariesDesc = [...gardenSeriesSummaries].reverse();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead
      title="Martingale Bet Tracker | Dan Denney"
      description="A clean snapshot of a Martingale betting streak with summary metrics and a bet-by-bet ledger."
    />
    <ViewTransitions />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen overflow-x-hidden antialiased">
    <main class="relative z-10 bg-slate-950">

    <!-- ═══════════════════════════════════════════════════════
         HERO — full-bleed image with active bet objectives
    ═══════════════════════════════════════════════════════ -->
    <section class="relative w-full min-h-[80vh] flex flex-col overflow-hidden">
      <!-- Background image -->
      <img
        src="/bet-background.webp"
        class="absolute inset-0 w-full h-full object-cover object-center"
        alt=""
        loading="eager"
      />
      <!-- Dark gradient overlays -->
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950/40 via-slate-950/65 to-slate-950"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950/80 via-transparent to-slate-950/50"></div>
      <!-- Tactical grid -->
      <div class="absolute inset-0 [background-image:linear-gradient(rgba(6,182,212,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(6,182,212,0.04)_1px,transparent_1px)] [background-size:48px_48px]"></div>
      <!-- Corner accent marks -->
      <div class="absolute top-0 left-0 w-20 h-20 border-t-2 border-l-2 border-cyan-500/50"></div>
      <div class="absolute top-0 right-0 w-20 h-20 border-t-2 border-r-2 border-cyan-500/50"></div>
      <div class="absolute bottom-0 left-0 w-12 h-12 border-b border-l border-cyan-500/20"></div>
      <div class="absolute bottom-0 right-0 w-12 h-12 border-b border-r border-cyan-500/20"></div>

      <!-- Nav -->
      <div class="relative z-10 border-b border-white/5 backdrop-blur-sm">
        <Header title={SITE_TITLE} />
      </div>

      <!-- Hero body -->
      <div class="relative z-10 flex-1 flex flex-col lg:flex-row lg:items-end gap-8 lg:gap-12 px-6 lg:px-12 xl:px-16 pb-12 pt-8">

        <!-- Left column: identity -->
        <div class="flex flex-col justify-end lg:w-[38%] flex-shrink-0">
          <!-- HUD label -->
          <div class="flex items-center gap-3 mb-4">
            <div class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse shadow-[0_0_8px_rgba(34,211,238,0.8)]"></div>
            <p class="font-mono text-[10px] uppercase tracking-[0.5em] text-cyan-400/80">Martingale Command Center · Live</p>
          </div>

          <h1 class="text-6xl lg:text-8xl font-black uppercase tracking-tighter text-white leading-none drop-shadow-2xl text-balance">
            Bet<br />Tracker
          </h1>
        </div>

        <!-- Right column: featured active objective card -->
        <div class="flex-1">
          <div class="relative border border-slate-700/40 bg-slate-950/75 backdrop-blur-md overflow-hidden">
            <!-- Dual-owner accent line -->
            <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-cyan-500 via-violet-400 to-violet-500"></div>

            <!-- Header -->
            <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b border-slate-700/40">
              <div class="flex items-center gap-2">
                <div class="w-1.5 h-1.5 rounded-full bg-cyan-400 shadow-[0_0_8px_rgba(34,211,238,0.8)]"></div>
                <p class="font-mono text-[10px] uppercase tracking-[0.45em] text-cyan-400/80">Active Objective</p>
              </div>
              {danActiveBets.length > 0 ? (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-amber-500/15 border border-amber-500/35 text-amber-300 font-mono text-[10px] uppercase tracking-[0.2em]">
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-400 animate-pulse"></span>
                  Pending
                </span>
              ) : (
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-slate-700/20 border border-slate-600/30 text-slate-500 font-mono text-[10px] uppercase tracking-[0.2em]">
                  <span class="w-1.5 h-1.5 rounded-full bg-slate-500/60"></span>
                  Standby
                </span>
              )}
            </div>

            <!-- Featured pick name -->
            <div class="px-6 py-6">
              {danActiveBets.length > 0 ? (
                <p class="text-3xl lg:text-4xl xl:text-5xl font-black text-white uppercase tracking-tight leading-none">{danActiveBets[0].pick}</p>
              ) : (
                <div>
                  <p class="text-3xl lg:text-4xl xl:text-5xl font-black text-slate-500 uppercase tracking-tight leading-none">No Current Bet</p>
                </div>
              )}
            </div>

            <!-- Per-owner metadata: Dan | GardenOf -->
            <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-slate-700/40 border-t border-slate-700/40">

              <!-- Dan -->
              <div class="px-6 py-4">
                <p class="font-mono text-[10px] uppercase tracking-[0.4em] text-cyan-400 mb-3">// Dan</p>
                {danActiveBets.length > 0 ? (
                  danActiveBets.map((bet) => (
                    <div>
                      <div class="grid grid-cols-3 gap-3">
                        <div>
                          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Series</p>
                          <p class="font-mono text-xl font-bold text-cyan-300">{danHeroSeriesState.displaySeriesId ?? bet.seriesId}</p>
                        </div>
                        <div>
                          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Line</p>
                          <p class="font-mono text-xl font-bold text-white">{bet.line}</p>
                        </div>
                        <div>
                          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Stake</p>
                          <p class="font-mono text-xl font-bold text-rose-300 tabular-nums">{currency.format(getStakeOut(bet))}</p>
                        </div>
                      </div>
                    </div>
                  ))
                ) : (
                  <div>
                    <div class="grid grid-cols-3 gap-3">
                      <div>
                        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">{danHeroSeriesState.status === "Continuing Series" ? "Series" : "Next Series"}</p>
                        <p class="font-mono text-xl font-bold text-cyan-300">{danHeroSeriesState.displaySeriesId ?? "—"}</p>
                      </div>
                      <div>
                        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Next Stake</p>
                        <p class="font-mono text-xl font-bold text-rose-300 tabular-nums">{danHeroSeriesState.nextBetStake ? currency.format(danHeroSeriesState.nextBetStake) : "—"}</p>
                      </div>
                      <div>
                        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Status</p>
                        <p class:list={["font-mono text-sm font-bold", danHeroSeriesState.status === "Continuing Series" ? "text-amber-300" : "text-emerald-400"]}>{danHeroSeriesState.status}</p>
                      </div>
                    </div>
                  </div>
                )}
              </div>

              <!-- GardenOf -->
              <div class="px-6 py-4">
                <p class="font-mono text-[10px] uppercase tracking-[0.4em] text-violet-400 mb-3">// GardenOf</p>
                {gardenActiveBetsList.length > 0 ? (
                  gardenActiveBetsList.map((bet) => (
                    <div>
                      <div class="grid grid-cols-3 gap-3">
                        <div>
                          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Series</p>
                          <p class="font-mono text-xl font-bold text-violet-300">{gardenHeroSeriesState.displaySeriesId ?? bet.seriesId}</p>
                        </div>
                        <div>
                          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Line</p>
                          <p class="font-mono text-xl font-bold text-white">{bet.line}</p>
                        </div>
                        <div>
                          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Stake</p>
                          <p class="font-mono text-xl font-bold text-rose-300 tabular-nums">{currency.format(getStakeOut(bet))}</p>
                        </div>
                      </div>
                    </div>
                  ))
                ) : (
                  <div>
                    <div class="grid grid-cols-3 gap-3">
                      <div>
                        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">{gardenHeroSeriesState.status === "Continuing Series" ? "Series" : "Next Series"}</p>
                        <p class="font-mono text-xl font-bold text-violet-300">{gardenHeroSeriesState.displaySeriesId ?? "—"}</p>
                      </div>
                      <div>
                        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Next Stake</p>
                        <p class="font-mono text-xl font-bold text-rose-300 tabular-nums">{gardenHeroSeriesState.nextBetStake ? currency.format(gardenHeroSeriesState.nextBetStake) : "—"}</p>
                      </div>
                      <div>
                        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-1">Status</p>
                        <p class:list={["font-mono text-sm font-bold", gardenHeroSeriesState.status === "Continuing Series" ? "text-amber-300" : "text-emerald-400"]}>{gardenHeroSeriesState.status}</p>
                      </div>
                    </div>
                  </div>
                )}
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         STATS — performance metrics for both accounts
    ═══════════════════════════════════════════════════════ -->
    <section class="w-full bg-slate-950 px-6 lg:px-12 xl:px-16 py-16">
      <div class="flex items-center gap-4 mb-10">
        <div class="h-px w-10 bg-cyan-500/60"></div>
        <p class="font-mono text-[10px] uppercase tracking-[0.5em] text-slate-500">// Performance Metrics</p>
        <div class="h-px flex-1 bg-slate-800/60"></div>
      </div>

      <div class="grid gap-10 lg:grid-cols-2">

        <!-- Dan stats -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-1 h-7 bg-cyan-400 shadow-[0_0_10px_rgba(34,211,238,0.5)]"></div>
            <p class="font-mono text-xs uppercase tracking-[0.4em] text-cyan-300 font-bold">Dan</p>
            <p class="font-mono text-[10px] text-slate-400 uppercase tracking-wider">· {totalWagers} bets · {settledBets.length} settled · {pendingBets} pending</p>
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden col-span-2 sm:col-span-1">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-slate-600/60 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">Starting Balance</p>
              <p class="font-mono text-2xl font-bold tabular-nums text-white">{currency.format(startingBalance)}</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-cyan-500/40 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">Current Balance</p>
              <p class:list={["font-mono text-2xl font-bold tabular-nums", currentBalance >= startingBalance ? "text-emerald-400" : "text-rose-400"]}>{currency.format(currentBalance)}</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-cyan-500/40 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">Net P/L</p>
              <p class:list={["font-mono text-2xl font-bold tabular-nums", netPL >= 0 ? "text-emerald-400" : "text-rose-400"]}>{netPL >= 0 ? "+" : ""}{currency.format(netPL)}</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-slate-600/60 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">Win Rate</p>
              <p class="font-mono text-2xl font-bold tabular-nums text-white">{settledBets.length ? `${winRate.toFixed(0)}%` : "—"}</p>
            </div>
            <div class="relative border border-cyan-500/20 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-cyan-500/40 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">HYSA Benchmark</p>
              <p class="font-mono text-2xl font-bold tabular-nums text-cyan-300">{currency.format(hysaCurrentValue)}</p>
              <p class="font-mono text-[10px] text-slate-600 mt-1 uppercase">4.2% APY · Sim only</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-slate-600/60 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">vs HYSA Delta</p>
              <p class:list={["font-mono text-2xl font-bold tabular-nums", strategyVsHysaDelta >= 0 ? "text-emerald-400" : "text-rose-400"]}>{strategyVsHysaDelta >= 0 ? "+" : ""}{currency.format(strategyVsHysaDelta)}</p>
            </div>
          </div>
        </div>

        <!-- GardenOf stats -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-1 h-7 bg-violet-400 shadow-[0_0_10px_rgba(167,139,250,0.5)]"></div>
            <p class="font-mono text-xs uppercase tracking-[0.4em] text-violet-300 font-bold">GardenOf</p>
            <p class="font-mono text-[10px] text-slate-400 uppercase tracking-wider">· {gardenOrderedBets.length} bets · {gardenSettledBets.length} settled · {gardenPendingBets} pending</p>
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden col-span-2 sm:col-span-1">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-slate-600/60 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">Starting Balance</p>
              <p class="font-mono text-2xl font-bold tabular-nums text-white">{currency.format(startingBalance)}</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-violet-500/40 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">Current Balance</p>
              <p class:list={["font-mono text-2xl font-bold tabular-nums", gardenCurrentBalance >= startingBalance ? "text-emerald-400" : "text-rose-400"]}>{currency.format(gardenCurrentBalance)}</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-violet-500/40 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">Net P/L</p>
              <p class:list={["font-mono text-2xl font-bold tabular-nums", gardenNetPL >= 0 ? "text-emerald-400" : "text-rose-400"]}>{gardenNetPL >= 0 ? "+" : ""}{currency.format(gardenNetPL)}</p>
            </div>
            <div class="relative border border-slate-700/50 bg-slate-900/40 p-4 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-slate-600/60 to-transparent"></div>
              <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 mb-2">Win Rate</p>
              <p class="font-mono text-2xl font-bold tabular-nums text-white">{gardenSettledBets.length ? `${gardenWinRate.toFixed(0)}%` : "—"}</p>
            </div>
          </div>
        </div>

      </div>

      <p class="mt-10 font-mono text-[10px] text-slate-500 uppercase tracking-wider border-t border-slate-800/40 pt-5">
        Accounting: Each placed bet debits stake immediately. Settlement credits return amount only (0 on losses, no credit while pending).
      </p>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         HISTORY — series summaries + full ledgers, descending
    ═══════════════════════════════════════════════════════ -->
    <section class="w-full px-6 lg:px-12 xl:px-16 py-16 border-t border-slate-800/50">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-12">
        <div class="flex items-center gap-4 flex-1">
          <div class="h-px w-10 bg-slate-500/60"></div>
          <p class="font-mono text-[10px] uppercase tracking-[0.5em] text-slate-500">// Bet History Ledger</p>
          <div class="h-px flex-1 bg-slate-800/60"></div>
        </div>
        <div class="flex items-center gap-3 flex-shrink-0">
          <a href="#dan-ledger" class="font-mono text-[10px] uppercase tracking-[0.2em] text-cyan-400/70 hover:text-cyan-300 transition-colors border border-cyan-500/20 hover:border-cyan-500/40 px-2.5 py-1">↓ Dan</a>
          <a href="#garden-ledger" class="font-mono text-[10px] uppercase tracking-[0.2em] text-violet-400/70 hover:text-violet-300 transition-colors border border-violet-500/20 hover:border-violet-500/40 px-2.5 py-1">↓ GardenOf</a>
        </div>
      </div>

      <!-- ── Series Summaries (two-col on lg) ── -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
        <!-- Dan series summary -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-1 h-6 bg-cyan-400 shadow-[0_0_8px_rgba(34,211,238,0.4)]"></div>
            <p class="font-mono text-xs uppercase tracking-[0.35em] text-cyan-300 font-bold">Dan · Series Summary</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left min-w-[480px]">
              <thead>
                <tr class="border-b border-slate-700/50">
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Series</th>
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Bets</th>
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Losses</th>
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Status</th>
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Net Impact</th>
                </tr>
              </thead>
              <tbody>
                {seriesSummariesDesc.map((series) => (
                  <tr class="border-b border-slate-800/20 odd:bg-slate-900/10 hover:bg-slate-800/20 transition-colors">
                    <td class="py-3 pr-8 font-mono font-bold text-white">{series.seriesId}</td>
                    <td class="py-3 pr-8 font-mono text-sm text-slate-400">{series.betsCount}</td>
                    <td class="py-3 pr-8 font-mono text-sm text-slate-400">{series.lossesCount}</td>
                    <td class="py-3 pr-8">
                      <span class:list={["font-mono text-[10px] uppercase tracking-wider px-2.5 py-1 border", series.status === "Won" ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-400" : series.status === "Full Fail" ? "border-rose-500/30 bg-rose-500/10 text-rose-400" : "border-amber-500/30 bg-amber-500/10 text-amber-300"]}>
                        {series.status}
                      </span>
                    </td>
                    <td class:list={["py-3 pr-8 font-mono text-sm font-bold tabular-nums", series.netImpact >= 0 ? "text-emerald-400" : "text-rose-400"]}>
                      {series.netImpact >= 0 ? "+" : ""}{currency.format(series.netImpact)}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- GardenOf series summary -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-1 h-6 bg-violet-400 shadow-[0_0_8px_rgba(167,139,250,0.4)]"></div>
            <p class="font-mono text-xs uppercase tracking-[0.35em] text-violet-300 font-bold">GardenOf · Series Summary</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left min-w-[480px]">
              <thead>
                <tr class="border-b border-slate-700/50">
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Series</th>
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Bets</th>
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Losses</th>
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Status</th>
                  <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-8 font-medium">Net Impact</th>
                </tr>
              </thead>
              <tbody>
                {gardenSeriesSummariesDesc.map((series) => (
                  <tr class="border-b border-slate-800/20 odd:bg-slate-900/10 hover:bg-slate-800/20 transition-colors">
                    <td class="py-3 pr-8 font-mono font-bold text-white">{series.seriesId}</td>
                    <td class="py-3 pr-8 font-mono text-sm text-slate-400">{series.betsCount}</td>
                    <td class="py-3 pr-8 font-mono text-sm text-slate-400">{series.lossesCount}</td>
                    <td class="py-3 pr-8">
                      <span class:list={["font-mono text-[10px] uppercase tracking-wider px-2.5 py-1 border", series.status === "Won" ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-400" : series.status === "Full Fail" ? "border-rose-500/30 bg-rose-500/10 text-rose-400" : "border-amber-500/30 bg-amber-500/10 text-amber-300"]}>
                        {series.status}
                      </span>
                    </td>
                    <td class:list={["py-3 pr-8 font-mono text-sm font-bold tabular-nums", series.netImpact >= 0 ? "text-emerald-400" : "text-rose-400"]}>
                      {series.netImpact >= 0 ? "+" : ""}{currency.format(series.netImpact)}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- ── Dan ── -->
      <div class="mb-20" id="dan-ledger">

        <!-- Dan full ledger -->
        <div class="flex items-center gap-3 mb-5">
          <div class="w-1 h-6 bg-cyan-400 shadow-[0_0_8px_rgba(34,211,238,0.4)]"></div>
          <p class="font-mono text-xs uppercase tracking-[0.35em] text-cyan-300 font-bold">Dan · Full Ledger</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-left min-w-[960px]">
            <thead class="sticky top-0 z-10 bg-slate-950 shadow-[0_1px_0_rgba(51,65,85,0.5)]">
              <tr>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Series</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Date</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Pick</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Line</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Stake Out</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Result</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Return In</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Net Impact</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Balance</th>
              </tr>
            </thead>
            <tbody>
              {withRunningBalanceDesc.map((bet) => (
                <tr class="border-b border-slate-800/20 odd:bg-slate-900/10 hover:bg-slate-800/20 transition-colors">
                  <td class="py-3 pr-6 font-mono font-bold text-cyan-300 text-sm whitespace-nowrap">{bet.seriesId}</td>
                  <td class="py-3 pr-6 font-mono text-xs text-slate-500 whitespace-nowrap">{formatDate(bet.date)}</td>
                  <td class="py-3 pr-6 font-mono text-sm text-white">{bet.pick}</td>
                  <td class="py-3 pr-6 font-mono text-sm text-slate-300 whitespace-nowrap">{bet.line}</td>
                  <td class="py-3 pr-6 font-mono text-sm text-rose-400 tabular-nums whitespace-nowrap">-{currency.format(bet.stakeOut)}</td>
                  <td class="py-3 pr-6 whitespace-nowrap">
                    <span class:list={["font-mono text-[10px] uppercase tracking-wider px-2.5 py-1 border", bet.result === "win" ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-400" : bet.result === "loss" ? "border-rose-500/30 bg-rose-500/10 text-rose-400" : "border-amber-500/30 bg-amber-500/10 text-amber-300"]}>
                      {bet.result === "pending" ? "Pending" : bet.result}
                    </span>
                  </td>
                  <td class:list={["py-3 pr-6 font-mono text-sm tabular-nums whitespace-nowrap", bet.returnAmount > 0 ? "text-emerald-400" : "text-slate-600"]}>
                    {bet.result === "pending" ? "—" : `+${currency.format(bet.returnAmount)}`}
                  </td>
                  <td class:list={["py-3 pr-6 font-mono text-sm font-bold tabular-nums whitespace-nowrap", bet.netImpact >= 0 ? "text-emerald-400" : "text-rose-400"]}>
                    {bet.netImpact >= 0 ? "+" : ""}{currency.format(bet.netImpact)}
                  </td>
                  <td class="py-3 pr-6 font-mono text-sm text-cyan-300 tabular-nums whitespace-nowrap">{currency.format(bet.runningBalance)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- ── GardenOf ── -->
      <div class="border-t border-slate-800/50 pt-16" id="garden-ledger">

        <!-- GardenOf full ledger -->
        <div class="flex items-center gap-3 mb-5">
          <div class="w-1 h-6 bg-violet-400 shadow-[0_0_8px_rgba(167,139,250,0.4)]"></div>
          <p class="font-mono text-xs uppercase tracking-[0.35em] text-violet-300 font-bold">GardenOf · Full Ledger</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-left min-w-[960px]">
            <thead class="sticky top-0 z-10 bg-slate-950 shadow-[0_1px_0_rgba(51,65,85,0.5)]">
              <tr>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Series</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Date</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Pick</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Line</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Stake Out</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Result</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Return In</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Net Impact</th>
                <th class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-400 py-3 pr-6 font-medium">Balance</th>
              </tr>
            </thead>
            <tbody>
              {gardenWithRunningBalanceDesc.map((bet) => (
                <tr class="border-b border-slate-800/20 odd:bg-slate-900/10 hover:bg-slate-800/20 transition-colors">
                  <td class="py-3 pr-6 font-mono font-bold text-violet-300 text-sm whitespace-nowrap">{bet.seriesId}</td>
                  <td class="py-3 pr-6 font-mono text-xs text-slate-500 whitespace-nowrap">{formatDate(bet.date)}</td>
                  <td class="py-3 pr-6 font-mono text-sm text-white">{bet.pick}</td>
                  <td class="py-3 pr-6 font-mono text-sm text-slate-300 whitespace-nowrap">{bet.line}</td>
                  <td class="py-3 pr-6 font-mono text-sm text-rose-400 tabular-nums whitespace-nowrap">-{currency.format(bet.stakeOut)}</td>
                  <td class="py-3 pr-6 whitespace-nowrap">
                    <span class:list={["font-mono text-[10px] uppercase tracking-wider px-2.5 py-1 border", bet.result === "win" ? "border-emerald-500/30 bg-emerald-500/10 text-emerald-400" : bet.result === "loss" ? "border-rose-500/30 bg-rose-500/10 text-rose-400" : "border-amber-500/30 bg-amber-500/10 text-amber-300"]}>
                      {bet.result === "pending" ? "Pending" : bet.result}
                    </span>
                  </td>
                  <td class:list={["py-3 pr-6 font-mono text-sm tabular-nums whitespace-nowrap", bet.returnAmount > 0 ? "text-emerald-400" : "text-slate-600"]}>
                    {bet.result === "pending" ? "—" : `+${currency.format(bet.returnAmount)}`}
                  </td>
                  <td class:list={["py-3 pr-6 font-mono text-sm font-bold tabular-nums whitespace-nowrap", bet.netImpact >= 0 ? "text-emerald-400" : "text-rose-400"]}>
                    {bet.netImpact >= 0 ? "+" : ""}{currency.format(bet.netImpact)}
                  </td>
                  <td class="py-3 pr-6 font-mono text-sm text-violet-300 tabular-nums whitespace-nowrap">{currency.format(bet.runningBalance)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

      </div>
    </section>

    </main>
    <Footer />
  </body>
</html>
