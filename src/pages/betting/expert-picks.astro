---
import BaseHead from "@/components/BaseHead.astro";
import { expertPicks, type ExpertPick } from "@/data/expertPicks";

export const prerender = true;

// Group by author, preserving insertion order (data is already ordered by date desc from the source)
const bettorMap = new Map<string, ExpertPick[]>();
for (const pick of expertPicks) {
  const existing = bettorMap.get(pick.authorName) ?? [];
  existing.push(pick);
  bettorMap.set(pick.authorName, existing);
}

// Sort each bettor's picks by gameDateTime ascending
const bettors = Array.from(bettorMap.entries()).map(([name, picks]) => {
  const sorted = [...picks].sort(
    (a, b) => new Date(a.gameDateTime).getTime() - new Date(b.gameDateTime).getTime(),
  );
  const wins = sorted.filter((p) => p.result === "win").length;
  const losses = sorted.filter((p) => p.result === "loss").length;
  const pushes = sorted.filter((p) => p.result === "push").length;
  const resolved = wins + losses + pushes;
  const winPct = resolved > 0 ? Math.round((wins / (wins + losses)) * 100) : 0;

  let longestLossStreak = 0;
  let currentStreak = 0;
  for (const pick of sorted) {
    if (pick.result === "loss") {
      currentStreak++;
      if (currentStreak > longestLossStreak) longestLossStreak = currentStreak;
    } else {
      currentStreak = 0;
    }
  }

  // Current streak from most recent picks
  let currentStreakType: "win" | "loss" | null = null;
  let currentStreakCount = 0;
  for (let i = sorted.length - 1; i >= 0; i--) {
    const r = sorted[i].result;
    if (i === sorted.length - 1) {
      currentStreakType = r === "push" ? null : r;
      currentStreakCount = r === "push" ? 0 : 1;
    } else if (r === currentStreakType) {
      currentStreakCount++;
    } else {
      break;
    }
  }

  return { name, picks: sorted, wins, losses, pushes, resolved, winPct, longestLossStreak, currentStreakType, currentStreakCount };
});

// Sort bettors by total pick count descending
bettors.sort((a, b) => b.picks.length - a.picks.length);

// Overall summary stats
const totalPicks = expertPicks.length;
const totalWins = expertPicks.filter((p) => p.result === "win").length;
const totalLosses = expertPicks.filter((p) => p.result === "loss").length;
const totalPushes = expertPicks.filter((p) => p.result === "push").length;
const overallWinPct = Math.round((totalWins / (totalWins + totalLosses)) * 100);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead
      title="Expert Picks | Dan Denney"
      description="CBS SportsLine expert picks broken down by bettor."
    />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen antialiased">
    <main class="mx-auto max-w-7xl px-4 py-12 space-y-12">

      <!-- Page header -->
      <header class="space-y-6">
        <div>
          <h1 class="text-4xl font-bold text-white tracking-tight">Expert Picks</h1>
          <p class="mt-1 text-slate-400">CBS SportsLine experts tracked across {bettors.length} bettors</p>
        </div>

        <!-- Summary bar -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="bg-slate-900 border border-slate-800 rounded-xl px-5 py-4">
            <div class="text-2xl font-bold text-white">{totalPicks}</div>
            <div class="text-xs text-slate-500 mt-0.5 uppercase tracking-wider">Total Picks</div>
          </div>
          <div class="bg-slate-900 border border-slate-800 rounded-xl px-5 py-4">
            <div class="text-2xl font-bold text-emerald-400">{totalWins}</div>
            <div class="text-xs text-slate-500 mt-0.5 uppercase tracking-wider">Wins</div>
          </div>
          <div class="bg-slate-900 border border-slate-800 rounded-xl px-5 py-4">
            <div class="text-2xl font-bold text-red-400">{totalLosses}</div>
            <div class="text-xs text-slate-500 mt-0.5 uppercase tracking-wider">Losses</div>
          </div>
          <div class="bg-slate-900 border border-slate-800 rounded-xl px-5 py-4">
            <div class={`text-2xl font-bold ${overallWinPct >= 55 ? 'text-emerald-400' : overallWinPct >= 50 ? 'text-yellow-400' : 'text-red-400'}`}>
              {overallWinPct}%
            </div>
            <div class="text-xs text-slate-500 mt-0.5 uppercase tracking-wider">Win Rate</div>
          </div>
        </div>
      </header>

      <!-- Bettors -->
      {bettors.map(({ name, picks, wins, losses, pushes, resolved, winPct, longestLossStreak, currentStreakType, currentStreakCount }) => {
        const firstPick = picks[0];
        return (
          <section class="space-y-3">
            <!-- Bettor header card -->
            <div class="bg-slate-900 border border-slate-800 rounded-xl p-4 sm:p-5">
              <div class="flex flex-wrap items-center gap-4">
                <!-- Avatar + name -->
                <div class="flex items-center gap-3 min-w-0">
                  {firstPick.authorImageUrl && (
                    <img
                      src={firstPick.authorImageUrl}
                      alt={name}
                      class="w-12 h-12 rounded-full object-cover bg-slate-800 shrink-0"
                    />
                  )}
                  <div class="min-w-0">
                    <h2 class="text-lg font-semibold text-white leading-tight">{name}</h2>
                    <p class="text-slate-500 text-sm truncate">{firstPick.authorOtherName}</p>
                  </div>
                </div>

                <!-- Stats row -->
                <div class="flex flex-wrap items-center gap-x-5 gap-y-2 ml-auto text-sm">
                  <!-- W/L/P -->
                  <div class="flex items-center gap-3">
                    <span class="text-slate-400">
                      <span class="text-emerald-400 font-semibold text-base">{wins}</span>
                      <span class="text-slate-500 ml-1">W</span>
                    </span>
                    <span class="text-slate-400">
                      <span class="text-red-400 font-semibold text-base">{losses}</span>
                      <span class="text-slate-500 ml-1">L</span>
                    </span>
                    {pushes > 0 && (
                      <span class="text-slate-400">
                        <span class="text-slate-300 font-semibold text-base">{pushes}</span>
                        <span class="text-slate-500 ml-1">P</span>
                      </span>
                    )}
                  </div>

                  <!-- Win % badge -->
                  <span class={`inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold ${
                    winPct >= 55 ? 'bg-emerald-900/40 text-emerald-400 border border-emerald-800/50' :
                    winPct >= 50 ? 'bg-yellow-900/40 text-yellow-400 border border-yellow-800/50' :
                    'bg-red-900/40 text-red-400 border border-red-800/50'
                  }`}>
                    {winPct}% W
                  </span>

                  <!-- Current streak -->
                  {currentStreakType && currentStreakCount > 1 && (
                    <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-semibold ${
                      currentStreakType === 'win'
                        ? 'bg-emerald-900/30 text-emerald-400 border border-emerald-800/40'
                        : 'bg-red-900/30 text-red-400 border border-red-800/40'
                    }`}>
                      {currentStreakCount} {currentStreakType === 'win' ? 'W' : 'L'} streak
                    </span>
                  )}

                  <!-- Longest loss streak -->
                  <span class="text-slate-500 text-xs">
                    <span class="text-orange-400 font-semibold">{longestLossStreak}</span>
                    <span class="ml-1">max L streak</span>
                  </span>

                  <span class="text-slate-600 text-xs hidden sm:inline">{picks.length} picks</span>
                </div>
              </div>
            </div>

            <!-- Picks table -->
            <div class="overflow-x-auto rounded-xl border border-slate-800">
              <table class="w-full text-sm text-left">
                <thead class="bg-slate-900/80 text-slate-500 uppercase text-xs tracking-wider border-b border-slate-800">
                  <tr>
                    <th class="px-4 py-3 whitespace-nowrap">Date</th>
                    <th class="px-4 py-3 whitespace-nowrap">Matchup</th>
                    <th class="px-4 py-3 whitespace-nowrap">Type</th>
                    <th class="px-4 py-3">Bet</th>
                    <th class="px-4 py-3 whitespace-nowrap hidden md:table-cell">Made</th>
                    <th class="px-4 py-3 whitespace-nowrap hidden md:table-cell">Book</th>
                    <th class="px-4 py-3 whitespace-nowrap text-center">Result</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/60">
                  {picks.map((pick) => (
                    <Fragment>
                      <tr class="bg-slate-950 hover:bg-slate-900/60 transition-colors group">
                        <td class="px-4 py-3 whitespace-nowrap text-slate-400 text-xs">
                          {pick.gameDateTime.split(",")[0].replace(/\s+\d{4}$/, "").trim()}
                        </td>
                        <td class="px-4 py-3 whitespace-nowrap">
                          <span class="text-slate-300">{pick.homeTeam}</span>
                          <span class="text-slate-600 mx-1.5">vs</span>
                          <span class="text-slate-300">{pick.awayTeam}</span>
                          {(pick.homeScore || pick.awayScore) && (
                            <span class="ml-2 text-slate-500 text-xs">
                              {pick.homeScore}–{pick.awayScore}
                            </span>
                          )}
                        </td>
                        <td class="px-4 py-3 whitespace-nowrap">
                          <span class="inline-block px-2 py-0.5 rounded text-xs bg-slate-800 text-slate-400">
                            {pick.betType}
                          </span>
                        </td>
                        <td class="px-4 py-3 text-slate-100 max-w-xs">
                          <div>{pick.betTitle}</div>
                          {pick.analysisText && (
                            <details class="mt-1">
                              <summary class="text-xs text-slate-500 hover:text-slate-300 cursor-pointer select-none transition-colors list-none flex items-center gap-1">
                                <svg class="w-3 h-3 details-arrow transition-transform" viewBox="0 0 12 12" fill="none">
                                  <path d="M4 3l4 3-4 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Analysis
                              </summary>
                              <p class="mt-2 text-xs text-slate-400 leading-relaxed max-w-prose pr-4">
                                {pick.analysisText}
                              </p>
                            </details>
                          )}
                        </td>
                        <td class="px-4 py-3 whitespace-nowrap text-slate-500 text-xs hidden md:table-cell">
                          {pick.pickMadeTime ?? "—"}
                        </td>
                        <td class="px-4 py-3 whitespace-nowrap text-slate-500 text-xs hidden md:table-cell">
                          {pick.sportsbook ?? "—"}
                        </td>
                        <td class="px-4 py-3 text-center whitespace-nowrap">
                          {pick.result === "win" && (
                            <span class="inline-block px-2.5 py-0.5 rounded-md text-xs font-semibold bg-emerald-900/50 text-emerald-400 border border-emerald-800/50">W</span>
                          )}
                          {pick.result === "loss" && (
                            <span class="inline-block px-2.5 py-0.5 rounded-md text-xs font-semibold bg-red-900/50 text-red-400 border border-red-800/50">L</span>
                          )}
                          {pick.result === "push" && (
                            <span class="inline-block px-2.5 py-0.5 rounded-md text-xs font-semibold bg-slate-700 text-slate-300 border border-slate-600">P</span>
                          )}
                        </td>
                      </tr>
                    </Fragment>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        );
      })}

    </main>
  </body>
</html>

<style>
  details[open] summary .details-arrow {
    transform: rotate(90deg);
  }
</style>
