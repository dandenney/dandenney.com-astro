---
import BaseHead from "@/components/BaseHead.astro";
import { harnessPicks, type HarnessPick, type HarnessSource } from "@/data/harnessPicks";

export const prerender = true;

const SOURCES: HarnessSource[] = ["Review", "ChatGPT", "Claude", "Gemini", "Perplexity"];

const resolved = harnessPicks.filter((p) => p.result !== "pending");
const pending = harnessPicks.filter((p) => p.result === "pending");

// Per-source stats
function sourceStats(source: HarnessSource) {
  const picks = resolved.filter((p) => p.source === source);
  const wins = picks.filter((p) => p.result === "win").length;
  const losses = picks.filter((p) => p.result === "loss").length;
  const pct = wins + losses > 0 ? Math.round((wins / (wins + losses)) * 100) : 0;

  // Current streak
  const chrono = harnessPicks
    .filter((p) => p.source === source && p.result !== "pending")
    .sort((a, b) => a.date.localeCompare(b.date) || a.id - b.id);
  let streakType: "win" | "loss" | null = null;
  let streakCount = 0;
  for (let i = chrono.length - 1; i >= 0; i--) {
    const r = chrono[i].result;
    if (i === chrono.length - 1) {
      streakType = r === "push" ? null : (r as "win" | "loss");
      streakCount = r === "push" ? 0 : 1;
    } else if (r === streakType) {
      streakCount++;
    } else {
      break;
    }
  }
  return { wins, losses, pct, streakType, streakCount };
}

// Group resolved picks by date descending
const dateMap = new Map<string, HarnessPick[]>();
for (const pick of harnessPicks) {
  const existing = dateMap.get(pick.date) ?? [];
  existing.push(pick);
  dateMap.set(pick.date, existing);
}
const dates = Array.from(dateMap.entries()).sort(([a], [b]) => b.localeCompare(a));

function formatDate(d: string): string {
  const [, m, day] = d.split("-");
  const months = ["", "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  return `${months[parseInt(m)]} ${parseInt(day)}`;
}

function sourceColor(source: HarnessSource): string {
  const map: Record<HarnessSource, string> = {
    Review: "text-emerald-400 border-emerald-800/50 bg-emerald-900/30",
    ChatGPT: "text-teal-400 border-teal-800/50 bg-teal-900/30",
    Claude: "text-orange-400 border-orange-800/50 bg-orange-900/30",
    Gemini: "text-blue-400 border-blue-800/50 bg-blue-900/30",
    Perplexity: "text-purple-400 border-purple-800/50 bg-purple-900/30",
  };
  return map[source];
}

function sourceDot(source: HarnessSource): string {
  const map: Record<HarnessSource, string> = {
    Review: "bg-emerald-400",
    ChatGPT: "bg-teal-400",
    Claude: "bg-orange-400",
    Gemini: "bg-blue-400",
    Perplexity: "bg-purple-400",
  };
  return map[source];
}
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead
      title="Harness Picks | Dan Denney"
      description="Daily ★ My Pick from each AI model — Review, ChatGPT, Claude, Gemini, Perplexity."
    />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen antialiased">
    <main class="mx-auto max-w-5xl px-4 py-12 space-y-10">

      <!-- Page header -->
      <header class="space-y-6">
        <div>
          <h1 class="text-4xl font-bold text-white tracking-tight">Harness Picks</h1>
          <p class="mt-1 text-slate-400">★ My Pick from each model — resolved picks only</p>
        </div>

        <!-- Per-source scorecards -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
          {SOURCES.map((source) => {
            const { wins, losses, pct, streakType, streakCount } = sourceStats(source);
            return (
              <div class="rounded-xl border border-slate-800 bg-slate-900 px-4 py-4 space-y-3">
                <div class="flex items-center gap-2">
                  <span class={`w-2 h-2 rounded-full flex-shrink-0 ${sourceDot(source)}`}></span>
                  <span class="text-xs font-semibold text-slate-300 tracking-wide">{source}</span>
                </div>
                <div>
                  <div class={`text-3xl font-black tabular-nums leading-none ${pct >= 60 ? "text-emerald-400" : pct >= 50 ? "text-yellow-400" : "text-red-400"}`}>
                    {pct}<span class="text-lg">%</span>
                  </div>
                  <div class="mt-1.5 h-0.5 bg-slate-800 rounded-full overflow-hidden">
                    <div
                      class={`h-full rounded-full ${pct >= 60 ? "bg-emerald-500" : pct >= 50 ? "bg-yellow-500" : "bg-red-500"}`}
                      style={`width: ${pct}%`}
                    ></div>
                  </div>
                </div>
                <div class="flex items-center justify-between text-xs">
                  <span>
                    <span class="text-emerald-400 font-semibold">{wins}</span>
                    <span class="text-slate-500">W</span>
                    <span class="text-slate-600 mx-1">·</span>
                    <span class="text-red-400 font-semibold">{losses}</span>
                    <span class="text-slate-500">L</span>
                  </span>
                  {streakType && streakCount > 1 && (
                    <span class={`font-semibold ${streakType === "win" ? "text-emerald-400" : "text-red-400"}`}>
                      {streakCount}{streakType === "win" ? "W" : "L"}
                    </span>
                  )}
                </div>
              </div>
            );
          })}
        </div>

        <!-- Overall pending count -->
        {pending.length > 0 && (
          <p class="text-sm text-slate-500">{pending.length} pick{pending.length !== 1 ? "s" : ""} pending</p>
        )}
      </header>

      <!-- Date groups -->
      {dates.map(([date, picks]) => {
        const dayResolved = picks.filter((p) => p.result !== "pending");
        const dayWins = dayResolved.filter((p) => p.result === "win").length;
        const dayLosses = dayResolved.filter((p) => p.result === "loss").length;
        const dayPct = dayWins + dayLosses > 0 ? Math.round((dayWins / (dayWins + dayLosses)) * 100) : null;
        const hasPending = picks.some((p) => p.result === "pending");

        // Sort picks by source order
        const sortedPicks = [...picks].sort((a, b) =>
          SOURCES.indexOf(a.source) - SOURCES.indexOf(b.source)
        );

        return (
          <section class="space-y-2">
            <!-- Day header -->
            <div class="bg-slate-900 border border-slate-800 rounded-xl px-5 py-4 flex flex-wrap items-center gap-4">
              <h2 class="text-lg font-semibold text-white">{formatDate(date)}</h2>
              {dayResolved.length > 0 && (
                <div class="flex items-center gap-3 text-sm">
                  <span>
                    <span class="text-emerald-400 font-semibold">{dayWins}</span>
                    <span class="text-slate-500 ml-1">W</span>
                  </span>
                  <span>
                    <span class="text-red-400 font-semibold">{dayLosses}</span>
                    <span class="text-slate-500 ml-1">L</span>
                  </span>
                  {dayPct !== null && (
                    <span class={`inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold border ${
                      dayPct >= 60 ? "bg-emerald-900/40 text-emerald-400 border-emerald-800/50" :
                      dayPct >= 50 ? "bg-yellow-900/40 text-yellow-400 border-yellow-800/50" :
                      "bg-red-900/40 text-red-400 border-red-800/50"
                    }`}>
                      {dayPct}%
                    </span>
                  )}
                  {hasPending && (
                    <span class="text-xs text-slate-500">some pending</span>
                  )}
                </div>
              )}
              <span class="text-slate-600 text-xs ml-auto">{picks.length} picks</span>
            </div>

            <!-- Picks table -->
            <div class="overflow-x-auto rounded-xl border border-slate-800">
              <table class="w-full text-sm text-left">
                <thead class="bg-slate-900/80 text-slate-500 uppercase text-xs tracking-wider border-b border-slate-800">
                  <tr>
                    <th class="px-4 py-3 whitespace-nowrap">Source</th>
                    <th class="px-4 py-3">Pick</th>
                    <th class="px-4 py-3 whitespace-nowrap">Odds</th>
                    <th class="px-4 py-3 whitespace-nowrap text-center">Result</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/60">
                  {sortedPicks.map((pick) => (
                    <tr class="bg-slate-950 hover:bg-slate-900/60 transition-colors">
                      <td class="px-4 py-3 whitespace-nowrap">
                        <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-semibold border ${sourceColor(pick.source)}`}>
                          <span class={`w-1.5 h-1.5 rounded-full ${sourceDot(pick.source)}`}></span>
                          {pick.source}
                        </span>
                      </td>
                      <td class="px-4 py-3 text-slate-100">{pick.pick}</td>
                      <td class="px-4 py-3 whitespace-nowrap text-slate-400 font-mono text-xs">{pick.odds}</td>
                      <td class="px-4 py-3 text-center whitespace-nowrap">
                        {pick.result === "win" && (
                          <span class="inline-block px-2.5 py-0.5 rounded-md text-xs font-semibold bg-emerald-900/50 text-emerald-400 border border-emerald-800/50">W</span>
                        )}
                        {pick.result === "loss" && (
                          <span class="inline-block px-2.5 py-0.5 rounded-md text-xs font-semibold bg-red-900/50 text-red-400 border border-red-800/50">L</span>
                        )}
                        {pick.result === "push" && (
                          <span class="inline-block px-2.5 py-0.5 rounded-md text-xs font-semibold bg-slate-700 text-slate-300 border border-slate-600">P</span>
                        )}
                        {pick.result === "pending" && (
                          <span class="inline-block px-2.5 py-0.5 rounded-md text-xs font-semibold bg-slate-800 text-slate-500 border border-slate-700">—</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        );
      })}

    </main>
  </body>
</html>
