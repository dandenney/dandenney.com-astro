---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import {
  rithhmmPicks,
  rithhmmStartingBalances,
  type RithhmmPick,
  type RithhmmPortfolioAction,
  type RithhmmHermesFlag,
} from "@/data/rithhmmPicks";

export const prerender = true;

// Split pending vs resolved
const pending = rithhmmPicks.filter((p) => p.result === "pending");
const resolved = rithhmmPicks.filter((p) => p.result !== "pending");

// Bet-only performance stats
const resolvedBets = resolved.filter((p) => p.portfolioAction === "bet");
const betWins = resolvedBets.filter((p) => p.result === "win").length;
const betLosses = resolvedBets.filter((p) => p.result === "loss").length;
const betWinRate =
  betWins + betLosses > 0
    ? Math.round((betWins / (betWins + betLosses)) * 100)
    : 0;

const hasPnLData = resolvedBets.some((p) => p.betAmount != null);
// betAmount and returnAmount are combined totals; divide by 2 for per-person P&L
const totalPnL = resolvedBets.reduce((sum, p) => {
  if (p.betAmount == null) return sum;
  if (p.result === "win" && p.returnAmount != null)
    return sum + (p.returnAmount - p.betAmount) / 2;
  if (p.result === "loss") return sum - p.betAmount / 2;
  return sum;
}, 0);

// Per-person running balances
const danBalance = Number((rithhmmStartingBalances.dan + totalPnL).toFixed(2));
const gardenOfBalance = Number((rithhmmStartingBalances.gardenOf + totalPnL).toFixed(2));

// Overall signal accuracy (all resolved picks)
const allWins = resolved.filter((p) => p.result === "win").length;
const allLosses = resolved.filter((p) => p.result === "loss").length;
const allWinRate =
  allWins + allLosses > 0
    ? Math.round((allWins / (allWins + allLosses)) * 100)
    : 0;

// Adaptive columns
const hasBetData = rithhmmPicks.some((p) => p.portfolioAction != null);
const hasHermes = rithhmmPicks.some((p) => p.hermesFlag != null);
const hasBetAmount = rithhmmPicks.some((p) => p.betAmount != null);

// Group resolved by date, most recent first
const dateMap = new Map<string, RithhmmPick[]>();
for (const pick of resolved) {
  const arr = dateMap.get(pick.date) ?? [];
  arr.push(pick);
  dateMap.set(pick.date, arr);
}
const dateGroups = Array.from(dateMap.entries()).sort(([a], [b]) =>
  b.localeCompare(a)
);

// Helpers
function formatDate(d: string): string {
  const [year, m, day] = d.split("-");
  const months = [
    "",
    "Jan",
    "Feb",
    "Mar",
    "Apr",
    "May",
    "Jun",
    "Jul",
    "Aug",
    "Sep",
    "Oct",
    "Nov",
    "Dec",
  ];
  return `${months[parseInt(m)]} ${parseInt(day)}, ${year}`;
}

function fmtPnL(n: number): string {
  const abs = Math.abs(n).toFixed(2);
  return n >= 0 ? `+$${abs}` : `-$${abs}`;
}

// betAmount and returnAmount are combined totals; divide by 2 for per-person net
function pickNet(p: RithhmmPick): number | null {
  if (p.portfolioAction !== "bet") return null;
  if (p.result === "pending" || p.betAmount == null) return null;
  if (p.result === "win" && p.returnAmount != null)
    return (p.returnAmount - p.betAmount) / 2;
  if (p.result === "loss") return -p.betAmount / 2;
  if (p.result === "push") return 0;
  return null;
}

function actionClasses(action: RithhmmPortfolioAction | undefined): string {
  if (!action) return "";
  if (action === "bet")
    return "bg-blue-50 text-blue-700 border border-blue-200 dark:bg-blue-950/30 dark:text-blue-400 dark:border-blue-800/50";
  if (action === "watch")
    return "bg-slate-100 text-slate-600 border border-slate-200 dark:bg-slate-800 dark:text-slate-400 dark:border-slate-700";
  return "bg-slate-50 text-slate-400 border border-slate-100 dark:bg-slate-900 dark:text-slate-600 dark:border-slate-800";
}

function hermesClasses(flag: RithhmmHermesFlag | undefined): string {
  if (!flag || flag === "no-flag") return "";
  if (flag === "strong")
    return "bg-orange-50 text-orange-700 border border-orange-200 dark:bg-orange-950/30 dark:text-orange-400 dark:border-orange-800/50";
  return "bg-amber-50 text-amber-700 border border-amber-200 dark:bg-amber-950/30 dark:text-amber-400 dark:border-amber-800/50";
}

function sportClasses(sport: "MLB" | "NBA" | "WNBA"): string {
  if (sport === "MLB")
    return "bg-sky-50 text-sky-700 dark:bg-sky-950/40 dark:text-sky-400";
  if (sport === "WNBA")
    return "bg-pink-50 text-pink-700 dark:bg-pink-950/40 dark:text-pink-400";
  return "bg-violet-50 text-violet-700 dark:bg-violet-950/40 dark:text-violet-400";
}

function dayBets(picks: RithhmmPick[]) {
  const bets = picks.filter((p) => p.portfolioAction === "bet" && p.result !== "pending");
  const wins = bets.filter((p) => p.result === "win").length;
  const losses = bets.filter((p) => p.result === "loss").length;
  const net = bets.reduce((s, p) => {
    const n = pickNet(p);
    return n != null ? s + n : s;
  }, 0);
  const hasMoney = bets.some((p) => p.betAmount != null);
  return { wins, losses, net, hasMoney, count: bets.length };
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Rithmm Tracker | Dan Denney"
      description="Rithmm Smart Signal daily picks — bet performance by day, tracked against actual results."
    />
  </head>
  <body class="bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100">
    <main class="relative shadow-xs z-10 bg-white dark:bg-slate-900">
      <Header />

      <!-- Page header -->
      <div class="border-b border-gray-200 dark:border-slate-800">
        <div class="mx-auto max-w-7xl px-4 py-10 sm:py-12">
          <h1 class="text-5xl sm:text-6xl font-black tracking-tight text-slate-900 dark:text-white leading-none">
            Rithmm<br />Tracker
          </h1>
          <p class="mt-3 text-slate-500 dark:text-slate-400">
            Smart Signal daily picks — bet performance by day
          </p>
        </div>
      </div>

      <!-- Stats strip -->
      <div class="border-b border-gray-200 dark:border-slate-800">
        <div class="mx-auto max-w-7xl">
          <dl class="grid grid-cols-2 sm:grid-cols-4 divide-x divide-y sm:divide-y-0 divide-gray-200 dark:divide-slate-800">

            <div class="px-4 sm:px-6 py-6">
              <dt class="font-mono text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-500">Signal</dt>
              <dd class="mt-2 text-4xl font-black tabular-nums text-slate-900 dark:text-white leading-none">{allWins}–{allLosses}</dd>
              <dd class="mt-1.5 text-xs text-slate-400 dark:text-slate-500 tabular-nums">{allWinRate}% of {allWins + allLosses} resolved</dd>
            </div>

            {hasBetData ? (
              <div class="px-4 sm:px-6 py-6">
                <dt class="font-mono text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-500">Bets Placed</dt>
                <dd class="mt-2 text-4xl font-black tabular-nums text-slate-900 dark:text-white leading-none">{betWins}–{betLosses}</dd>
                <dd class="mt-1.5 text-xs text-slate-400 dark:text-slate-500">{betWinRate}% win rate</dd>
              </div>
            ) : (
              <div class="px-4 sm:px-6 py-6">
                <dt class="font-mono text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-500">Bets Placed</dt>
                <dd class="mt-2 text-4xl font-black tabular-nums text-slate-200 dark:text-slate-700 leading-none">—</dd>
                <dd class="mt-1.5 text-xs text-slate-300 dark:text-slate-700">no bets tagged</dd>
              </div>
            )}

            {hasPnLData ? (
              <div class="px-4 sm:px-6 py-6">
                <dt class="font-mono text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-500">P&amp;L</dt>
                <dd class={`mt-2 text-4xl font-black tabular-nums font-mono leading-none ${totalPnL >= 0 ? "text-green-700 dark:text-green-400" : "text-red-700 dark:text-red-400"}`}>{fmtPnL(totalPnL)}</dd>
                <dd class="mt-1.5 text-xs text-slate-400 dark:text-slate-500">net return</dd>
              </div>
            ) : (
              <div class="px-4 sm:px-6 py-6">
                <dt class="font-mono text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-500">P&amp;L</dt>
                <dd class="mt-2 text-4xl font-black tabular-nums text-slate-200 dark:text-slate-700 leading-none">—</dd>
                <dd class="mt-1.5 text-xs text-slate-300 dark:text-slate-700">no amounts yet</dd>
              </div>
            )}

            <div class="px-4 sm:px-6 py-6">
              <dt class="font-mono text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-500">Pending</dt>
              <dd class={`mt-2 text-4xl font-black tabular-nums leading-none ${pending.length > 0 ? "text-amber-600 dark:text-amber-400" : "text-slate-200 dark:text-slate-700"}`}>{pending.length}</dd>
              <dd class="mt-1.5 text-xs text-slate-400 dark:text-slate-500">{pending.length === 1 ? "open pick" : "open picks"}</dd>
            </div>

          </dl>

          {hasBetAmount && (
            <dl class="grid grid-cols-2 divide-x divide-gray-200 dark:divide-slate-800 border-t border-gray-200 dark:border-slate-800">
              <div class="px-4 sm:px-6 py-4">
                <dt class="font-mono text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-500">Dan</dt>
                <dd class={`mt-1 text-2xl font-black tabular-nums font-mono leading-none ${danBalance >= rithhmmStartingBalances.dan ? "text-green-700 dark:text-green-400" : "text-red-700 dark:text-red-400"}`}>
                  ${danBalance.toFixed(2)}
                </dd>
              </div>
              <div class="px-4 sm:px-6 py-4">
                <dt class="font-mono text-[10px] uppercase tracking-widest text-slate-400 dark:text-slate-500">GardenOf</dt>
                <dd class={`mt-1 text-2xl font-black tabular-nums font-mono leading-none ${gardenOfBalance >= rithhmmStartingBalances.gardenOf ? "text-green-700 dark:text-green-400" : "text-red-700 dark:text-red-400"}`}>
                  ${gardenOfBalance.toFixed(2)}
                </dd>
              </div>
            </dl>
          )}

          {(allWins + allLosses) > 0 && (
            <div class="flex h-0.5 bg-gray-100 dark:bg-slate-800">
              <div class="bg-green-600 dark:bg-green-500 transition-all" style={`width: ${allWinRate}%`}></div>
            </div>
          )}
        </div>
      </div>

      <!-- Content sections -->
      <div class="mx-auto max-w-7xl px-4 pt-8 pb-16 space-y-10">

        <!-- Pending picks -->
        {pending.length > 0 && (
          <section>
            <div class="flex items-center gap-4 mb-4">
              <h2 class="text-xs font-black uppercase tracking-[0.15em] text-slate-900 dark:text-white whitespace-nowrap">
                Pending <span class="font-normal text-amber-600 dark:text-amber-400">{pending.length} open</span>
              </h2>
              <div class="flex-1 h-px bg-gray-200 dark:bg-slate-800"></div>
            </div>

            <div class="overflow-x-auto border border-gray-200 dark:border-slate-800 rounded">
              <table class="w-full text-sm text-left">
                <thead>
                  <tr class="bg-gray-50 dark:bg-slate-800/50 border-b border-gray-200 dark:border-slate-800">
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Sport</th>
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Date</th>
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400">Pick</th>
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Odds</th>
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Conf</th>
                    {hasBetData && <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Action</th>}
                    {hasHermes && <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Hermes</th>}
                    {hasBetAmount && <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap text-right">Bet</th>}
                  </tr>
                </thead>
                <tbody>
                  {pending.map((pick) => (
                    <tr class="border-t border-gray-100 dark:border-slate-800 hover:bg-gray-50 dark:hover:bg-slate-800/40 transition-colors">
                      <td class="px-4 py-2.5 whitespace-nowrap">
                        <span class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider ${sportClasses(pick.sport)}`}>
                          {pick.sport}
                        </span>
                      </td>
                      <td class="px-4 py-2.5 whitespace-nowrap font-mono text-xs text-slate-400 dark:text-slate-500">
                        {formatDate(pick.date)}
                      </td>
                      <td class="px-4 py-2.5">
                        <div class="font-medium text-slate-900 dark:text-slate-100">{pick.pick}</div>
                        <div class="text-xs text-slate-400 dark:text-slate-500 mt-0.5">{pick.matchup}</div>
                      </td>
                      <td class="px-4 py-2.5 whitespace-nowrap font-mono text-xs text-slate-500 dark:text-slate-400">
                        {pick.odds}
                      </td>
                      <td class="px-4 py-2.5 whitespace-nowrap font-mono text-xs text-slate-600 dark:text-slate-400 tabular-nums">
                        {pick.confidence}%
                      </td>
                      {hasBetData && (
                        <td class="px-4 py-2.5 whitespace-nowrap">
                          {pick.portfolioAction ? (
                            <span class={`inline-block px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide ${actionClasses(pick.portfolioAction)}`}>
                              {pick.portfolioAction}
                            </span>
                          ) : (
                            <span class="text-slate-300 dark:text-slate-700">—</span>
                          )}
                        </td>
                      )}
                      {hasHermes && (
                        <td class="px-4 py-2.5 whitespace-nowrap">
                          {pick.hermesFlag && pick.hermesFlag !== "no-flag" ? (
                            <span class={`inline-block px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide ${hermesClasses(pick.hermesFlag)}`}>
                              {pick.hermesFlag}
                            </span>
                          ) : (
                            <span class="text-slate-300 dark:text-slate-700">—</span>
                          )}
                        </td>
                      )}
                      {hasBetAmount && (
                        <td class="px-4 py-2.5 whitespace-nowrap text-right font-mono text-xs text-slate-500 dark:text-slate-400">
                          {pick.betAmount != null ? `$${pick.betAmount.toFixed(2)}` : "—"}
                        </td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        <!-- History: unified table -->
        <section>
          <div class="flex items-center gap-4 mb-4">
            <h2 class="text-xs font-black uppercase tracking-[0.15em] text-slate-900 dark:text-white whitespace-nowrap">History</h2>
            <div class="flex-1 h-px bg-gray-200 dark:bg-slate-800"></div>
          </div>

          {dateGroups.length === 0 && (
            <p class="text-slate-400 dark:text-slate-500 text-sm">No resolved picks yet.</p>
          )}

          {dateGroups.length > 0 && (
            <div class="overflow-x-auto border border-gray-200 dark:border-slate-800 rounded">
              <table class="w-full text-sm text-left">
                <thead>
                  <tr class="bg-gray-50 dark:bg-slate-800/50 border-b border-gray-200 dark:border-slate-800">
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Sport</th>
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400">Pick</th>
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Odds</th>
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Conf</th>
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap hidden sm:table-cell">Model</th>
                    {hasBetData && <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Action</th>}
                    {hasHermes && <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap">Hermes</th>}
                    {hasBetAmount && <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap text-right">Bet</th>}
                    <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap text-center">Result</th>
                    {hasBetAmount && <th class="px-4 py-2.5 font-mono text-[10px] uppercase tracking-widest text-slate-400 whitespace-nowrap text-right">Net</th>}
                  </tr>
                </thead>
                <tbody>
                  {dateGroups.map(([date, picks]) => {
                    const { net: dayNet, hasMoney, count: betCount } = dayBets(picks);
                    const dayWins = picks.filter((p) => p.result === "win").length;
                    const dayLosses = picks.filter((p) => p.result === "loss").length;
                    const colspan = 6 + (hasBetData ? 1 : 0) + (hasHermes ? 1 : 0) + (hasBetAmount ? 2 : 0);
                    return (
                      <>
                        <tr class="border-t-2 border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800/30 first:border-t-0">
                          <td colspan={colspan} class="px-4 py-2">
                            <div class="flex flex-wrap items-baseline gap-x-3">
                              <span class="text-sm font-black text-slate-900 dark:text-white">{formatDate(date)}</span>
                              <span class="font-mono text-[10px] tabular-nums text-slate-400 dark:text-slate-500 uppercase tracking-wider">{dayWins}W {dayLosses}L</span>
                              {betCount > 0 && (
                                <span class="font-mono text-[10px] text-slate-300 dark:text-slate-600 uppercase tracking-wider">{betCount} bet{betCount !== 1 ? "s" : ""}</span>
                              )}
                              {hasMoney && (
                                <span class={`ml-auto font-mono text-xs font-semibold tabular-nums ${dayNet >= 0 ? "text-green-700 dark:text-green-400" : "text-red-700 dark:text-red-400"}`}>
                                  {fmtPnL(dayNet)}
                                </span>
                              )}
                            </div>
                          </td>
                        </tr>
                        {picks.map((pick) => {
                          const net = pickNet(pick);
                          return (
                            <tr class="border-t border-gray-100 dark:border-slate-800 hover:bg-gray-50 dark:hover:bg-slate-800/30 transition-colors">
                              <td class="px-4 py-2.5 whitespace-nowrap">
                                <span class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider ${sportClasses(pick.sport)}`}>
                                  {pick.sport}
                                </span>
                              </td>
                              <td class="px-4 py-2.5">
                                <div class="font-medium text-slate-900 dark:text-slate-100 leading-snug">{pick.pick}</div>
                                <div class="text-xs text-slate-400 dark:text-slate-500 mt-0.5">{pick.matchup}</div>
                              </td>
                              <td class="px-4 py-2.5 whitespace-nowrap font-mono text-xs text-slate-500 dark:text-slate-400">
                                {pick.odds}
                              </td>
                              <td class="px-4 py-2.5 whitespace-nowrap font-mono text-xs text-slate-600 dark:text-slate-400 tabular-nums">
                                {pick.confidence}%
                              </td>
                              <td class="px-4 py-2.5 whitespace-nowrap text-xs text-slate-400 dark:text-slate-500 hidden sm:table-cell">
                                {pick.modelProjection}
                              </td>
                              {hasBetData && (
                                <td class="px-4 py-2.5 whitespace-nowrap">
                                  {pick.portfolioAction ? (
                                    <span class={`inline-block px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide ${actionClasses(pick.portfolioAction)}`}>
                                      {pick.portfolioAction}
                                    </span>
                                  ) : (
                                    <span class="text-slate-300 dark:text-slate-700">—</span>
                                  )}
                                </td>
                              )}
                              {hasHermes && (
                                <td class="px-4 py-2.5 whitespace-nowrap">
                                  {pick.hermesFlag && pick.hermesFlag !== "no-flag" ? (
                                    <span class={`inline-block px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide ${hermesClasses(pick.hermesFlag)}`}>
                                      {pick.hermesFlag}
                                    </span>
                                  ) : (
                                    <span class="text-slate-300 dark:text-slate-700">—</span>
                                  )}
                                </td>
                              )}
                              {hasBetAmount && (
                                <td class="px-4 py-2.5 whitespace-nowrap text-right font-mono text-xs text-slate-500 dark:text-slate-400">
                                  {pick.betAmount != null ? `$${pick.betAmount.toFixed(2)}` : "—"}
                                </td>
                              )}
                              <td class="px-4 py-2.5 whitespace-nowrap text-center">
                                {pick.result === "win" && <span class="text-xs font-black text-green-700 dark:text-green-400">W</span>}
                                {pick.result === "loss" && <span class="text-xs font-black text-red-700 dark:text-red-400">L</span>}
                                {pick.result === "push" && <span class="text-xs font-black text-slate-400 dark:text-slate-500">P</span>}
                              </td>
                              {hasBetAmount && (
                                <td class={`px-4 py-2.5 whitespace-nowrap text-right font-mono text-xs font-semibold ${
                                  net == null
                                    ? "text-slate-400 dark:text-slate-600"
                                    : net > 0
                                      ? "text-green-700 dark:text-green-400"
                                      : net < 0
                                        ? "text-red-700 dark:text-red-400"
                                        : "text-slate-500 dark:text-slate-400"
                                }`}>
                                  {net != null ? fmtPnL(net) : "—"}
                                </td>
                              )}
                            </tr>
                          );
                        })}
                      </>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </section>

      </div>
    </main>
    <Footer />
  </body>
</html>
