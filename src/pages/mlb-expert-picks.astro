---
import BaseHead from "../components/BaseHead.astro";
import { mlbExpertPicks, type MlbExpertPick } from "../data/mlbExpertPicks";

export const prerender = true;

// Group by author, preserving insertion order (data is already ordered by date desc from the source)
const bettorMap = new Map<string, MlbExpertPick[]>();
for (const pick of mlbExpertPicks) {
  const existing = bettorMap.get(pick.authorName) ?? [];
  existing.push(pick);
  bettorMap.set(pick.authorName, existing);
}

// Sort each bettor's picks by gameDateTime ascending
const bettors = Array.from(bettorMap.entries()).map(([name, picks]) => {
  const sorted = [...picks].sort(
    (a, b) => new Date(a.gameDateTime).getTime() - new Date(b.gameDateTime).getTime(),
  );
  const wins = sorted.filter((p) => p.result === "win").length;
  const losses = sorted.filter((p) => p.result === "loss").length;
  const pushes = sorted.filter((p) => p.result === "push").length;
  let longestLossStreak = 0;
  let currentStreak = 0;
  for (const pick of sorted) {
    if (pick.result === "loss") {
      currentStreak++;
      if (currentStreak > longestLossStreak) longestLossStreak = currentStreak;
    } else {
      currentStreak = 0;
    }
  }
  return { name, picks: sorted, wins, losses, pushes, longestLossStreak };
});

// Sort bettors by total pick count descending
bettors.sort((a, b) => b.picks.length - a.picks.length);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead
      title="MLB Expert Picks | Dan Denney"
      description="CBS SportsLine MLB expert picks broken down by bettor."
    />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen antialiased">
    <main class="mx-auto max-w-7xl px-4 py-12 space-y-16">

      <header>
        <h1 class="text-3xl font-bold text-white">MLB Expert Picks</h1>
        <p class="mt-1 text-slate-400 text-sm">{mlbExpertPicks.length} picks across {bettors.length} bettors</p>
      </header>

      {bettors.map(({ name, picks, wins, losses, pushes, longestLossStreak }) => {
        const firstPick = picks[0];
        return (
          <section>
            <!-- Bettor header -->
            <div class="flex items-center gap-4 mb-4">
              {firstPick.authorImageUrl && (
                <img
                  src={firstPick.authorImageUrl}
                  alt={name}
                  class="w-12 h-12 rounded-full object-cover bg-slate-800"
                />
              )}
              <div>
                <h2 class="text-xl font-semibold text-white">{name}</h2>
                <p class="text-slate-400 text-sm">{firstPick.authorOtherName}</p>
              </div>
              <div class="ml-auto flex gap-6 text-sm text-slate-400">
                <span><span class="text-emerald-400 font-semibold">{wins}</span> W</span>
                <span><span class="text-red-400 font-semibold">{losses}</span> L</span>
                {pushes > 0 && (
                  <span><span class="text-slate-300 font-semibold">{pushes}</span> P</span>
                )}
                <span class="text-slate-500">{picks.length} total</span>
                <span class="border-l border-slate-700 pl-6">
                  <span class="text-orange-400 font-semibold">{longestLossStreak}</span>
                  <span class="text-slate-500 ml-1">longest L streak</span>
                </span>
              </div>
            </div>

            <!-- Picks table -->
            <div class="overflow-x-auto rounded-lg border border-slate-800">
              <table class="w-full text-sm text-left">
                <thead class="bg-slate-900 text-slate-400 uppercase text-xs tracking-wider">
                  <tr>
                    <th class="px-4 py-3 whitespace-nowrap">Game Date</th>
                    <th class="px-4 py-3 whitespace-nowrap">Matchup</th>
                    <th class="px-4 py-3 whitespace-nowrap">Bet Type</th>
                    <th class="px-4 py-3">Bet</th>
                    <th class="px-4 py-3 whitespace-nowrap">Pick Made</th>
                    <th class="px-4 py-3 whitespace-nowrap">Book</th>
                    <th class="px-4 py-3 whitespace-nowrap text-center">Result</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                  {picks.map((pick) => (
                    <tr class="bg-slate-950 hover:bg-slate-900 transition-colors">
                      <td class="px-4 py-3 whitespace-nowrap text-slate-300">
                        {pick.gameDateTime.split(",")[0].replace(/\s+\d{4}$/, "").trim()}
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-slate-300">
                        <span>{pick.homeTeam}</span>
                        <span class="text-slate-500 mx-1">vs</span>
                        <span>{pick.awayTeam}</span>
                        {(pick.homeScore !== "" || pick.awayScore !== "") && (
                          <span class="ml-2 text-slate-500 text-xs">
                            {pick.homeScore}–{pick.awayScore}
                          </span>
                        )}
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-slate-400">{pick.betType}</td>
                      <td class="px-4 py-3 text-slate-100">{pick.betTitle}</td>
                      <td class="px-4 py-3 whitespace-nowrap text-slate-500 text-xs">{pick.pickMadeTime}</td>
                      <td class="px-4 py-3 whitespace-nowrap text-slate-500 text-xs">{pick.sportsbook ?? "—"}</td>
                      <td class="px-4 py-3 text-center">
                        {pick.result === "win" && (
                          <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-emerald-900/50 text-emerald-400">WIN</span>
                        )}
                        {pick.result === "loss" && (
                          <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-red-900/50 text-red-400">LOSS</span>
                        )}
                        {pick.result === "push" && (
                          <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-slate-700 text-slate-300">PUSH</span>
                        )}
                        {pick.result === "pending" && (
                          <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-slate-800 text-slate-500">–</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        );
      })}

    </main>
  </body>
</html>
