        <div class="reviews-grid mt-12 grid grid-cols-1 md:grid-cols-2 border-y border-gray-200 dark:border-slate-700">
          {
            reviews.map((review) => (
              <a
                class="reviews-grid-item group flex items-center gap-6 md:gap-8 no-underline p-6 md:p-8 bg-slate-50 dark:bg-slate-900"
                href={`/no-reserv-ai-tions/${review.slug}`}
              >
                <figure
                  class="shrink-0 bg-white pb-4 pt-2 px-2 shadow-sm transition-transform duration-300 group-hover:-rotate-3"
                  transition:name={`${review.data.title}-img`}
                >
                  <img
                    src={`/no-reserv-ai-tions/${review.data.heroImage}-thumb.webp`}
                    alt={review.data.heroImageAlt}
                    height="120"
                    width="160"
                    class="w-32 md:w-40"
                    loading="lazy"
                  />
                </figure>
                <div class="min-w-0">
                  <p class="text-xs font-mono uppercase tracking-widest text-gray-400 dark:text-slate-500">
                    <span class="whitespace-nowrap">[&nbsp;{toTitleCase(review.data.city)}, {review.data.country === "United States" ? toTitleCase(review.data.state) : review.data.country}&nbsp;]</span>
                  </p>
                  <h3 class="mt-2 text-2xl font-bold uppercase leading-tight text-red-700 transition-colors group-hover:text-red-800 dark:text-red-400 dark:group-hover:text-red-300 md:text-3xl">
                    {review.data.title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-gray-500 dark:text-slate-400 line-clamp-2">
                    {review.data.description}
                  </p>
                </div>
              </a>
            ))
          }
        </div>

        <div class="mt-8 px-8">
          <a href="/no-reserv-ai-tions" class="btn-link">View No ReservAItions</a>
        </div>
      </section>
    </main>
    <Footer />
